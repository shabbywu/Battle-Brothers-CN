  {
    "key": "e7de98b13b6c41b8937ebca30fd811fee38c5a03c11c3b298eb6a840f3ebcfa0",
    "original": "Character Screen",
    "translation": "",
    "context": ""
  },
  {
    "key": "e7184010ac9fcaa81e931228a2811402bb036aaa850901b7f89c803b4c42b6ca",
    "original": "Clicking a non-targeted skill e.g. Shieldwall, Rally the Troops etc. while pressing this key will cause it to not be used immediately and instead behave as a targeted skill that can be used on your character. This allows you to preview the costs of the skill and easily check the predicted affordability of skills after its use.",
    "translation": "",
    "context": ""
  },
  {
    "key": "82b5eb44877393ba260d1d393b282a6cd859d3e0bdd21529c4a34405752c4391",
    "original": "Collapse Actives When",
    "translation": "",
    "context": ""
  },
  {
    "key": "1ea201a0e7fbd86acaf052c474126805dc01bbf9854b1a779985f1bddc7ec240",
    "original": "Collapse Effects When",
    "translation": "",
    "context": ""
  },
  {
    "key": "4487397280691346dbeb227abb4dca1dc5b6fa50bcfa66d0b3f8d848663dbc2d",
