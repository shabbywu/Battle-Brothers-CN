  },
  {
    "key": "57d557d0f7bee501f3bd6415885285cbc9c32e5bbf1d33c1404fc426b1819c3c",
    "original": "During a [turn|Concept.Turn] gain ",
    "translation": "",
    "context": "\"During a [turn|Concept.Turn] gain \" + getroottable().MSU.Text.colorPositive(\"half\") + \" of the stacks gained during the previous [turn|Concept.Turn] as additional [Action Points|Concept.ActionPoints] and attacks build up \" + getroottable().MSU.Text.colorPositive(\"5%\") + \" less [Fatigue|Concept.Fatigue] per such stack.\""
  },
  {
    "key": "7871ea006c3332d414ebe71102bfb5f80bead92203352affadc920aabed03d44",
    "original": "During your [turn|Concept.Turn], after a successful attack against a target, all subsequent attacks have a ",
    "translation": "",
    "context": "\"During your [turn|Concept.Turn], after a successful attack against a target, all subsequent attacks have a \" + getroottable().MSU.Text.colorNegative(\"33%\") + \" reduced [threshold|Concept.InjuryThreshold] to inflict [injury|Concept.InjuryTemporary] and will inflict [$ $|Skill+bleeding_effect]. If any of the attacks inflicted an [injury|Concept.InjuryTemporary]., the attacks inflict additional [$ $|Skill+bleeding_effect].\""
  },
  {
    "key": "a47c6e78bc740efaa091bd7201f9bf2ce690ddc557813387ba2bcd3b994fa3f8",
    "original": "During your [turn|Concept.Turn], when attacking with one-handed flails, perform a free extra attack with ",
    "translation": "",
    "context": "\"During your [turn|Concept.Turn], when attacking with one-handed flails, perform a free extra attack with \" + getroottable().MSU.Text.colorNegative(\"50%\") + \" less damage against a different adjacent enemy who has lower current [Reach|Concept.Reach] than you. This extra attack does not increase your [Reach|Concept.Reach].\""
  },
  {
    "key": "376939ce770c280c85a6629f66501030adabb5dc962f1249cd7f0e4b13c0e296",
    "original": "During your turn, attacks have a ",
    "translation": "",
    "context": "\"During your turn, attacks have a \" + getroottable().MSU.Text.colorPositive(\"50%\") + \" chance to perform a free extra attack of the same type with \" + getroottable().MSU.Text.colorNegative(\"50%\") + \" reduced damage.\""
  },
  {
    "key": "895fd761c6f49d6601db2d2acf2d5029d9cb3c86ca042259a2ac8028a17a0c54",
    "original": "Dynamic Duo",
    "translation": "",
    "context": "RF_DynamicDuo = \"Dynamic Duo\""
  },
  {
    "key": "a3ad1cc473fcff05c1687e322cd7acbd5e65ee0abecf6267669f8b29dbd31122",
    "original": "Each attack that does damage to [Hitpoints|Concept.Hitpoints] triggers a mental [morale check|Concept.Bravery] for the target. If the target fails the morale check, it gains the [$ $|Skill+horrified_effect] effect.",
    "translation": "",
    "context": ""
  },
  {
    "key": "fed03b227d56432bfa03649ab357bb25c0ca2d7152c6e8e42ac99d93548a7ab5",
    "original": "Each stack increases [Action Points|Concept.ActionPoints] by ",
    "translation": "",
    "context": "\"Each stack increases [Action Points|Concept.ActionPoints] by \" + getroottable().MSU.Text.colorPositive(\"+1\") + \" and [Initiative|Concept.Initiative] by \" + getroottable().MSU.Text.colorPositive(\"+10\") + \".\""
  },
  {
    "key": "e595e98fb4ff7b5268a34dd0e8546663e764d47fbd806d2e100001e4f9fdbf92",
    "original": "Each stack increases your [Initiative|Concept.Initiative] by ",
    "translation": "",
    "context": "\"Each stack increases your [Initiative|Concept.Initiative] by \" + getroottable().MSU.Text.colorPositive(\"+15\") + \". This bonus is carried over into your next [turn|Concept.Turn] but only until the first skill used or upon [waiting|Concept.Wait] that [turn|Concept.Turn].\""
  },
  {
    "key": "ecaba34a54fb74811cbe126cc78320a3da5e5e1c0f8016cd9cd82623f0a840e1",
    "original": "Each stack of rage increases [Resolve|Concept.Bravery] and [Initiative|Concept.Initiative] by ",
    "translation": "",
    "context": "\"Each stack of rage increases [Resolve|Concept.Bravery] and [Initiative|Concept.Initiative] by \" + getroottable().MSU.Text.colorPositive(\"+2\") + \" and Melee Damage by \" + getroottable().MSU.Text.colorPositive(\"2%\") + \". Each stack lowers [Melee Defense|Concept.MeleeDefense] by \" + getroottable().MSU.Text.colorNegative(\"-1\") + \" and lowers damage received by \" + getroottable().MSU.Text.colorPositive(\"2%\") + \", up to a maximum of 70%.\""
  },
  {
    "key": "8f81a40a955e110ca8d1824909f20bf29a6574b3a36fee33119b70379e00aa45",
    "original": "Each subsequent [$ $|Skill+quick_shot] in a [turn|Concept.Turn] builds ",
    "translation": "",
    "context": "\"Each subsequent [$ $|Skill+quick_shot] in a [turn|Concept.Turn] builds \" + getroottable().MSU.Text.colorNegative(\"10%\") + \" more [Fatigue|Concept.Fatigue].\""
  },
  {
    "key": "9e538f0004c80732dc1212c4b54ff1803de134cd9a4b8e1bb91a6c710b43a73a",
    "original": "En Garde",
    "translation": "",
    "context": "RF_EnGarde = \"En Garde\""
  },
  {
    "key": "791c555e6d9b0781640135edbc17b947896c63301b1757b26cc908beb2a21d64",
    "original": "Enemies [$ $|Skill+net_effect] by you at a distance of 2 or fewer tiles have a ",
    "translation": "",
    "context": "\"Enemies [$ $|Skill+net_effect] by you at a distance of 2 or fewer tiles have a \" + getroottable().MSU.Text.colorNegative(\"50%\") + \" increased [Action Point|Concept.ActionPoints] cost for using the [$ $|Skill+break_free_skill] skill.\""
  },
  {
    "key": "641e7ecba4e0c1743118b366aa7571e1686ff79b0fcc5a0cd5c3886309e2da06",
    "original": "Enemies within 2 tiles are considered [surrounded|Concept.Surrounding] by you for the purposes of hit-chance bonus for any allies attacking that target.",
    "translation": "",
    "context": ""
  },
  {
    "key": "a6f47b219d0d84f556e5dba57463d257b7f0255d8ebbd962e0c2d9ac9b961889",
    "original": "Entrenched",
    "translation": "",
    "context": "RF_Entrenched = \"Entrenched\""
  },
  {
    "key": "6b50a9120886f2e0e374278ef972572f65cc0cb14853727b3a2244aa86e1a178",
    "original": "Equipped Net",
    "translation": "",
    "context": "Requirement = \"Equipped Net\""
  },
  {
    "key": "9d23aecee5a098ed344a84bf2c9b18b35150f7b1cb9e411aaeb0b52978a0f76d",
    "original": "Every attack with flails increases your current [Reach|Concept.Reach] by ",
    "translation": "",
    "context": "\"Every attack with flails increases your current [Reach|Concept.Reach] by \" + getroottable().MSU.Text.colorPositive(\"+1\") + \" until your next [turn|Concept.Turn].\""
  },
  {
    "key": "a1887f5e882b97f92072da39ddb0a9eba1b4641aa30fcddfcb81faeab8ee8e31",
    "original": "Every hit applies the [$ $|Skill+rf_rattled_effect] effect for one [turn|Concept.Turn].",
    "translation": "",
    "context": ""
  },
  {
    "key": "55277131879b194f112f4c721650113f434ce7acdcd1e30724695267ea895d11",
    "original": "Every successful hit has a chance to apply the [$ $|Skill+rf_dismantled_effect] effect, which causes the target to receive a stacking ",
    "translation": "",
    "context": "\"Every successful hit has a chance to apply the [$ $|Skill+rf_dismantled_effect] effect, which causes the target to receive a stacking \" + getroottable().MSU.Text.colorNegative(\"+20%\") + \" damage received ignoring armor on the body part hit for the remainder of the combat.\""
  },
  {
    "key": "23b73e9fc9ca9c42d83913aedd9f036d5a2a2140035abde08d7142fa0b6102cb",
    "original": "Every time an opponent attacks you in melee or you attack an opponent, gain a stacking ",
    "translation": "",
    "context": "\"Every time an opponent attacks you in melee or you attack an opponent, gain a stacking \" + getroottable().MSU.Text.colorPositive(\"+3\") + \" [Melee Skill|Concept.MeleeSkill] and [Melee Defense|Concept.MeleeDefense] against that opponent for the remainder of the combat.\""
  },
  {
    "key": "1f03c4edc4c0e2385d72bc40525fb88afd13bc94bc785bc1193a3deb1296bfa4",
    "original": "Every time you are hit, gain a stacking ",
    "translation": "",
    "context": "\"Every time you are hit, gain a stacking \" + getroottable().MSU.Text.colorPositive(\"25%\") + \" damage bonus for your next attack.\""
  },
  {
    "key": "07437db655fab1425fbde3b254aa8b9a2824beadfc6a44b67502f1f0eadc2b64",
    "original": "Every time you spend a level-up, gain between ",
    "translation": "",
    "context": "\"Every time you spend a level-up, gain between \" + getroottable().MSU.Text.colorPositive(1) + \" and \" + getroottable().MSU.Text.colorPositive(3) + \" [talent|Concept.Talent] stars in a random attribute in which you have fewer than 3 stars.\""
  },
  {
    "key": "06dbbb676d2f7b77f97301a2bde5e2e55eeb4061a0256c17775871b38c507a6b",
    "original": "Everything can be learned if you put your mind to it.",
