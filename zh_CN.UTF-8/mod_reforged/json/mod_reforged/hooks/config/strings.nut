    "original": "[Vision|Concept.SightDistance] and maximum shooting range with bows is increased by ",
    "translation": "",
    "context": "\"[Vision|Concept.SightDistance] and maximum shooting range with bows is increased by \" + getroottable().MSU.Text.colorPositive(\"+1\") + \".\""
  },
