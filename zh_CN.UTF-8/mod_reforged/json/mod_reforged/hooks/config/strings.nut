    "original": "Welcome to the chopping block!",
    "translation": "",
    "context": "Fluff = \"Welcome to the chopping block!\""
  },
  {
    "key": "9fd886d8dc38933b39e82b33abf558f7555661a822b712e0836a704aefcad552",
    "original": "When attacking a target against whom you have a [Reach Disadvantage|Concept.ReachAdvantage], reduce this disadvantage by ",
    "translation": "",
    "context": "\"When attacking a target against whom you have a [Reach Disadvantage|Concept.ReachAdvantage], reduce this disadvantage by \" + getroottable().MSU.Text.colorPositive(1) + \" if your [Initiative|Concept.Initiative] is greater than that of your target.\""
  },
  {
    "key": "89ac60e43ad71ea2beab6e0ab2e962b0eedbc3314f2d45bf28d2e75ffc1cddd9",
    "original": "When attacking a target against whom you have a [Reach Disadvantage|Concept.ReachDisadvantage], reduce this disadvantage by 1 for every 300 current combined head and body armor durability you have.",
    "translation": "",
    "context": ""
  },
  {
    "key": "7416992df6851323b642aa8c96a4850375d8fbf3f75eaaa69e46b4b4fd3bffd1",
    "original": "When attacking a target at a range of 2 tiles, gain ",
    "translation": "",
    "context": "\"When attacking a target at a range of 2 tiles, gain \" + getroottable().MSU.Text.colorNegative(\"+20%\") + \" chance to hit the head.\""
  },
  {
    "key": "1caf82e515db8d4d18b4f9ad8993b6b5c1400ebce5ca2042e25b4d4307071ce1",
    "original": "When attacking a target which already has at least 3 stacks of [$ $|Skill+bleeding_effect], you have a ",
    "translation": "",
    "context": "\"When attacking a target which already has at least 3 stacks of [$ $|Skill+bleeding_effect], you have a \" + getroottable().MSU.Text.colorPositive(\"33%\") + \" chance to apply an injury. If the attack already applied an injury, this applies an additional injury.\""
  },
  {
    "key": "112848d20b1f21d2deaca92c361c39e9be12daf154a44a9270372c35b962e7cf",
    "original": "When attacking or defending in melee, gain ",
    "translation": "",
    "context": "\"When attacking or defending in melee, gain \" + getroottable().MSU.Text.colorPositive(\"+1\") + \" [Reach|Concept.Reach] per adjacent ally who is wielding a two-handed weapon with a piercing attack or a shield.\""
  },
  {
    "key": "e4583fe836d21e408103dd299f29d40a765d54d32b852443cde80fc7d8c94229",
    "original": "When equipped with a net, gain the [$ $|Skill+rf_trip_artist_effect] effect.",
    "translation": "",
    "context": ""
  },
  {
    "key": "4a63de01c80e2c49d99c3b1a800f632b5fef7072fb307231914c77db4ca23d3b",
    "original": "When inflicting an [injury|Concept.InjuryTemporary] with an attack, if you meet the [threshold|Concept.InjuryThreshold] for the lowest possible injury, instead inflict one with the highest [threshold|Concept.InjuryThreshold].",
    "translation": "",
    "context": ""
  },
  {
    "key": "aabd1c8a42b9ffa69f0934fb877f507253ed031c629fc21f2b99de8de6f03c54",
    "original": "When no members of your faction are adjacent to you nor are there more than 1 within 2 tiles of distance from you, gain a ",
    "translation": "",
    "context": "\"When no members of your faction are adjacent to you nor are there more than 1 within 2 tiles of distance from you, gain a \" + getroottable().MSU.Text.colorPositive(\"15%\") + \" bonus to [Melee Skill|Concept.MeleeSkill], [Ranged Skill|Concept.RangeSkill], [Melee Defense|Concept.MeleeDefense], [Ranged Defense|Concept.RangeDefense], and [Resolve|Concept.Bravery].\""
  },
  {
    "key": "dabb597f7ae146e5e157f2481b4eb3dbc0915f547bc2281a0c5692aa6c4dba78",
    "original": "When standing adjacent to an ally wielding a melee weapon who is not [engaged in melee|Concept.ZoneOfControl], gain ",
    "translation": "",
    "context": "\"When standing adjacent to an ally wielding a melee weapon who is not [engaged in melee|Concept.ZoneOfControl], gain \" + getroottable().MSU.Text.colorPositive(\"+7\") + \" [Ranged Skill|Concept.RangeSkill], [Ranged Defense|Concept.RangeDefense], and [Resolve|Concept.Bravery]. The bonus increases by \" + getroottable().MSU.Text.colorPositive(\"+2\") + \" every [turn|Concept.Turn] up to a maximum of \" + getroottable().MSU.Text.colorPositive(\"+15\") + \" as long as you continue to start your [turn|Concept.Turn] adjacent to any ally wielding a melee weapon who is not [engaged in melee|Concept.ZoneOfControl].\""
  },
  {
    "key": "99f16ba25b6e62bc801cbacc908e7b245625ebbd1854df4a9acadee15299f3e9",
    "original": "When starting your [turn|Concept.Turn] with a spear equipped, the first piercing spear attack costs ",
    "translation": "",
    "context": "\"When starting your [turn|Concept.Turn] with a spear equipped, the first piercing spear attack costs \" + getroottable().MSU.Text.colorPositive(\"no\") + \" [Action Points|Concept.ActionPoints] and builds \" + getroottable().MSU.Text.colorPositive(\"50%\") + \" less [Fatigue|Concept.Fatigue]. This expires upon moving from your position if using a two-handed spear, or moving more than 1 tile if using a one-handed spear.\""
  },
  {
    "key": "fafcb00bb544b5264e57237ad2061387312c80274b2b3c1a66fa5be3efae24cc",
    "original": "When surrounded by carnage, you feel revitalized and right at home!",
    "translation": "",
    "context": "Fluff = \"When surrounded by carnage, you feel revitalized and right at home!\""
  },
  {
    "key": "06cc960bc58c4e4ef769ad5360336a81e94dc807921c47ae2c186734d2f74c27",
    "original": "When the number of adjacent allies is greater than or equal to the number of adjacent enemies, you may ignore [Zone of Control|Concept.ZoneOfControl] for your next movement action.",
    "translation": "",
    "context": ""
  },
  {
    "key": "7181525fadfa73315fa5745756b2999cbc4473c6de66c0ec662d8a6413886f59",
    "original": "When used on an adjacent target, reduces their [Melee Defense|Concept.MeleeDefense] and [Ranged Defense|Concept.RangeDefense] by ",
    "translation": "",
    "context": "\"When used on an adjacent target, reduces their [Melee Defense|Concept.MeleeDefense] and [Ranged Defense|Concept.RangeDefense] by \" + getroottable().MSU.Text.colorPositive(\"20%\") + \" of the user's [Resolve|Concept.Bravery].\""
  },
  {
    "key": "15a4b5e629cd3a2484493c040b6e0a1cc7d1c59a174c2605d0527e12a21fcee5",
    "original": "When using a non-fencing sword, the [Action Point|Concept.ActionPoints] cost of non-AOE skills is reduced by ",
    "translation": "",
    "context": "\"When using a non-fencing sword, the [Action Point|Concept.ActionPoints] cost of non-AOE skills is reduced by \" + getroottable().MSU.Text.colorPositive(1) + \" and these skills build up \" + getroottable().MSU.Text.colorPositive(\"25%\") + \" less [Fatigue|Concept.Fatigue].\""
  },
  {
    "key": "342763ed8d6f835694d40a3109a56b613b3493895b242fe46b34c4ee8fa782c6",
    "original": "When using a one-handed fencing sword, the [Action Point|Concept.ActionPoints] costs of [$ $|Skill+rf_sword_thrust_skill], [$ $|Skill+riposte] and [$ $|Skill+lunge_skill] are reduced by ",
    "translation": "",
    "context": "\"When using a one-handed fencing sword, the [Action Point|Concept.ActionPoints] costs of [$ $|Skill+rf_sword_thrust_skill], [$ $|Skill+riposte] and [$ $|Skill+lunge_skill] are reduced by \" + getroottable().MSU.Text.colorPositive(1) + \".\""
  },
  {
    "key": "81722464448c53f07f03e13def93be79a850ad18f33858849c15b1f412aa71c1",
    "original": "When using a throwing weapon which uses ammo, whenever you end your movement over an enemy's corpse during your [turn|Concept.Turn], recover ",
    "translation": "",
    "context": "\"When using a throwing weapon which uses ammo, whenever you end your movement over an enemy's corpse during your [turn|Concept.Turn], recover \" + getroottable().MSU.Text.colorPositive(1) + \" ammo. Immediately afterward, the next throwing attack costs \" + getroottable().MSU.Text.colorPositive(\"no\") + \" [Action Points|Concept.ActionPoints] and builds \" + getroottable().MSU.Text.colorPositive(\"50%\") + \" less [Fatigue|Concept.Fatigue].\""
  },
  {
    "key": "1072ae853291478d187c67ff9dfe4600831883d95c1c832eeae4dca5d5c13317",
    "original": "When using a two-handed fencing sword, the range of [$ $|Skill+lunge_skill] is increased by ",
    "translation": "",
    "context": "\"When using a two-handed fencing sword, the range of [$ $|Skill+lunge_skill] is increased by \" + getroottable().MSU.Text.colorPositive(1) + \" tile.\""
  },
  {
    "key": "0f212e022e6cd96fbb69bad4eb3b1d0dc6b000d1b68650168b2d46e4c7222b26",
    "original": "When using two-handed hammers gain the [$ $|Skill+rf_pummel_skill] skill.",
    "translation": "",
    "context": ""
  },
  {
    "key": "f1259a12618b838c092c0326d90f4789ee3bee65f071a54a2882c9c98206f93b",
    "original": "When wielding a melee weapon with up to 4 [Reach|Concept.Reach] and ending your movement next to a [surrounded|Concept.Surrounding] enemy, the next attack against that enemy deals ",
    "translation": "",
    "context": "\"When wielding a melee weapon with up to 4 [Reach|Concept.Reach] and ending your movement next to a [surrounded|Concept.Surrounding] enemy, the next attack against that enemy deals \" + getroottable().MSU.Text.colorPositive(\"25%\") + \" more damage and \" + getroottable().MSU.Text.colorPositive(\"+20%\") + \" damage ignoring armor. This bonus expires upon taking any action other than an attack.\""
  },
  {
    "key": "115739249b5b0e897294a8725f5100d0d8e7e2700b3848a8d0ec6c2190f6c36a",
    "original": "When wielding a shield, the chance is increased by an additional ",
    "translation": "",
    "context": "\"When wielding a shield, the chance is increased by an additional \" + getroottable().MSU.Text.colorPositive(\"+15%\") + \" and the attack does not build or require any [Fatigue|Concept.Fatigue].\""
  },
  {
    "key": "5297e7e2d3cb1dbd1308073bcf16a54fb2cc84753c5d411ea3699beca1f7d78d",
    "original": "When wielding a weapon with a [Reach|Concept.Reach] of less than 4, gain the difference in [Reach|Concept.Reach] up to 4.",
    "translation": "",
    "context": ""
  },
  {
    "key": "ab282677fcca335431454418cf434e03fe10eaa2c3a1ed67fd1d4042c08df998",
    "original": "When you use [Wait|Concept.Wait], recover [Action Points|Concept.ActionPoints] until you have ",
    "translation": "",
    "context": "\"When you use [Wait|Concept.Wait], recover [Action Points|Concept.ActionPoints] until you have \" + getroottable().MSU.Text.colorPositive(\"4\") + \" [Action Points|Concept.ActionPoints].\""
  },
  {
    "key": "9e60bfe494fa4754b5deac8d40487b9019b6aa32a1b76ff3b64cd8a3f55b3ab8",
    "original": "Whenever an ally dies adjacent to you, gain a stacking ",
    "translation": "",
    "context": "\"Whenever an ally dies adjacent to you, gain a stacking \" + getroottable().MSU.Text.colorPositive(\"5%\") + \" increased damage for the remainder of the combat.\""
  },
  {
    "key": "5a87c9d2f2da8bf56f14b1112e392ad018f7af0f7f7c10d582e9fecf61a96315",
    "original": "Whenever you are attacked, gain a stacking bonus to [Melee Defense|Concept.MeleeDefense] and [Ranged Defense|Concept.RangeDefense] of ",
    "translation": "",
    "context": "\"Whenever you are attacked, gain a stacking bonus to [Melee Defense|Concept.MeleeDefense] and [Ranged Defense|Concept.RangeDefense] of \" + getroottable().MSU.Text.colorPositive(\"+2\") + \" on a miss and \" + getroottable().MSU.Text.colorPositive(\"+5\") + \" on a hit. This can stack up to \" + getroottable().MSU.Text.colorPositive(\"5\") + \" times for misses and up to \" + getroottable().MSU.Text.colorPositive(\"2\") + \" times for hits.\""
  },
  {
    "key": "414e28478d6617d7b262aef80a6f0768cd0d5741c687a3498c7a7e610dd5e41a",
    "original": "Whenever you attack or are attacked, hit or miss, gain a stacking ",
    "translation": "",
    "context": "\"Whenever you attack or are attacked, hit or miss, gain a stacking \" + getroottable().MSU.Text.colorPositive(\"+5\") + \" [Initiative|Concept.Initiative] and \" + getroottable().MSU.Text.colorPositive(\"+5%\") + \" reduction to the [Fatigue|Concept.Fatigue] cost of skills until the end of your next [turn|Concept.Turn], up to a maximum of \" + getroottable().MSU.Text.colorPositive(\"+25\") + \" and \" + getroottable().MSU.Text.colorPositive(\"+25%\") + \" respectively.\""
  },
  {
    "key": "88139c0835f79b4f132a990b14301b5cbb1e1900e0383676d5bc1299f4754eae",
    "original": "While holding a [$ $|Item+throwing_net], every successful melee attack against an adjacent target has a chance to [$ $|Skill+net_effect] the target without expending your currently held [$ $|Item+throwing_net]. The chance is equal to the hit chance of the attack.",
    "translation": "",
    "context": ""
  },
  {
    "key": "bc3ab6aac1e9713adc0daa54c6c7eeda4cc1811b9fcd5dca2d3a5629db54a788",
    "original": "While not [engaged in melee|Concept.ZoneOfControl], whenever you attack, hit or miss, trigger a Positive [Morale Check|Concept.Morale] for adjacent members of your company who are not [fleeing|Concept.Morale].",
    "translation": "",
    "context": ""
  },
  {
    "key": "387ca7b3d8109a62711571ce6316a0ef3b780c6eed4d395f7de6ab95c9dfb1d9",
    "original": "While wielding a fencing type sword an additional ",
    "translation": "",
    "context": "\"While wielding a fencing type sword an additional \" + getroottable().MSU.Text.colorPositive(\"25%\") + \" of damage ignores armor.\""
  },
  {
    "key": "2423fc6ff602c0198a7815c2f013f2a0a173daaed40d6ad3781e1d731f0d7a28",
    "original": "Whirling Death",
    "translation": "",
    "context": "RF_WhirlingDeath = \"Whirling Death\""
  },
  {
    "key": "f99e0512554d27ddde1e534da93b7d23808071fabe9f190426d4da9b9f177a23",
    "original": "Who's next?",
    "translation": "",
    "context": "Fluff = \"Who's next?\""
  },
  {
    "key": "7abcd19572d014b1e419decae8006b0a23b375aed687904c23ade9517cbddb0b",
    "original": "With a little tinkering, you've managed to rig up sighting methods for your ranged weapons that allow more focused shots!",
    "translation": "",
    "context": "Fluff = \"With a little tinkering, you've managed to rig up sighting methods for your ranged weapons that allow more focused shots!\""
  },
  {
    "key": "b9fa2e7b7202dda4db0fecb6bf9535c294a979b63adf55607069e701cfbfca57",
    "original": "With every attack, hit or miss, against an opponent that acts after you in the current round, inflict the [$ $|Skill+overwhelmed_effect] status effect which lowers both [Melee Skill|Concept.MeleeSkill] and [Ranged Skill|Concept.RangeSkill] by ",
    "translation": "",
    "context": "\"With every attack, hit or miss, against an opponent that acts after you in the current round, inflict the [$ $|Skill+overwhelmed_effect] status effect which lowers both [Melee Skill|Concept.MeleeSkill] and [Ranged Skill|Concept.RangeSkill] by \" + getroottable().MSU.Text.colorNegative(\"-10%\") + \" for one [turn|Concept.Turn].\""
  },
  {
    "key": "2c33f2a5c22d26f401d1c068420ab266beaa05663fbf5c9a7daa1cfac3c381dc",
    "original": "With less than ",
    "translation": "",
    "context": "\"With less than \" + getroottable().MSU.Text.colorNegative(\"10\") + \" weight in your offhand, southern swords retain their double grip bonus and use [$ $|Skill+gash_skill] as their primary attack instead of [$ $|Skill+slash].\""
  },
  {
    "key": "72fca0e8c1aa7f163c58aab3972eb4d31fd1baaf10aa3878ff4a599e79c60d5a",
    "original": "With two-handed flails, when attacking a target who has lower current [Reach|Concept.Reach] than you, gain ",
    "translation": "",
    "context": "\"With two-handed flails, when attacking a target who has lower current [Reach|Concept.Reach] than you, gain \" + getroottable().MSU.Text.colorPositive(\"+10%\") + \" chance to hit the head per difference in current [Reach|Concept.Reach] between you and the target.\""
  },
  {
    "key": "095a56aa5893b6f9ba4f677e7bd41077cf91ebb6f266527116e4cde00687444a",
    "original": "With you by their side, your comrades feel they can conquer mountains!",
    "translation": "",
    "context": "Fluff = \"With you by their side, your comrades feel they can conquer mountains!\""
  },
  {
    "key": "07eec27e450c5a778ff7bca3e2b6c6e08b9382fe2c7f8d2b214bf3366c6ee27c",
    "original": "Years of carrying heavy loads has given you the capability to carry the burden of your mercenary gear with ease!",
    "translation": "",
    "context": "Fluff = \"Years of carrying heavy loads has given you the capability to carry the burden of your mercenary gear with ease!\""
  },
  {
    "key": "081902b34ade7d4426d4f29476464a810919a8437d484e62afff63c4c80793e8",
    "original": "Years of combat training have given you insight into the most efficient way of carrying yourself on the battlefield.",
    "translation": "",
    "context": "Fluff = \"Years of combat training have given you insight into the most efficient way of carrying yourself on the battlefield.\""
  },
  {
    "key": "68b45cf16454e2b08f0258e8c944a06d756c3f5e56aefcd31a0bae620cf6119f",
    "original": "You can [$ $|Skill+throw_net] one further tile away up to a maximum of 3 tiles.",
    "translation": "",
    "context": ""
  },
  {
    "key": "92ded84869ca1876a225ce07294c6f3e09a6ab94e4622af87b638595a2123f18",
    "original": "You can only pick ONE perk from the Swordmaster perk group.",
    "translation": "",
    "context": ""
  },
  {
    "key": "dfa87c602327ac2d845965bfb15176b18ace679b8848a22938a3e2b9927b9036",
    "original": "You cannot use or swap this [$ $|Item+throwing_net] until the target breaks free or dies. If you move more than 1 tile away from the target, the target remains [$ $|Skill+net_effect] but you lose the [$ $|Item+throwing_net].",
    "translation": "",
    "context": ""
  },
  {
    "key": "b767e3cd435b8bcd1a3ed42218152bd3275f0126be2908d3d743e9b781fc7b6c",
    "original": "You don't know where it came from, but you've suddenly started excelling at everything you do!",
    "translation": "",
    "context": "Fluff = \"You don't know where it came from, but you've suddenly started excelling at everything you do!\""
  },
  {
    "key": "2987eff12d6bab2e6d3dcfeb17d5363742d580b74054318a5ae451d6bd127dd8",
    "original": "You have to fight for your place in this world.",
    "translation": "",
    "context": "Fluff = \"You have to fight for your place in this world.\""
  },
  {
    "key": "390d674b012e97f3ab6937b5983190d2de6da7e010f91b5c5a1ac4aceaecda18",
    "original": "You know the best whetstone techniques to get your cutting edge wickedly sharp!",
    "translation": "",
    "context": "Fluff = \"You know the best whetstone techniques to get your cutting edge wickedly sharp!\""
  },
  {
    "key": "206a22ae79743f3b9862628939132ec211d951f223ce6d2a7b925ba56a76f2d9",
    "original": "You lose ",
    "translation": "",
    "context": "\"You lose \" + getroottable().MSU.Text.colorNegative(\"1\") + \" stack at the start of every [turn|Concept.Turn].\""
  },
  {
    "key": "9aac0cf5e852a24b5adce14aaf96de3aea37c9d2f4c7b1db3fba23418e4483cb",
    "original": "You lose all stacks if you use [Wait|Concept.Wait].",
    "translation": "",
    "context": ""
  },
  {
    "key": "16466831ba20756960d91ac5d5795c5c07ac792206e55c143f21626c63fabbde",
    "original": "You only gain the free [$ $|Skill+riposte_effect] or [$ $|Perk+perk_rf_rebuke] if you have at least ",
    "translation": "",
    "context": "\"You only gain the free [$ $|Skill+riposte_effect] or [$ $|Perk+perk_rf_rebuke] if you have at least \" + getroottable().MSU.Text.colorNegative(15) + \" [Fatigue|Concept.Fatigue] remaining, but this does not cost any [Action Points|Concept.ActionPoints] nor builds any [Fatigue|Concept.Fatigue].\""
  },
  {
    "key": "726da0f2e6515085c7df1312e9ba820384b4a4aa50868e693f8a9b449955c404",
    "original": "You will use [$ $|Skill+shieldwall] for free as long as you start or end your [turn|Concept.Turn] adjacent to an ally who has the [$ $|Skill+shieldwall] skill available.",
    "translation": "",
    "context": ""
  },
  {
    "key": "0ce088cbffed611c108025811dfccba1045ac9a52f484f04cfbe9ea2b2cdd5e2",
    "original": "You're a professional, experienced fighter!",
    "translation": "",
    "context": "Fluff = \"You're a professional, experienced fighter!\""
  },
  {
    "key": "16601ed13d6ce51facb9b7e3993f51aac66c82831e7e400db1c1479c6bd022df",
    "original": "You've become so well-practiced with a blade that attacking and defending are done congruously!",
    "translation": "",
    "context": "Fluff = \"You've become so well-practiced with a blade that attacking and defending are done congruously!\""
  },
  {
    "key": "389eb78da1b3cc387d38d521fccfee9a138df6b1e6f8162cf757a0e06a0e33ef",
    "original": "You've learned that you fight best with a buddy to watch your back!",
    "translation": "",
    "context": "Fluff = \"You've learned that you fight best with a buddy to watch your back!\""
  },
  {
    "key": "51258120d7e97e9926bbc08653f2f10f14a09c0ee92aa7c7c9f126d9155dc868",
    "original": "You've learned to fight in formation, trusting in the comrades to your front and sides to keep you safe while you go to work!",
    "translation": "",
    "context": "Fluff = \"You've learned to fight in formation, trusting in the comrades to your front and sides to keep you safe while you go to work!\""
  },
  {
    "key": "253bd18ef6cf2c65780c1097c9a47bc60ded432c2288170af418fd50a1f345db",
    "original": "You've learned to use the unpredictable swings of your flail to keep your enemies guessing!",
    "translation": "",
    "context": "Fluff = \"You've learned to use the unpredictable swings of your flail to keep your enemies guessing!\""
  },
  {
    "key": "0f681abe13a2e2b5778f4b9b99963f5b07ebc955012f1f61bc342bbb85c30d85",
    "original": "You've learned to use the very momentum of your movement as a weapon unto itself!",
    "translation": "",
    "context": "Fluff = \"You've learned to use the very momentum of your movement as a weapon unto itself!\""
  },
  {
    "key": "d0e52f730cb6bc6bab97978fd7fc5c6a8ce0fba9bcb727418d285a7698fb52cf",
    "original": "You've learned well that weapons are like tools, tailor-made to accomplish specific tasks. Therefore, you carry a small arsenal, ready to handle any situation!",
    "translation": "",
    "context": "Fluff = \"You've learned well that weapons are like tools, tailor-made to accomplish specific tasks. Therefore, you carry a small arsenal, ready to handle any situation!\""
  },
  {
    "key": "0f7e50cba4b46d2746d2546b2aa2a645d51de4bae47a5c35d6ef7f0611246ca2",
    "original": "You've quickly realized that your years of hard labor give you an edge in mercenary work!",
    "translation": "",
    "context": "Fluff = \"You've quickly realized that your years of hard labor give you an edge in mercenary work!\""
  },
  {
    "key": "37004ee7fc7335ad8270e5a72f7defde4178325831debc5b494b80856d23d6bf",
    "original": "Your appearance gives your enemies a bit of doubt!",
    "translation": "",
    "context": "Fluff = \"Your appearance gives your enemies a bit of doubt!\""
  },
  {
    "key": "2132694e56ae8378b17003e2b958f97d805335858abd9afe75cef3c78f9d85a6",
    "original": "Your battle brothers feel confident when you're there backing them up!",
    "translation": "",
    "context": "Fluff = \"Your battle brothers feel confident when you're there backing them up!\""
  },
  {
    "key": "673412b1c09d0c025540bf8a1e068e5bf304d048755d1940222fe19a5d9303e6",
    "original": "Your experience in battle has led to you being able to quickly adapt to an opponent's fighting style!",
    "translation": "",
    "context": "Fluff = \"Your experience in battle has led to you being able to quickly adapt to an opponent's fighting style!\""
  },
  {
    "key": "ce6655882aac91d983bdde0022cdda6d46fcd18a2d3af5e1dc98cd0773a8fb37",
    "original": "Your will to live is strong!",
    "translation": "",
    "context": "Fluff = \"Your will to live is strong!\""
  },
  {
    "key": "48790a8d9fd88b0c4a7a455d334a361e48f7227dd1c89e778f334664c0f3ff1d",
    "original": "[$ $|Item+handgonne] now require ",
    "translation": "",
    "context": "\"[$ $|Item+handgonne] now require \" + getroottable().MSU.Text.colorNegative(\"6\") + \" [Action Points|Concept.ActionPoints] to [$ $|Skill+reload_handgonne_skill] and can be fired every turn instead of every other turn.\""
  },
  {
    "key": "2bcca16e9239eab396e1644a579a3f18ecbc78f17af42cea5bb376a1fe9e3959",
    "original": "[$ $|Item+heavy_crossbow] now require ",
    "translation": "",
    "context": "\"[$ $|Item+heavy_crossbow] now require \" + getroottable().MSU.Text.colorNegative(\"4\") + \" [Action Points|Concept.ActionPoints] to [$ $|Skill+reload_bolt], just like regular crossbows, allowing you to shoot, reload and move.\""
  },
  {
    "key": "90bc4c7958e433c5923b960a327e40a3c9f59e014eaffa5faa27dbf05908d990",
    "original": "[$ $|Perk+perk_brawny] does not affect this perk.",
    "translation": "",
    "context": ""
  },
  {
    "key": "1d2bbdb6ad7c5ba9ad5e61d05077d24bed277d6944f2761985ffcc6efaafccd1",
    "original": "[$ $|Skill+crush_armor] and [$ $|Skill+demolish_armor_skill] inflict ",
    "translation": "",
    "context": "\"[$ $|Skill+crush_armor] and [$ $|Skill+demolish_armor_skill] inflict \" + getroottable().MSU.Text.colorPositive(\"33%\") + \" more damage against armor and apply the [$ $|Skill+rf_dented_armor_effect] effect.\""
  },
  {
    "key": "b7da32acf4afa2eb23281469bcfba9bf4dcce60da19c4c72eac9b42598202444",
    "original": "[$ $|Skill+disarm_skill] only has half the penalty to hit.",
    "translation": "",
    "context": ""
  },
  {
    "key": "20a8c8a775e571d5085495fd0fca98357de14fb5510d74b170786478fc83ce73",
    "original": "[$ $|Skill+gash_skill] has a ",
    "translation": "",
    "context": "\"[$ $|Skill+gash_skill] has a \" + getroottable().MSU.Text.colorNegative(\"50%\") + \" lower [threshold|Concept.InjuryThreshold] to inflict [injuries|Concept.InjuryTemporary].\""
  },
  {
    "key": "8bbed011f0d2567625ebac0edd542ca2519a61cb4cf34bac65c16eea72fa9321",
    "original": "[$ $|Skill+knock_back] gains ",
    "translation": "",
    "context": "\"[$ $|Skill+knock_back] gains \" + getroottable().MSU.Text.colorPositive(\"+15%\") + \" chance to hit.\""
  },
  {
    "key": "276f6be1311482626a6bdf9e772367ce1a50894e1fa723ab29d889c40b28300d",
    "original": "[$ $|Skill+knock_out], [$ $|Skill+knock_over_skill] and [$ $|Skill+strike_down_skill] have a ",
    "translation": "",
    "context": "\"[$ $|Skill+knock_out], [$ $|Skill+knock_over_skill] and [$ $|Skill+strike_down_skill] have a \" + getroottable().MSU.Text.colorPositive(\"100%\") + \" chance to [$ $|Skill+stunned_effect] the target if not immune.\""
  },
  {
    "key": "bf7522f143b70ea01dadda7f36d4167292a1a96d5bd7acf58c4433b80b4cc983",
    "original": "[$ $|Skill+lash_skill] and [$ $|Skill+hail_skill] ignore the defense bonus granted by shields but not by [$ $|Skill+shieldwall_effect].",
    "translation": "",
    "context": ""
  },
  {
    "key": "4b670751cb84942ef5b29b84a51612ccaf0e4559f7a0e9d88f7f718c476dd843",
    "original": "[$ $|Skill+pound] ignores an additional ",
    "translation": "",
    "context": "\"[$ $|Skill+pound] ignores an additional \" + getroottable().MSU.Text.colorPositive(\"+10%\") + \" of armor on head hits.\""
  },
  {
    "key": "e75b2f2d63758c022efa3e66a37ed943b5209df507661ff8f3463a8935d0ebed",
    "original": "[$ $|Skill+rf_gouge_skill] has a ",
    "translation": "",
    "context": "\"[$ $|Skill+rf_gouge_skill] has a \" + getroottable().MSU.Text.colorNegative(\"50%\") + \" lower [threshold|Concept.InjuryThreshold] to inflict [injuries|Concept.InjuryTemporary].\""
  },
  {
    "key": "7e9fe1d91c7a14fb91e347ebcef7d88d533165938556b177f8c7085b680a5ab2",
    "original": "[$ $|Skill+rf_passing_step_skill] costs ",
    "translation": "",
    "context": "\"[$ $|Skill+rf_passing_step_skill] costs \" + getroottable().MSU.Text.colorPositive(2) + \" fewer [Action Points|Concept.ActionPoints] and builds \" + getroottable().MSU.Text.colorPositive(2) + \" less [Fatigue|Concept.Fatigue], both down to a minimum of 0.\""
  },
  {
    "key": "c4cde7712a0b371f4db793becbf959a4836d8714de947a880f6274fb0e0a5de8",
    "original": "[$ $|Skill+riposte] no longer has a penalty to hitchance.",
    "translation": "",
    "context": ""
  },
  {
    "key": "e8a7f86d5828cf1959be5c61203899698972df766d55a53f0902aad59a070fee",
    "original": "[$ $|Skill+round_swing] gains ",
    "translation": "",
    "context": "\"[$ $|Skill+round_swing] gains \" + getroottable().MSU.Text.colorPositive(\"+5%\") + \" chance to hit.\""
  },
  {
    "key": "0395d773d556b5654b8f51948031ea6672add34cd2178603f8c8f56ddf403431",
    "original": "[$ $|Skill+shatter_skill] gains ",
    "translation": "",
    "context": "\"[$ $|Skill+shatter_skill] gains \" + getroottable().MSU.Text.colorPositive(\"+5%\") + \" chance to hit.\""
  },
  {
    "key": "ef876a49cb5661e1670365220c09e6b8b1907d9509780554dd029344ec33957e",
    "original": "[$ $|Skill+spearwall] is no longer disabled once an opponent manages to overcome it. Instead, [$ $|Skill+spearwall] can still be used and continues to give free attacks on any further opponent attempting to enter the [Zone of Control|Concept.ZoneOfControl]",
    "translation": "",
    "context": ""
  },
  {
    "key": "13eed3bf0654b9a7f3e3af3db75253023c04cfb0743e9ab6fba68aae652cc34a",
    "original": "[$ $|Skill+split] and [$ $|Skill+swing] no longer have a penalty to hitchance and gain ",
    "translation": "",
    "context": "\"[$ $|Skill+split] and [$ $|Skill+swing] no longer have a penalty to hitchance and gain \" + getroottable().MSU.Text.colorPositive(\"+5%\") + \" chance to hit.\""
  },
  {
    "key": "cf93771efe03e0eece4e87562aa8d4822299e0d0ac0670cc9c56e70be5f25f1e",
    "original": "[$ $|Skill+stab], [$ $|Skill+puncture] and [$ $|Skill+deathblow_skill] have a reduced [Action Point|Concept.ActionPoints] cost to allow for an additional attack each turn.",
    "translation": "",
    "context": ""
  },
  {
    "key": "cc0524161e8f4308f431185e8d0d8b99b15577588ce3ea8062789974f2ce8803",
    "original": "[$ $|Skill+thresh] gains ",
    "translation": "",
    "context": "\"[$ $|Skill+thresh] gains \" + getroottable().MSU.Text.colorPositive(\"+5%\") + \" chance to hit.\""
  },
  {
    "key": "94b4b50feb18d29ab649873d24cf214efd9ede41e2e827cff40a58e84d5171bf",
    "original": "[Action Point|Concept.ActionPoints] costs for movement on all terrain is reduced by ",
    "translation": "",
    "context": "\"[Action Point|Concept.ActionPoints] costs for movement on all terrain is reduced by \" + getroottable().MSU.Text.colorPositive(\"1\") + \" to a minimum of 2 [Action Points|Concept.ActionPoints] per tile, and [Fatigue|Concept.Fatigue] cost is reduced to half.\""
  },
  {
    "key": "ed88b0595d6ad37c4a9801dd72be5fe391d51a10a8fdc4c1a06b87975279301d",
    "original": "[Experience|Concept.Experience] gained is increased by ",
    "translation": "",
    "context": "\"[Experience|Concept.Experience] gained is increased by \" + getroottable().MSU.Text.colorPositive(\"20%\") + \" for the next 5 [levels|Concept.Level] and by \" + getroottable().MSU.Text.colorPositive(\"5%\") + \" after that.\""
  },
  {
    "key": "4146e717aae900363e201df6f1dc13bf723c03a700222ec0f205c031bc100b82",
    "original": "[Fatigue|Concept.Fatigue] cost of skills is reduced by ",
    "translation": "",
    "context": "\"[Fatigue|Concept.Fatigue] cost of skills is reduced by \" + getroottable().MSU.Text.colorPositive(\"20%\") + \".\""
  },
  {
    "key": "518aa1bd5cc22524b1d3e0641eb511176d668e41345a62e9d51ad7d9d47204c4",
    "original": "[Hitpoints|Concept.Hitpoints] and [Maximum Fatigue|Concept.MaximumFatigue] are increased by ",
    "translation": "",
    "context": "\"[Hitpoints|Concept.Hitpoints] and [Maximum Fatigue|Concept.MaximumFatigue] are increased by \" + getroottable().MSU.Text.colorPositive(\"10%\") + \" of their respective base values.\""
  },
  {
    "key": "f22af5e80b51092fe6370df3617e840613507a289fa989360f8d90fbdc24d25a",
    "original": "[Initiative|Concept.Initiative] is reduced by ",
    "translation": "",
    "context": "\"[Initiative|Concept.Initiative] is reduced by \" + getroottable().MSU.Text.colorNegative(\"20%\") + \".\""
  },
  {
    "key": "f98fa6625e012f6792463c70b0975b62663cfca6d0e55a4456a472512db609dd",
    "original": "[Resolve|Concept.Bravery] and [Initiative|Concept.Initiative] are both increased by ",
    "translation": "",
    "context": "\"[Resolve|Concept.Bravery] and [Initiative|Concept.Initiative] are both increased by \" + getroottable().MSU.Text.colorPositive(\"15%\") + \" while you have at least 1 stack.\""
  },
  {
    "key": "e9794344d5febe39c62378b9992cd85ca9d132be91c22b24555e362d2f94c0ec",
    "original": "[Resolve|Concept.Bravery] is increased by ",
    "translation": "",
    "context": "\"[Resolve|Concept.Bravery] is increased by \" + getroottable().MSU.Text.colorPositive(\"50%\") + \" against negative [morale checks|Concept.Morale].\""
  },
  {
    "key": "6ad262e0cd2bd995d2b74a954d53602d0897ac9c38f27e673d70e20d972196e8",
    "original": "[Status effects|Concept.StatusEffect] that have their effects grow weaker over several [turns|Concept.Turn] (e.g. [$ $|Skill+goblin_poison_effect]) are at their weakest state from the start.",
    "translation": "",
    "context": ""
  },
