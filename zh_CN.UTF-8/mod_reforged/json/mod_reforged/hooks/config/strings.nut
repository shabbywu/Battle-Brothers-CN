  {
    "key": "00bb12858679f3dd374e96f37e99eff5f2a861378411969b12b53e67cb38c694",
    "original": "Any ally who is adjacent to an enemy, or is adjacent to an ally who is adjacent to an enemy, gains ",
    "translation": "",
    "context": "\"Any ally who is adjacent to an enemy, or is adjacent to an ally who is adjacent to an enemy, gains \" + getroottable().MSU.Text.colorPositive(\"+3\") + \" [Action Points|Concept.ActionPoints] as long as they start their [turn|Concept.Turn] adjacent to you.\""
  },
  {
    "key": "36967b6b15bc8242bd936458fd3207835d0050c9a59d556bb857e82ad6840dbf",
    "original": "Any negative [status effect|Concept.StatusEffect] with a finite duration (e.g. [$ $|Skill+disarmed_effect], [$ $|Skill+charmed_effect]) has its duration reduced to ",
    "translation": "",
    "context": "\"Any negative [status effect|Concept.StatusEffect] with a finite duration (e.g. [$ $|Skill+disarmed_effect], [$ $|Skill+charmed_effect]) has its duration reduced to \" + getroottable().MSU.Text.colorPositive(1) + \" [turn|Concept.Turn].\""
  },
  {
    "key": "175447ac7d259fc0ba67a22c4762cc22b450d2b0d98681227a7b3ca9be897095",
    "original": "Arbalester",
    "translation": "",
    "context": ""
  },
  {
    "key": "b8e3aba63367ca05fcb89cd6c0edaef4b2825cf8f56190a1fffbdb0d52d71fd7",
    "original": "Arbalesters",
    "translation": "",
    "context": ""
  },
  {
    "key": "053d98de6758c125106b9dbb19b8230334278f505c13fcfa6730923f53728c86",
    "original": "Armor damage taken is reduced by a percentage equal to ",
    "translation": "",
    "context": "\"Armor damage taken is reduced by a percentage equal to \" + getroottable().MSU.Text.colorPositive(\"5%\") + \" of the current total armor value of both body and head armor.\""
  },
  {
    "key": "9740e157a39c552f464130cf7360db5b4f7e714a88f0ac02eb506e55982901ca",
    "original": "Armor penetrating damage received is reduced by a percentage equal to ",
    "translation": "",
    "context": "\"Armor penetrating damage received is reduced by a percentage equal to \" + getroottable().MSU.Text.colorPositive(\"10%\") + \" of the current durability of the armor piece hit.\""
  },
  {
    "key": "9e742878d7cb04b34856adee3b193643bac56bd644ba26d721355794cd469e6b",
    "original": "As long as you have attacked at least once during your [turn|Concept.Turn], if you end the [turn|Concept.Turn] with half or fewer of your [Action Points|Concept.ActionPoints] remaining, gain a stack, up to a maximum of 5 stacks.",
    "translation": "",
    "context": ""
  },
  {
    "key": "0896a221f3517911c8801b6f294e0b3eb822c2bcabc11b0376abb20d8de22ce4",
    "original": "At all times your [Initiative|Concept.Initiative] is reduced only by ",
    "translation": "",
    "context": "\"At all times your [Initiative|Concept.Initiative] is reduced only by \" + getroottable().MSU.Text.colorPositive(\"50%\") + \" of accumulated [Fatigue|Concept.Fatigue], instead of all of it.\""
  },
  {
    "key": "9bd3757175b0f2141e67197c60a2c6525419a1b083c0c29d071c258448405a16",
    "original": "At the eleventh character level, you gain an additional perk point and this perk becomes inert.",
    "translation": "",
    "context": ""
  },
  {
    "key": "de299d9b9932993b8905111678f53cd7675be5ee9f3bc6bdf2f19c7b68e9e74a",
    "original": "At the end of your [turn|Concept.Turn], gain ",
    "translation": "",
    "context": "\"At the end of your [turn|Concept.Turn], gain \" + getroottable().MSU.Text.colorPositive(\"half\") + \" of your remaining [Action Points|Concept.ActionPoints], rounded down, as additional [Action Points|Concept.ActionPoints] during your next [turn|Concept.Turn].\""
  },
  {
    "key": "a7f6d5ef3d79f50a7db3388dc81cae4738a27d0520a7c0dbff17fdcf5b097e10",
    "original": "At the start of every [turn|Concept.Turn] the bonus is reset except the bonus gained from getting hit which is retained for the remainder of the combat.",
    "translation": "",
    "context": ""
  },
  {
    "key": "95e1a273e060dcf74c08cb5e4c686ab29d5b22150cfa0f70f98a8d4500fdc6a8",
    "original": "At the start of your [turn|Concept.Turn], if you have at least Steady [morale|Concept.Morale], improve the [morale state|Concept.Morale] of adjacent allies by ",
    "translation": "",
    "context": "\"At the start of your [turn|Concept.Turn], if you have at least Steady [morale|Concept.Morale], improve the [morale state|Concept.Morale] of adjacent allies by \" + getroottable().MSU.Text.colorPositive(1) + \" as long as their [morale state|Concept.Morale] is lower than yours.\""
  },
  {
    "key": "2de3656c13737ef1317fccd19a9129de4b03f1e55e5bf6616b037724e3a2b56e",
    "original": "Attacks against [surrounded|Concept.Surrounding] targets deal ",
    "translation": "",
    "context": "\"Attacks against [surrounded|Concept.Surrounding] targets deal \" + getroottable().MSU.Text.colorPositive(\"10%\") + \" more damage and have \" + getroottable().MSU.Text.colorPositive(\"+10%\") + \" armor penetration per character surrounding the target.\""
  },
  {
    "key": "d4199badb514e7ba288da9829ec5b5fa5d8d67e14926345639cd382d181e5a99",
    "original": "Attacks against characters with a lower [morale|Concept.Morale] than you deal ",
    "translation": "",
    "context": "\"Attacks against characters with a lower [morale|Concept.Morale] than you deal \" + getroottable().MSU.Text.colorPositive(\"10%\") + \" more damage per level of [morale|Concept.Morale] difference.\""
  },
  {
    "key": "9f4c1a2359663a3f96c47b93bb15880477507449774c358876eb1a2c74031c94",
    "original": "Attacks from cleavers apply an additional stack of [$ $|Skill+bleeding_effect] on the target.",
    "translation": "",
    "context": ""
  },
  {
    "key": "aa6d7d75a840168ce9f3409a193d6621491bfb9b016d10d1629cd2b694fc5898",
    "original": "Attacks from cleavers apply an additional stack of [$ $|Skill+bleeding_effect].",
    "translation": "",
    "context": ""
  },
  {
    "key": "e86d7750abc96a3175a4bf5a648a7e9f93e1496e3e23a516e46edbb77ff7e3a9",
    "original": "Attacks from daggers against targets who act after you in the current [round|Concept.Round] ignore all of the target's [reach advantage|Concept.ReachAdvantage].",
    "translation": "",
    "context": ""
  },
  {
    "key": "579381c7ae454131e8e8cd4f03f2c622f36c5e1725f9b626b995d70c38d26da6",
    "original": "Attacks from swords inflict [$ $|Skill+bleeding_effect] on the target.",
    "translation": "",
    "context": ""
  },
  {
    "key": "e5a8da8f4056a7774e2085c8e3e930dd6edace75a4edd35dfdea58bfd4b7df02",
    "original": "Attacks have a chance equal to ",
    "translation": "",
    "context": "\"Attacks have a chance equal to \" + getroottable().MSU.Text.colorPositive(\"66%\") + \" of your current [Melee Skill|Concept.MeleeSkill] to target the body part with the lower armor.\""
  },
  {
    "key": "416fa3e807b05a5f8f426f4422bdfd9abccc53f41da194cd33ad5f401ab2d8c2",
    "original": "Attacks have a random ",
    "translation": "",
    "context": "\"Attacks have a random \" + getroottable().MSU.Text.colorPositive(\"+10%\") + \" to \" + getroottable().MSU.Text.colorPositive(\"+25%\") + \" armor penetration.\""
  },
  {
    "key": "fad16bea15d71fc3c8b0a4c5f27c1d33461dc494063557fcfbd0cf0e3317821f",
    "original": "Attacks have an additional ",
    "translation": "",
    "context": "\"Attacks have an additional \" + getroottable().MSU.Text.colorPositive(\"25%\") + \" chance to hit the head.\""
  },
  {
    "key": "090b3888fceb269e9a351321ab4e359111c866777ae0cac33dcdd38d381e47e7",
    "original": "Attacks that do at least ",
    "translation": "",
    "context": "\"Attacks that do at least \" + getroottable().MSU.Text.colorNegative(5) + \" damage to [Hitpoints|Concept.Hitpoints] and apply a valid [status effect|Concept.StatusEffect] or are against characters with a valid [status effect|Concept.StatusEffect] have a chance to inflict an [injury|Concept.Injury]. This chance is \" + getroottable().MSU.Text.colorPositive(\"100%\") + \" for two-handed maces and \" + getroottable().MSU.Text.colorPositive(\"50%\") + \" for one-handed maces.\""
  },
