  },
  {
    "key": "a855640419bf90f301f0730bc85d83b46f8e95802d9f1fbab4ebe1d2602c8a4e",
    "original": "Does not work when swapping a shield, or when swapping from one Two-Handed melee weapon to another Two-Handed melee weapon.",
