  },
  {
    "key": "b06ae68a360186ca05f8efc07aa5e628d043ba6175baeb75ca10788e5da8b539",
    "original": "Unlocks the [$ $|Skill+rf_flaming_arrows_skill] skill.",
    "translation": "",
    "context": ""
  },
  {
    "key": "a6428bde72050b6bfea74f59e18bd6f129781ad3afb364f5d99710fa0d4708d7",
