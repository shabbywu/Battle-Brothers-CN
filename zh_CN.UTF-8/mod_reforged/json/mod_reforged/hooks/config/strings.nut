  },
  {
    "key": "28f26007a4adf2390fc42c5ebe0194a4e7e2afe867921157fcfbc4ffb1233843",
    "original": "Upon equipping a weapon, temporarily gain the first and second [perk|Concept.Perk] of all of its [perk|Concept.Perk] groups if you have the corresponding [perk|Concept.Perk] in any weapon [perk|Concept.Perk] group regardless of tier.",
    "translation": "",
    "context": ""
  },
  {
    "key": "6acfd536d47aff4e7e7f184b07afc84c876caafc37c7fd2f359edf89bcd16a63",
    "original": "Upon reaching level 11, this perk has a ",
    "translation": "",
    "context": "\"Upon reaching level 11, this perk has a \" + getroottable().MSU.Text.colorPositive(\"50%\") + \" chance of being replaced with [$ $|Perk+perk_rf_realized_potential].\""
  },
  {
    "key": "73439ac6dc84bea58a459fff78105c0643a0a87bccd8f61d43fdba87f79f13dc",
    "original": "Upon triggering, gain [$ $|Skill+nine_lives_effect] until the start of your next [turn|Concept.Turn].",
    "translation": "",
    "context": ""
  },
  {
    "key": "bd34cd10c50504ea55788e1bbf448cbce9e03a0e636e8406e361d2d7536a4655",
    "original": "Use [$ $|Skill+riposte] for free at the end of your [turn|Concept.Turn] if you have access to [$ $|Skill+riposte]. Otherwise, gain [$ $|Perk+perk_rf_rebuke] instead for one [turn|Concept.Turn], with an additional chance of ",
    "translation": "",
    "context": "\"Use [$ $|Skill+riposte] for free at the end of your [turn|Concept.Turn] if you have access to [$ $|Skill+riposte]. Otherwise, gain [$ $|Perk+perk_rf_rebuke] instead for one [turn|Concept.Turn], with an additional chance of \" + getroottable().MSU.Text.colorPositive(\"+15%\") + \" for returning a missed attack. The attacks triggered from this [$ $|Perk+perk_rf_rebuke] do not build [Fatigue|Concept.Fatigue].\""
  },
  {
    "key": "e97eb216a33b369c04e55c82563faffb03cbc64834eee748503e669dd7c6d651",
    "original": "Use the momentum of your flail to enable quick follow-up blows!",
    "translation": "",
    "context": "Fluff = \"Use the momentum of your flail to enable quick follow-up blows!\""
  },
  {
    "key": "2a1ba63a6a4b18da3964d5420bc8332c057344a470f05f42d2a4551f2d8a007f",
    "original": "Use the reach of your weapon to find an angle on the head!",
    "translation": "",
    "context": "Fluff = \"Use the reach of your weapon to find an angle on the head!\""
  },
  {
    "key": "ecde3eaf36bcb2886b4e17c42fe46761e9171f3ed30c0954d5155cef78e0b7b5",
    "original": "Using any skill that costs [Action Points|Concept.ActionPoints] reduces the [Action Point|Concept.ActionPoints] cost of all skills by ",
    "translation": "",
    "context": "\"Using any skill that costs [Action Points|Concept.ActionPoints] reduces the [Action Point|Concept.ActionPoints] cost of all skills by \" + getroottable().MSU.Text.colorPositive(\"1\") + \" to a minimum of 3.\""
  },
  {
    "key": "28663572ef1ff549b25d0d23f53c16b719c64a232fe39d6477d59135dfeb3fab",
