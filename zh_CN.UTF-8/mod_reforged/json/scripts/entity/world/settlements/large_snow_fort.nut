  },
  {
    "key": "5590cbec93839b3ed865de363944fb4fe5fe29078e222658cb3e031f72efe9f5",
    "original": "This large citadel looks wide over the endless snow and is a stronghold against anything that may come down from the far north. As people flocked to its protection over the years, the many houses and workshops in its vicinity now also grant shelter and supply to travelers, mercenaries and adventurers in the area.",
    "translation": "",
    "context": "this.m.Description = \"This large citadel looks wide over the endless snow and is a stronghold against anything that may come down from the far north. As people flocked to its protection over the years, the many houses and workshops in its vicinity now also grant shelter and supply to travelers, mercenaries and adventurers in the area.\""
  },
