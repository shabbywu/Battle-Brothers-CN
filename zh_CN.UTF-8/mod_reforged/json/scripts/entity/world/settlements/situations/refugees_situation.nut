[
  {
    "key": "533692d499c255ea648e6427334318eb5886746f12fa9a29e7fcc941db86f9b3",
    "original": " no longer has ",
    "translation": "",
    "context": "_s + \" no longer has \" + this.m.Name"
  },
  {
    "key": "a0a4d5a0a49ec1f86c5178602a8c9170b39450f5963c5deb7da8a5d049c83ed6",
    "original": " now has ",
    "translation": "",
    "context": "_s + \" now has \" + this.m.Name"
  },
  {
    "key": "d3d76422b2041604c41b98aaea4ad3f3638f6daf21d4c90120e950e7df2eb0fb",
    "original": "Come morning I'll head out to %settlement%. Word is a large group of refugees just arrived and I need more hands for my farm.",
    "translation": "",
    "context": ""
  },
  {
    "key": "aec8ac4b3c3ba16ecdbea1d12ff222cccc3653bafc487dc106ff2ffeb2b08ed6",
    "original": "From what I've heard, %settlement% is flooded with refugees nowadays. Those cowards should have stayed and fought for their home, I'd say!",
    "translation": "",
    "context": ""
  },
  {
    "key": "431f1e13802ddb26247115947545359590b74d86335553b8cd6720f2e38ef20c",
    "original": "Refugees",
    "translation": "",
    "context": "this.m.Name = \"Refugees\""
  },
  {
    "key": "cbc89f4f1e8adb73cc422a26d31cf7987ec544572eb0897ed9d4ce5eac4f3ac3",
    "original": "The beggars, the downtrodden, the fugitives, they all have to go somewhere. A large group of them just arrived at %settlement% from what I heard.",
    "translation": "",
    "context": ""
  },
  {
    "key": "e680a20114008c1e05885e5fb228edb97afaafa75824238af19e54d7be4a1dcb",
    "original": "With the war raging, a constant stream of refugees is pouring into this settlement. It puts a strain on local economy, but it also means cheap recruits for anyone that can offer work.",
    "translation": "",
    "context": "this.m.Description = \"With the war raging, a constant stream of refugees is pouring into this settlement. It puts a strain on local economy, but it also means cheap recruits for anyone that can offer work.\""
  }
]