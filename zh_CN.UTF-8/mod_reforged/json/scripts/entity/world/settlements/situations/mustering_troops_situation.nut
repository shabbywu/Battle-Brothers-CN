    "key": "96970b23ddb591e2b50b9b4721e9c9eb2b49f2ed4a86cc7bf68d400add762670",
    "original": " no longer is ",
    "translation": "",
    "context": "_s + \" no longer is \" + this.m.Name"
  },
  {
    "key": "c96c2e9cd6a838b486d772ff9ca44d06da800bbaa64d190c3bd271b738f82c4e",
    "original": " now is ",
    "translation": "",
    "context": "_s + \" now is \" + this.m.Name"
  },
  {
    "key": "f46c88931401c2b138990617078422d7362d0ddd60563fc5dcf3e98f4fe2c162",
    "original": "Another damn noble is pressing younglings into a regiment at %settlement%. Ach, why am I even talking to you about this, sellsword? You are no better!",
    "translation": "",
    "context": ""
  },
  {
    "key": "35c4bce6be68aab0c9c944c20b09167958b6d00a42f21e701f560afd5a43907f",
    "original": "I'm just passing trough. Narrowly escaped from impressment at %settlement%. They wanted to force me to fight for some lord, but no thanks, I says, not gonna happen, and away I went. I'll strike my luck further down south.",
    "translation": "",
    "context": ""
  },
  {
    "key": "c0fb1d1d10d3e28278fc90b9ab1efca495180bc973acbb68595f2a7aa6d38516",
    "original": "If I were a merchant with a wagonload full of weapons and armor, I'd know just where to sell it all - they're mustering troops at %settlement% and will surely pay good coin. Alas, I'm neither a merchant nor do I have any weapons.",
    "translation": "",
    "context": ""
  },
  {
    "key": "9eae283d3bd175bdf2ff957873e9a49b6784f39cc83c6e8addf53baed6e25bc9",
    "original": "Mustering Troops",
    "translation": "",
    "context": "this.m.Name = \"Mustering Troops\""
  },
  {
    "key": "35298109ee523ff176dc27df73f2f04970f236718ce06ea76b0e24fe6ee3f2e0",
    "original": "Order has been given to muster troops for service in this settlement. Equipment and recruits are in short supply, but a quick crown can be made by selling arms and armor here.",
    "translation": "",
    "context": "this.m.Description = \"Order has been given to muster troops for service in this settlement. Equipment and recruits are in short supply, but a quick crown can be made by selling arms and armor here.\""
  }
]