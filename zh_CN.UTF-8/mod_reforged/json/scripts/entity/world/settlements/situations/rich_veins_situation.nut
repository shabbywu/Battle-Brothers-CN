[
  {
    "key": "494e895ffcf2d73c2f0e2216ad74739aaadc6d313988a37b9fa7182b4d3265d0",
    "original": " had ",
    "translation": "",
    "context": "_s + \" had \" + this.m.Name"
  },
  {
    "key": "533692d499c255ea648e6427334318eb5886746f12fa9a29e7fcc941db86f9b3",
    "original": " no longer has ",
    "translation": "",
    "context": "_s + \" no longer has \" + this.m.Name"
  },
  {
    "key": "14186f39acb44388184e1f4268a1b87be30d7d798a8948ca17da2b2c1d112d77",
    "original": "I hear that the mines in %settlement% are awfully productive these days. Not a bad way to make some coin if you're in the trading business.",
    "translation": "",
    "context": ""
  },
  {
    "key": "b0b54f1d31c7c3ecfe69518d25a97f3128ab39b6a019befd70a27cf2caa8c2a0",
    "original": "Rich Veins",
    "translation": "",
    "context": "this.m.Name = \"Rich Veins\""
  },
  {
    "key": "d77bdb6b68aa4be22437d49d93b07720a70b94e59ee4a9e82f8e73633aab7ceb",
    "original": "Some lucky miner struck a particularly rich vein! Extraction of minerals and metals will be greatly increased until it is exhausted, but the settlement also experiences an inflation of prices.",
    "translation": "",
    "context": "this.m.Description = \"Some lucky miner struck a particularly rich vein! Extraction of minerals and metals will be greatly increased until it is exhausted, but the settlement also experiences an inflation of prices.\""
  },
  {
    "key": "16d9b7820efe16340be2188febb6a27532809009666be77394a02ca8ee60f276",
    "original": "They struck a mother lode over in %settlement%. I myself worked the mines for decades, too, and all I got to show for it is a bad cough.",
    "translation": "",
    "context": ""
  },
  {
    "key": "065698d4e2b1a65d21c53463eef63e1f7dc9939291095a9395f5c3b78a2dcdb3",
    "original": "Those lucky bastards in %settlement% have found a new vein in the mine. Caravans can't come fast enough now with what they're shoveling up.",
    "translation": "",
    "context": ""
  }
]