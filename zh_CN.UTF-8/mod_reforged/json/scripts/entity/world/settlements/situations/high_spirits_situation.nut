  },
  {
    "key": "6a1d74cae6bfb6bf8a4ed88ae588ad40b92f2be9faeb2d636ac71751b4e92465",
    "original": "High Spirits",
    "translation": "",
    "context": "this.m.Name = \"High Spirits\""
  },
  {
    "key": "b046367210ee3130bda8fae75d6ad8cd7b1c1003887a11f293efe87d16fe74c4",
    "original": "I arrived from %settlement% today, my clothes are still dusty from the road. The folks over there surely were in a good mood, not quite sure why though...",
    "translation": "",
    "context": ""
  },
  {
    "key": "74999affe2e73cd35a823d453a4c7ed377b108d3928798c779122b44fac76a7a",
    "original": "No need to get me a mug, I am still drunk from the celebrations in %settlement%. They sure know how to have a good time!",
    "translation": "",
    "context": ""
  },
  {
    "key": "6771a7a9fa7860cadf4f92d68e1e3109bbd3eb4e4cfe97868bf62433690be517",
    "original": "Rumor has it that the townsfolk of %settlement% just got an important relic back.",
    "translation": "",
    "context": ""
  },
  {
    "key": "041b85989c09d3cb24a305165a12dce2e75c2644e4f94ea65eb934edafd4cabd",
    "original": "Spirits are high here, and people are eager to do business with you.",
    "translation": "",
    "context": "this.m.Description = \"Spirits are high here, and people are eager to do business with you.\""
  }
]