[
  {
    "key": "e2bd64a545a5a5906e7d41639e39f06956bf05bb459cb90f077f2ea703369d5c",
    "original": "Terrified Villagers",
    "translation": "",
    "context": "this.m.Name = \"Terrified Villagers\""
  },
  {
    "key": "95cb401f5c605febb6a4e1df064097ae17f44f095ca562307e2d1232824131fa",
    "original": "The dead ain't really dead, sometimes they come back to haunt the living! Don't believe me? Just head over to %settlement% and see for yourself!",
    "translation": "",
    "context": ""
  },
  {
    "key": "f8e7630274b30f0f76c45dc5d7b6893d31f1617b686f06f56853fc08339bdbc8",
    "original": "The villagers here are terrified of unknown horrors. Fewer potential recruits are to be found on the streets, and people deal less favourably with strangers.",
    "translation": "",
    "context": "this.m.Description = \"The villagers here are terrified of unknown horrors. Fewer potential recruits are to be found on the streets, and people deal less favourably with strangers.\""
  },
  {
    "key": "3aeb35883507b4cb6c128f7dd49a3848c3264c67819830f4c1fb56845fd89b30",
    "original": "You look like an able swordsman! I heard rumors of the dead walking again near %settlement%. Humbug probably, but frightened folks often pay good crowns to feel safe again.",
    "translation": "",
    "context": ""
  }
]