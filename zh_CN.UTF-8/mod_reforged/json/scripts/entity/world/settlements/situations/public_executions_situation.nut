[
  {
    "key": "533692d499c255ea648e6427334318eb5886746f12fa9a29e7fcc941db86f9b3",
    "original": " no longer has ",
    "translation": "",
    "context": "_s + \" no longer has \" + this.m.Name"
  },
  {
    "key": "a0a4d5a0a49ec1f86c5178602a8c9170b39450f5963c5deb7da8a5d049c83ed6",
    "original": " now has ",
    "translation": "",
    "context": "_s + \" now has \" + this.m.Name"
  },
  {
    "key": "95ed207b9d1cb193eeeb502875a463af8ca4187dac56650e0aea0d67ff83d56f",
    "original": "A public execution is not to be missed and provides entertainment for the whole family. Food and drink are abundant during such an occasion, but merchants may also try to take advantage of spectators.",
    "translation": "",
    "context": "this.m.Description = \"A public execution is not to be missed and provides entertainment for the whole family. Food and drink are abundant during such an occasion, but merchants may also try to take advantage of spectators.\""
  },
  {
    "key": "672c8fb6bf60f865eaf387ec071cefbc6e27bbfce3a21d4cc1db4a90a8f3e386",
    "original": "A whole bunch of folks is headin' over to %settlement% for the big spectacle! Men, womenfolk, young ones, all on the road to see the upcoming executions!",
    "translation": "",
    "context": ""
  },
  {
    "key": "9c3724cc5182fb824415967b20620b6fd748b84933f7baa7451e3bbea810182a",
    "original": "I heard they grabbed some brigands near %settlement% and are putting them to the chopping block. Serves them just right, waylaying poor folk on the roads...",
    "translation": "",
    "context": ""
  },
  {
    "key": "b815ab65354bb405137d07b7d481a7740fa42b3c871c776767c8b5fe36f516a3",
    "original": "Public Executions",
    "translation": "",
    "context": "this.m.Name = \"Public Executions\""
  },
  {
    "key": "9a3ee2e7e5c2b77b04db4a1112d7abacd82e0787ce280a1a8f5d30050aa687a2",
    "original": "Us poor folks don't have much to enjoy these days, but a good hanging is always welcome. Hasn't been one here since autumn, but they is hanging folk over at %settlement% is what %randomname% tells me.",
    "translation": "",
    "context": ""
  }
]