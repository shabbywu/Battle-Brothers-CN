    "key": "533692d499c255ea648e6427334318eb5886746f12fa9a29e7fcc941db86f9b3",
    "original": " no longer has ",
    "translation": "",
    "context": "_s + \" no longer has \" + this.m.Name"
  },
  {
    "key": "a0a4d5a0a49ec1f86c5178602a8c9170b39450f5963c5deb7da8a5d049c83ed6",
    "original": " now has ",
    "translation": "",
    "context": "_s + \" now has \" + this.m.Name"
  },
  {
    "key": "82d50791469fd3b429337ebe46907acd875c84bbc7788ecf17b595dab5dbbd79",
    "original": "Disappearing Villagers",
    "translation": "",
    "context": "this.m.Name = \"Disappearing Villagers\""
  },
  {
    "key": "5f7edf57e4543325759719c4079e53dbafedc6c447f056cfd770945ba5e4242e",
    "original": "I just cancelled my visit to %settlement% after I heard that people go missing over there. Staying out of trouble served me well so far!",
    "translation": "",
    "context": ""
  },
  {
    "key": "45edff1e44c600f70424889391a449026c6025d9564aa042b87c28f4ee8eefbd",
    "original": "Me neighbour %randomname% went to %settlement% 'bout a week ago. Haven't heard a word of him since. I just hope nothing happened to him, you know, with them brigands and monsters and all roaming 'bout...",
    "translation": "",
    "context": ""
  },
  {
    "key": "8c60c46b2a2f6158723c1621627d283d94289d4b9d795e956d45b3631b86df55",
    "original": "The forces of evil are strong in this world. They hide in the woods, and in the mountains, and in the shadows, and sometimes folk just disappear without a trace. It's happening again right now over in %settlement%.",
    "translation": "",
    "context": ""
  },
  {
    "key": "e95317f2b008d0799ff21b2724bd0537e479f5c6328705fd62740ee3e24282ee",
    "original": "Villagers have been disappearing from this town, putting everyone on edge. Fewer potential recruits are to be found on the streets, and people deal less favourably with strangers.",
    "translation": "",
    "context": "this.m.Description = \"Villagers have been disappearing from this town, putting everyone on edge. Fewer potential recruits are to be found on the streets, and people deal less favourably with strangers.\""
  }
]