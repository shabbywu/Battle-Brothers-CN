  {
    "key": "d2d23622e1f3dcd5f9295204c3f70f78ef0301ffdebab7e237d592c8dce193f6",
    "original": "Ceremonial Season",
    "translation": "",
    "context": "this.m.Name = \"Ceremonial Season\""
  },
  {
    "key": "8ea861b0a21daa6ae37031a089e995a1bd80b0f7003834ba2eee6453e78db942",
    "original": "During the ceremonial season, large amounts of incense are used by temples. The demand and prices for incense are at an all-time high.",
    "translation": "",
    "context": "this.m.Description = \"During the ceremonial season, large amounts of incense are used by temples. The demand and prices for incense are at an all-time high.\""
  },
  {
    "key": "603812b6333ed2c92293e52c962d9acecfc0af31f825d12e124d64f2e9bd72d3",
    "original": "During this time of the year, the temples in %settlement% smoke like a hovel that's on fire! I wonder where they get all that incense from...",
    "translation": "",
    "context": ""
  },
  {
    "key": "0bc71831b8958e1592a342c3fc0d4cd1311b5f4dc792a42ad0405249b5bf6655",
    "original": "If you are a godly person you might want to head to %settlement% to burn some incense and say some prayers.",
    "translation": "",
    "context": ""
  }
]