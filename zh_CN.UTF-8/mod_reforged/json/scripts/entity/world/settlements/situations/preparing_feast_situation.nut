  {
    "key": "e9506263136b33bf2d2946a304a1ab6993ac5116346871fe6371e802fb07bd93",
    "original": "My uncle is a servant at %settlement%, and he tells me that they're preparing a big feast. No point in going there unless you're invited, though.",
    "translation": "",
    "context": ""
  },
  {
    "key": "99b279052939ce37d83e23d54bc7282dc0fc5c16e47eb881120902278e7610f8",
    "original": "Preparing Feast",
    "translation": "",
    "context": "this.m.Name = \"Preparing Feast\""
  },
  {
    "key": "862261fe6f9acf163adfa3f954431b855be5472d5f2a655337401832b6c7a284",
    "original": "The nobles are preparing for a feast. Cook houses and kitchens are buying food in bulk.",
    "translation": "",
    "context": "this.m.Description = \"The nobles are preparing for a feast. Cook houses and kitchens are buying food in bulk.\""
  },
  {
    "key": "a8929b9e0f1bfb1ceea651beeb61198ad825630bb8ffd30b34e861344542b386",
    "original": "The oh-so-noble highborns are preparing a feast at %settlement% while us peasants have but old grain to choke on...",
    "translation": "",
    "context": ""
  }
]