[
  {
    "key": "533692d499c255ea648e6427334318eb5886746f12fa9a29e7fcc941db86f9b3",
    "original": " no longer has ",
    "translation": "",
    "context": "_s + \" no longer has \" + this.m.Name"
  },
  {
    "key": "a0a4d5a0a49ec1f86c5178602a8c9170b39450f5963c5deb7da8a5d049c83ed6",
    "original": " now has ",
    "translation": "",
    "context": "_s + \" now has \" + this.m.Name"
  },
  {
    "key": "ebbba757b2d355bb2b9c1fb017d61edc19494987783105b2896f3070e741fc58",
    "original": "Do you like venison, sellsword? And how about your men? I heard that hunting season has started in %settlement%. Just saying.",
    "translation": "",
    "context": ""
  },
  {
    "key": "0d6d822fc8388815baee1fb5a66d4cecbb1e86c0930f1b66952e79aeba28a2ce",
    "original": "Hunting Season",
    "translation": "",
    "context": "this.m.Name = \"Hunting Season\""
  },
  {
    "key": "a2780041b303b2a26b391ab9b34de7c9c1ca47af6f6a98bd144d536e691d7927",
    "original": "Hunting outside the season might get you your hands cut right off! Doesn't matter, though, as the season will start any day now in the forests over by %settlement%.",
    "translation": "",
    "context": ""
  },
  {
    "key": "744812a671ddc4a0ecff12e1a6fd7ca73f5594118a9c111d5e8f7dd1b162eaed",
    "original": "It's the time of the year that all hunters have been eagerly waiting for. The hunting season started around %settlement% just now!",
    "translation": "",
    "context": ""
  },
  {
    "key": "619f931e89a267cb1abc9c5c5dbb7fe15335f7b49efc61314c5e6e0e26ead68a",
    "original": "The forests are bustling with deer and it is hunting season. Venison and furs are in rich supply.",
    "translation": "",
    "context": "this.m.Description = \"The forests are bustling with deer and it is hunting season. Venison and furs are in rich supply.\""
  }
]