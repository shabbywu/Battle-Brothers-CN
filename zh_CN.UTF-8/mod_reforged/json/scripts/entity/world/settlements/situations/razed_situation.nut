[
  {
    "key": "96970b23ddb591e2b50b9b4721e9c9eb2b49f2ed4a86cc7bf68d400add762670",
    "original": " no longer is ",
    "translation": "",
    "context": "_s + \" no longer is \" + this.m.Name"
  },
  {
    "key": "c96c2e9cd6a838b486d772ff9ca44d06da800bbaa64d190c3bd271b738f82c4e",
    "original": " now is ",
    "translation": "",
    "context": "_s + \" now is \" + this.m.Name"
  },
  {
    "key": "d793699ecd00382cf725e999ed61746235513adf65a6f6e01c6081694daac0ae",
    "original": "%settlement% is no more, just a black charred skeleton smoking and smoldering... How did it come to this?",
    "translation": "",
    "context": ""
  },
  {
    "key": "58d1bc2638b90ae70dcb2a0f9f83d21e6c257ac548cee215fc38ee05f5767aac",
    "original": "Floods of refugees have been arriving from %settlement%. They claim that most of it has been burned to the ground! Can this be true?",
    "translation": "",
    "context": ""
  },
  {
    "key": "9e1d4a6d99278127aa928d3b14f6b533af2312ad2c8815b25b4202db544ddf8f",
    "original": "Razed",
    "translation": "",
    "context": "this.m.Name = \"Razed\""
  },
  {
    "key": "fca8aa88b6a8da3afe62eb910c6088f6324453050aaa5cc6f01d723de3978330",
    "original": "Smoke columns can be seen from miles and miles away. There is naught more than a burning pile of rubble where %settlement% once stood.",
    "translation": "",
    "context": ""
  },
  {
    "key": "34369d5c320a58f6a3fcdffb1dbd455a649924ce94d5e2456974759887c8aaa8",
    "original": "This place has been razed. Many of its inhabitants lie slain, and any valuables have been plundered.",
    "translation": "",
    "context": "this.m.Description = \"This place has been razed. Many of its inhabitants lie slain, and any valuables have been plundered.\""
  }
]