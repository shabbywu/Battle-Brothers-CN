    "original": " no longer is ",
    "translation": "",
    "context": "_s + \" no longer is \" + this.m.Name"
  },
  {
    "key": "c96c2e9cd6a838b486d772ff9ca44d06da800bbaa64d190c3bd271b738f82c4e",
    "original": " now is ",
    "translation": "",
    "context": "_s + \" now is \" + this.m.Name"
  },
  {
    "key": "1f93cb9e14ec1f070f59934e118e87ba5127063e5dc5cf3e5fa221213453b356",
    "original": "My cousin over in %settlement% keeps bragging about how good they have it there. Well stocked market stands and all. Not like this rotten place.",
    "translation": "",
    "context": ""
  },
  {
    "key": "64ecce868c5670a4e502f42dee529961328f00e84ce4809a90f458fd52288107",
    "original": "This place has been recently supplied with fresh wares, and many of those can now be bought for the right price.",
    "translation": "",
    "context": "this.m.Description = \"This place has been recently supplied with fresh wares, and many of those can now be bought for the right price.\""
  },
  {
    "key": "9708e2d42e776d82c9e98be0ba3abe862fe63f510251329fe8cd06430bd5d535",
    "original": "Trade with %settlement% is prospering, my friend! Safe roads and full stocks, let's hope it stays this way...",
    "translation": "",
    "context": ""
  },
  {
    "key": "a4817507f2d2636d7e83d668861df163fd95c4a7d7f5fe7608783143a92fb238",
    "original": "Well Supplied",
    "translation": "",
    "context": "this.m.Name = \"Well Supplied\""
  }
]