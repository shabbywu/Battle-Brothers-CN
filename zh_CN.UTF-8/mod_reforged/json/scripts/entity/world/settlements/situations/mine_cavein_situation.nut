    "key": "913f59f7a64e88f3e350d9e24be0945f1b0012fe88a79a7232f3a40c74c111c6",
    "original": " had a ",
    "translation": "",
    "context": "_s + \" had a \" + this.m.Name"
  },
  {
    "key": "018b7eb30e02b49bbba8caa9561297c3d898a58f83c35043e20c441265cbf404",
    "original": " no longer suffers from a ",
    "translation": "",
    "context": "_s + \" no longer suffers from a \" + this.m.Name"
  },
  {
    "key": "51146f772f4ebdb15573585f93e281aa6d61d970e0bebd0fce8ffc0e976ff807",
    "original": "A delivery of ores and minerals from the mines of %settlement% was due today, but alas it did not arrive yet. Something must have happened over there.",
    "translation": "",
    "context": ""
  },
  {
    "key": "54ee7e22778815817776fe131f2107f76ca5987478f25b9cb76f51aa3075b98c",
    "original": "A tragic accident occured, and there was a cave-in in one of the mines. Production came to a halt until the damages are repaired, and miners are without means to feed their families.",
    "translation": "",
    "context": "this.m.Description = \"A tragic accident occured, and there was a cave-in in one of the mines. Production came to a halt until the damages are repaired, and miners are without means to feed their families.\""
  },
  {
    "key": "11df15726647f86a530c7042501774da8465d90a318d757a780a9cd81d044cbc",
    "original": "Heard there was a cave-in on one of the mines at %settlement%. Just imagine being buried alive deep under rock and earth...",
    "translation": "",
    "context": ""
  },
  {
    "key": "263701482f360eff6dc0e268b450d93f41b6d1da2fb85fca5169d5652875f2d4",
    "original": "I'd never work underground, I am no stinkin' mole! It's a damn deathtrap! Not long ago a mine gave in by %settlement%, don't even want to know how many died that day...",
    "translation": "",
    "context": ""
  },
  {
    "key": "f19afa544618f62c898372fe28e08cff2cdaf1bb51033c309a97cbb44e6b423c",
    "original": "Mine Cave In",
    "translation": "",
    "context": "this.m.Name = \"Mine Cave In\""
  }
]