  {
    "key": "c32995c52942357f35ff445cf4a4de6bf9b548036ae5af73ed38e27fa1529736",
    "original": "Me, I am more of the solitary type. Big fairs like the one over in %settlement% just don't appeal to me at all....",
    "translation": "",
    "context": ""
  },
  {
    "key": "9c0d738513a4fbaf01938d631004c02b09f715bd149645350326e8ca026f56de",
    "original": "Seasonal Fair",
    "translation": "",
    "context": "this.m.Name = \"Seasonal Fair\""
  },
  {
    "key": "f8b4d0da7946501e46cd5c40d67c9ddc57fe4551e9ba1738e88d83684a5f1922",
    "original": "Traders from far and wide gather here for the seasonal fair. Lots of people flock here from the surrounding countryside, and it's a great time to sell goods or rummage through plentiful offers.",
    "translation": "",
    "context": "this.m.Description = \"Traders from far and wide gather here for the seasonal fair. Lots of people flock here from the surrounding countryside, and it's a great time to sell goods or rummage through plentiful offers.\""
  },
  {
    "key": "1bc9f636ffaaa11705feba68a321062877f541a5824ff0b70776e1fdb359cbc1",
    "original": "What's going on around here you're asking? Well, there's a fair over in %settlement%. Merchants from far and wide gather to offer their wares.",
    "translation": "",
    "context": ""
  }
]