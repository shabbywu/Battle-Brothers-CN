  {
    "key": "c96c2e9cd6a838b486d772ff9ca44d06da800bbaa64d190c3bd271b738f82c4e",
    "original": " now is ",
    "translation": "",
    "context": "_s + \" now is \" + this.m.Name"
  },
  {
    "key": "bdd810d58b5e8852658de9ab327828c9d6eddf1f0a7e40b782062be6a822f7ef",
    "original": "A sickness has struck down many folks in this settlement. There are fewer recruits available, and food and medical supplies are scarce.",
    "translation": "",
    "context": "this.m.Description = \"A sickness has struck down many folks in this settlement. There are fewer recruits available, and food and medical supplies are scarce.\""
  },
  {
    "key": "e398aaf886be84dc6405d27434dc47618dca18b6125a1f14a4bf455d75270b75",
    "original": "Don't go near %settlement%! A sickness struck that poor town and the folks are dying like flies over there...",
    "translation": "",
    "context": ""
  },
  {
    "key": "37a7b4d5c5658b4fcfcabcad77f8cb5c9f099068a087f9916e8452e4ffee4c41",
    "original": "Fancy my herbal necklace? It protects me against even the most pestilent disease. You better get yourself one, too, if you're planning to ahead on towards %settlement%.",
    "translation": "",
    "context": ""
  },
  {
    "key": "373a598974cd99bda2510a1ffe5cd3903e148547a896ae7f79ea6b36df577193",
    "original": "Sickness",
    "translation": "",
    "context": "this.m.Name = \"Sickness\""
  },
  {
    "key": "6872e7d221c2d6564ecbdac16716b76cfd325a6c59d5fd2b301db5cc971e096a",
    "original": "We had some folks coming here from %settlement%, but had to send them away at the gates. Everybody knows that a cruel disease is spreading in that cursed town.",
    "translation": "",
    "context": ""
  }
]