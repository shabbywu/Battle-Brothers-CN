[
  {
    "key": "2fb92304011897790be2a2862ed588a736e0749d87bb33f1acc88dc5d6d2b897",
    "original": "Been telling my cousin for years to stop robbing people on the road. Ain't no way for it but to end badly. And right I was, it did. Got his comeuppance the other day by %settlement%. Place is crawling with militia.",
    "translation": "",
    "context": ""
  },
  {
    "key": "3d2b69958e38f68c20b28336bdb86fe16047e75d52fc6c39b437df8777be9ddf",
    "original": "Just got back from %settlement% last night. No brigand in sight on the roads, thank the gods.",
    "translation": "",
    "context": ""
  },
  {
    "key": "1eada91e6aebb26338b3e1ea2b9168e22891d183ef1e063247ca0c52448759a2",
    "original": "Safe Roads",
    "translation": "",
    "context": "this.m.Name = \"Safe Roads\""
  },
  {
    "key": "e83062fd26c32b3c281f5f9a25baf4fbda1566a908f15c995ef042a5613d1918",
    "original": "Seems the brigands around %settlement% are having a rough time now with all those patrols going on.",
    "translation": "",
    "context": ""
  },
  {
    "key": "9ba54cb5bc139a1f9d74854cb69de00198f8c2bfc800a642bbb0a6b4e67e2634",
    "original": "The roads leading here have been reasonably safe of late, which allowed for many a profitable trade to be made and the settlement to prosper somewhat.",
    "translation": "",
    "context": "this.m.Description = \"The roads leading here have been reasonably safe of late, which allowed for many a profitable trade to be made and the settlement to prosper somewhat.\""
  }
]