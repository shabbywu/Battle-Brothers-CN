  {
    "key": "533692d499c255ea648e6427334318eb5886746f12fa9a29e7fcc941db86f9b3",
    "original": " no longer has ",
    "translation": "",
    "context": "_s + \" no longer has \" + this.m.Name"
  },
  {
    "key": "a0a4d5a0a49ec1f86c5178602a8c9170b39450f5963c5deb7da8a5d049c83ed6",
    "original": " now has ",
    "translation": "",
    "context": "_s + \" now has \" + this.m.Name"
  },
  {
    "key": "40be0fb2899a9dc2a2e814e550b1beab59c9e0290164275c2d56957aec278df8",
    "original": "Did you see the columns of smoke in the evening sky? They are rising over from %settlement% where greenskins are burning and pillaging the countryside.",
    "translation": "",
    "context": ""
  },
  {
    "key": "0a71e1fd97e0972cfd50831fecefd102aad6990a74f17a9a20442ab7878bd914",
    "original": "Greenskins are terrorizing the surrounding lands, and many lives have been lost as orcs or goblins continue to raid outlying farms and raze caravans. Supplies are beginning to run low and people become desperate.",
    "translation": "",
    "context": "this.m.Description = \"Greenskins are terrorizing the surrounding lands, and many lives have been lost as orcs or goblins continue to raid outlying farms and raze caravans. Supplies are beginning to run low and people become desperate.\""
  },
  {
    "key": "79bdd2b76c91424ba8dd13cbf1f5eb9210d10946ae11b881c6985538fe759aec",
    "original": "Here, take a look at what's left of my hand! Can hardly use it anymore on account of it having no fingers since that run-in with greenskins a while ago. Now I hear they are back, marauding around %settlement% right as we speak.",
    "translation": "",
    "context": ""
  },
  {
    "key": "1265bda57509f54c8eee27b5aaa20a9f7362ac8a7917f5579edf07cfd31cca6b",
    "original": "I heard rumors that vile greenskins are marauding around %settlement%! Is it true? I hope they don't make their way over here...",
    "translation": "",
    "context": ""
  },
  {
    "key": "9230e3727c957053161871551522afa5a3a2f9f3ec7c430f6f76512adb0c122b",
    "original": "Marauding Greenskins",
    "translation": "",
    "context": "this.m.Name = \"Marauding Greenskins\""
  }
]