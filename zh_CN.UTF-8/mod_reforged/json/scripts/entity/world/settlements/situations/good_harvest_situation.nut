    "key": "7a9681b5c1014500613cc052e78cfcebcaa86d754ca85444194b537b6082b595",
    "original": " benefits from a ",
    "translation": "",
    "context": "_s + \" benefits from a \" + this.m.Name"
  },
  {
    "key": "aec119f4b7b55553e7c8a16da7233ae7b5088e74cd6bc20e70380cee9ea30f28",
    "original": " no longer benefits from a ",
    "translation": "",
    "context": "_s + \" no longer benefits from a \" + this.m.Name"
  },
  {
    "key": "0af67dccf5bf29b0cf83be0c263eb157520d0a3227570d7ffcd0f5552df821d6",
    "original": "Conditions for crops have been perfect. Food is readily available and offered at lower prices.",
    "translation": "",
    "context": "this.m.Description = \"Conditions for crops have been perfect. Food is readily available and offered at lower prices.\""
  },
  {
    "key": "6ab12fea5fa85fc3d7f50cccffdb0278697edd124a9914ba00e5e77f43137423",
    "original": "Good Harvest",
    "translation": "",
    "context": "this.m.Name = \"Good Harvest\""
  },
  {
    "key": "4d45bd0c57a757e4dbbe7e07b8e7e8f32b0b903f0b605010b70933a4f07c3fc3",
    "original": "Head over to %settlement% if you need to restock on food. Those lucky bastards have had themselves a bountiful harvest season this year.",
    "translation": "",
    "context": ""
  },
  {
    "key": "53bc22f6b04ef80e9114eccea8c054335c2716ddd83a34d26f8c2cf829799c66",
    "original": "I came here from %settlement% to sell our extra produce. The gods have been smiling on us and granted us the best harvest in many years!",
    "translation": "",
    "context": ""
  },
  {
    "key": "31fe142e8910e0ea3f83731f8e99ee0a1b926f347f63dd3b3d04b24f89d39959",
    "original": "I just learned that in %settlement% the granaries and larders are filled to the brim thanks to a good harvest. ",
    "translation": "",
    "context": ""
  }
]