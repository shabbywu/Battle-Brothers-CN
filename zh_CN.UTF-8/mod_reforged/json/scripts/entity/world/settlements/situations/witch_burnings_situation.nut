  },
  {
    "key": "63e427e3a2d05283e46e65b1492715eb327b81f04221b9b01e3ccf3953f37809",
    "original": "A fiery spectacle, witch burnings attract spectators, and spectators attract food stands. And then, there's bound to be a number of witchhunters in town...",
    "translation": "",
    "context": "this.m.Description = \"A fiery spectacle, witch burnings attract spectators, and spectators attract food stands. And then, there's bound to be a number of witchhunters in town...\""
  },
  {
    "key": "9d66b673bb845ee20eb3ac4fe9d6082a6bb1dbb001cba1bca0cdce6092706692",
    "original": "From what I hear they found a witch in %settlement% and will put her to the pyre. Come to think of it, maybe I should report that old shrew that bested me on the market the other day, she's a witch for sure!",
    "translation": "",
    "context": ""
  },
  {
    "key": "ae949f7531ef25bf80d0dc7f90534994c9a8bd53eb72f4411e044d38e881a333",
    "original": "Some witch hunters came by yesterday. They didn't find what they were looking for and headed on to %settlement%.",
    "translation": "",
    "context": ""
  },
  {
    "key": "101d73a0de7c47b314e0727c6e688b41d4768dd8d1065b7b679f90ad3007d25d",
    "original": "Witch Burnings",
    "translation": "",
    "context": "this.m.Name = \"Witch Burnings\""
  }
]