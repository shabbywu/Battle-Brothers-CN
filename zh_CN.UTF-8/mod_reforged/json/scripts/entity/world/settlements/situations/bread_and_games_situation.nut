[
  {
    "key": "533692d499c255ea648e6427334318eb5886746f12fa9a29e7fcc941db86f9b3",
    "original": " no longer has ",
    "translation": "",
    "context": "_s + \" no longer has \" + this.m.Name"
  },
  {
    "key": "a0a4d5a0a49ec1f86c5178602a8c9170b39450f5963c5deb7da8a5d049c83ed6",
    "original": " now has ",
    "translation": "",
    "context": "_s + \" now has \" + this.m.Name"
  },
  {
    "key": "b57f89036ed4c213fedefeddf4f681e7f0a3903093c708007c19818bacf29bb0",
    "original": "All the hard work through the year and for what? I will tell you: Food, drink and games! I will head out to %settlement% to join in, and so should you.",
    "translation": "",
    "context": ""
  },
  {
    "key": "d82624dfaf0b725dbcd32e120b08589633a0e6fa6def79e475df950ef36e436e",
    "original": "Bread and Games",
    "translation": "",
    "context": "this.m.Name = \"Bread and Games\""
  },
  {
    "key": "4ddfd103faa2b4163cb56580741390c5db4752de0bc1d8ca18d9ca62a6f0c286",
    "original": "Ever been to the famed games of the south? Head to %settlement% and see for yourself the glory of the festivities!",
    "translation": "",
    "context": ""
  },
  {
    "key": "b213a517f4b4f822753dbabccbf172ea93df82925520c18669b0f41894fe1840",
    "original": "Praise the wise council of %settlement%! A time of food, drink and games is upon us!",
    "translation": "",
    "context": ""
  },
  {
    "key": "1aab18ee7ef27dd1e84a39d84e699f7d178a67590c7b4e222f32179670a845e2",
    "original": "The city council ordered a time of food, drink and games for everyone to keep the population happy. Food and drink are easy to come by, gladiators are flocking to the city, and arena fights pay more than usual.",
    "translation": "",
    "context": "this.m.Description = \"The city council ordered a time of food, drink and games for everyone to keep the population happy. Food and drink are easy to come by, gladiators are flocking to the city, and arena fights pay more than usual.\""
  }
]