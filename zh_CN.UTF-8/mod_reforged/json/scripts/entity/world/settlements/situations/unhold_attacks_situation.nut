  {
    "key": "9f8b4186052a8c1f3753ec8e9caa47673c57509df3f9471ec5f9f73357bbd45e",
    "original": "A traveling merchant told me about giant footprints near the road from %settlement%. Sure as hell would not want to meet whatever beast left those!",
    "translation": "",
    "context": ""
  },
  {
    "key": "3874a9ba69560f77f766974b620e9a087f91c88656c0fac2fccee97c169b89be",
    "original": "Ever heard of unholds? Huge monsters that stomp whole carts under a foot! I heard rumors of sightings near %settlement%.",
    "translation": "",
    "context": ""
  },
  {
    "key": "02f98d0fd89fde0cf1acdb6d0f0dfd1db094195d147013f7052f8a13ad268377",
    "original": "Large Unholds have been seen and heard in the area. The townsfolk are scared of leaving the vicinity of the settlement.",
    "translation": "",
    "context": "this.m.Description = \"Large Unholds have been seen and heard in the area. The townsfolk are scared of leaving the vicinity of the settlement.\""
  },
  {
    "key": "9c122ea3e2d2db2f8402e81319f96010a721b15f77f9fd57826ea02c5cb3c21c",
    "original": "Unhold Attacks",
    "translation": "",
    "context": "this.m.Name = \"Unhold Attacks\""
  },
  {
    "key": "6e04459045520d8ba677471ac76a35bff347a8e63c739d5a2cb0838316b4ad52",
    "original": "When I was in %settlement% the other day, a group of hunters went missing. They were after some sort of giant...",
    "translation": "",
    "context": ""
  }
