  },
  {
    "key": "ceafdacd3e433e5e43c0ec9c5142fcbfbeb44ec7013fe8d5acbb158a080fe045",
    "original": "Recent events have left this place short on food. As people are on the verge of starving, food is hard to come by and prices are on the rise.",
    "translation": "",
    "context": "this.m.Description = \"Recent events have left this place short on food. As people are on the verge of starving, food is hard to come by and prices are on the rise.\""
  },
  {
    "key": "416973f036f09a74acd785112b4415c583898c9d3622691aa06e93b3ad474eb4",
    "original": "Short on Food",
    "translation": "",
    "context": "this.m.Name = \"Short on Food\""
  },
  {
    "key": "6cf725c45294efdab6f8c2024873b1f132c562e5ced6a96a61be8aeb4b88654b",
    "original": "Some farmer just arrived today from %settlement%. Told stories of slain cattle, burned fields and empty larders. Looked like a damn walking skeleton himself!",
    "translation": "",
    "context": ""
  },
  {
    "key": "aab5754fe3997127e3df3edfc265dcd5f70d5196cf3a0446cbde2625568b3156",
    "original": "The men and women in %settlement% are starving, I heard, with nothing but dirt to eat. I don't think I'll ever complain about my mouldy grain soup again!",
    "translation": "",
    "context": ""
  }
]