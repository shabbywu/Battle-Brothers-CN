[
  {
    "key": "e66a75c3496621929eabe534a29a50e0969f29abe0b98f9548acc69e1c8a57f2",
    "original": " has been ",
    "translation": "",
    "context": "_s + \" has been \" + this.m.Name"
  },
  {
    "key": "96970b23ddb591e2b50b9b4721e9c9eb2b49f2ed4a86cc7bf68d400add762670",
    "original": " no longer is ",
    "translation": "",
    "context": "_s + \" no longer is \" + this.m.Name"
  },
  {
    "key": "ef7e35acc922b91cbaac8dfc1be113ba7788d17dad21238afa214dc1d039b524",
    "original": "Folks' arrivin' from %settlement%, sayin' it's been raided and plundered right good. Poor sobs, but what're we to do? Ain't got much ourselves. It's up to the lord to protect them!",
    "translation": "",
    "context": ""
  },
  {
    "key": "36b23a0d5bc59affbed9f943ef0867a7e7776dfa35898df0b280095261081560",
    "original": "Raided",
    "translation": "",
    "context": "this.m.Name = \"Raided\""
  },
  {
    "key": "c7db4fc2cf23c32e485e4dd0d7683065a1ad187878ccc27e211171f30d48a7be",
    "original": "These are dangerous times indeed, sellsword. I just got word that %settlement% was plundered and raided not two nights past.",
    "translation": "",
    "context": ""
  },
  {
    "key": "daf46921507678c51cb801edc665b773986a10d947a53b78b0fe9953938de07e",
    "original": "This place has been recently raided! It's suffered damage, has lost valuable goods and supplies, and lives were lost.",
    "translation": "",
    "context": "this.m.Description = \"This place has been recently raided! It's suffered damage, has lost valuable goods and supplies, and lives were lost.\""
  },
  {
    "key": "14991ea1d416bfc57773832384a1c2ea53a51b05b8ac29b5d2e24dea36f21a9c",
    "original": "You one of them raiders? Sure look and smell like one! Your men pillage %settlement%? Get out of here, I says, we don't want your kind around!",
    "translation": "",
    "context": ""
  }
]