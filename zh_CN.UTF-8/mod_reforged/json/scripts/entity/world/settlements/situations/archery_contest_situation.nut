    "key": "533692d499c255ea648e6427334318eb5886746f12fa9a29e7fcc941db86f9b3",
    "original": " no longer has ",
    "translation": "",
    "context": "_s + \" no longer has \" + this.m.Name"
  },
  {
    "key": "a0a4d5a0a49ec1f86c5178602a8c9170b39450f5963c5deb7da8a5d049c83ed6",
    "original": " now has ",
    "translation": "",
    "context": "_s + \" now has \" + this.m.Name"
  },
  {
    "key": "682dce4dc09191c76771556cd3f445154071630dc2e8e16716f41da9bb956394",
    "original": "A contest in archery has attracted anyone proficient with a bow. A good time, perhaps, to look for according recruits.",
    "translation": "",
    "context": "this.m.Description = \"A contest in archery has attracted anyone proficient with a bow. A good time, perhaps, to look for according recruits.\""
  },
  {
    "key": "34079f711568aede3a7701e1fa5091c0d4938bc7a2e9e6a5b4bb46811efa1f32",
    "original": "Anyone skilled with a bow is making their way to %settlement% these days for some contest. Most of them poachers and other lowlifes, I imagine.",
    "translation": "",
    "context": ""
  },
  {
    "key": "3e66f9b23ac972fd538e744b4529f6f20f704123dd5cf64522998732196b6ce1",
    "original": "Archery Contest",
    "translation": "",
    "context": "this.m.Name = \"Archery Contest\""
  },
  {
    "key": "ebd73ced2cfee63eafd22485b333234703e4a4223f258fa4b82ad29c8b7c0ece",
    "original": "If you're a skilled archer, you might want to head to that big contest over in %settlement% and let fly some arrows!",
    "translation": "",
    "context": ""
  },
  {
    "key": "a59b694ae2cfb97f9bb8ef801d39c83098e83300ce52d127a9f46a506b7815d9",
    "original": "You know, I myself was once the best archer near and far, I swear! Until a damned donkey stepped on my hand, that is. Otherwise, I'd be in %settlement% for the archery contest right now...",
    "translation": "",
    "context": ""
  }
]