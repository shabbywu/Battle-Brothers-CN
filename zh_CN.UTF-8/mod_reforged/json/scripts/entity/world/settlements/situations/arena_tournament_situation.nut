    "context": "this.m.Description = \"A large tournament is to be held at the arena. Enter it to win marvelous prizes!\""
  },
  {
    "key": "cf9d0a8aad80a0a66b07b7bc587328f13dcab0d53715b7c0706d14dd9270e829",
    "original": "After this drink I will head straight out towards %settlement% to watch the great arena tournament! Best entertainment all year!",
    "translation": "",
    "context": ""
  },
  {
    "key": "5a83851e9e5e68c4bb4fe5aed709665e5faaa0b92c978268ac84caac230589f3",
    "original": "I heard the prize for the arena tournament winner in %settlement% is even more marvelous this year!",
