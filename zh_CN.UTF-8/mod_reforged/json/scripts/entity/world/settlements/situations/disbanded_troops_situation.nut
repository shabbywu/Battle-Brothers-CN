[
  {
    "key": "533692d499c255ea648e6427334318eb5886746f12fa9a29e7fcc941db86f9b3",
    "original": " no longer has ",
    "translation": "",
    "context": "_s + \" no longer has \" + this.m.Name"
  },
  {
    "key": "a0a4d5a0a49ec1f86c5178602a8c9170b39450f5963c5deb7da8a5d049c83ed6",
    "original": " now has ",
    "translation": "",
    "context": "_s + \" now has \" + this.m.Name"
  },
  {
    "key": "f8838fff1be5dcce9bd5b3f4f0184087bf317afab5e7baec87049adac02ed294",
    "original": "Disbanded Troops",
    "translation": "",
    "context": "this.m.Name = \"Disbanded Troops\""
  },
  {
    "key": "337f2f72a8bbba5877050f49f5e3008fa1edbb0e968891b065ed49c7c9d6fa5e",
    "original": "I'm concerned for my niece; an entire unit of soldiers got disbanded at %settlement%, right near where she lives. Things won't end well if those brutes don't find employment soon!",
    "translation": "",
    "context": ""
  },
  {
    "key": "799b59f0ee9f0798612964eac7a926a557ae40e22a198254b077544ae7cd1938",
    "original": "Standing armies are expensive, my friend. I heard an entire regiment was disbanded at %settlement%. Surely there'll be some veteran fighters lingering there still, desperate for coin.",
    "translation": "",
    "context": ""
  },
  {
    "key": "fb219a8acb7a7a29e67eb9070867c8b4f418219d68ac584f1162c027e811cc5f",
    "original": "When I was young I used to be a soldier, and I liked it. Even the marching. But when my unit was disbanded I didn't know what the hell to do with myself. Now they're disbanding one of them regiments over at %settlement%, from what I hear.",
    "translation": "",
    "context": ""
  },
  {
    "key": "9051eaccc4eab4aa62834e9af55ff116eb6c38952289bca7b29df66166c9cac6",
    "original": "With a local conflict now solved, many levied troops and their weapons are no longer needed. A good time to grab a bargain or hire experienced new men.",
    "translation": "",
    "context": "this.m.Description = \"With a local conflict now solved, many levied troops and their weapons are no longer needed. A good time to grab a bargain or hire experienced new men.\""
  }
]