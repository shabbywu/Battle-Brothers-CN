[
  {
    "key": "f4c648802a15bf65bc69f9427d8089319aff4b1111431570ad082d0383b1c047",
    "original": " no longer has a ",
    "translation": "",
    "context": "_s + \" no longer has a \" + this.m.Name"
  },
  {
    "key": "ffdf580c076ee3333dda362cd4814697e493bdfad34e3cff54d5c339e9475911",
    "original": " now has a ",
    "translation": "",
    "context": "_s + \" now has a \" + this.m.Name"
  },
  {
    "key": "641b1230cc0cf097d374f7224d27b99a8c78d0923e152217bfe63cda911fcbfd",
    "original": "A local holiday has the people in a generous mood. Time for food and drink!",
    "translation": "",
    "context": "this.m.Description = \"A local holiday has the people in a generous mood. Time for food and drink!\""
  },
  {
    "key": "89acd7acff9a804f4fe84aba6072c65c4877f53ef7b9d8cb9b1643163c5133be",
    "original": "If you're looking to have a good time, head on over to %settlement% and join their celebration! Boy, I wish I could be there.",
    "translation": "",
    "context": ""
  },
  {
    "key": "1b1138bfef5b2bf89cb81656860c7dc8099be1beca88802fa846b960a8d0a1c4",
    "original": "Local Holiday",
    "translation": "",
    "context": "this.m.Name = \"Local Holiday\""
  },
  {
    "key": "46c5839e3115b005b5558374b7db86ea3930ebe6fc1d294b5c439a1cf9840608",
    "original": "The good folks over in %settlement% are having their annual holiday right now. I'd be there drinking and eating and all, if only I had the crowns. Mind getting me another ale, friend?",
    "translation": "",
    "context": ""
  },
  {
    "key": "ec21a6467a8a8d413085d1025717788b409ebcde57d33d474cbda4167fcfd086",
    "original": "You don't look quite like the festive type, if I might say so, but perhaps your men would enjoy some food and drink. Alas, both can be found aplenty in %settlement%, as they're celebrating some holiday over there.",
    "translation": "",
    "context": ""
  }
]