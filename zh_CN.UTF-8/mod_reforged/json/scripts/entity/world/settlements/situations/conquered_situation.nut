    "key": "e0add334da70addec97c6c65ec758d5da5c21da70fd5f3bc435de613131f4327",
    "original": "%settlement% was recently captured, or so I have heard. 'New Lords - same shit' is what I always say...",
    "translation": "",
    "context": ""
  },
  {
    "key": "c5856825a797bec648dbb584898603768b3f2a8d1ac58df82b2cd0b0c9c44cbf",
    "original": "Conquered",
    "translation": "",
    "context": "this.m.Name = \"Conquered\""
  },
  {
    "key": "ab7cbd95b2d226e3c87273cf0ce91031b856eef150e8e0dd4b712aca0da5333f",
    "original": "Conquering new lands is the game of nobles. I heard they just sacked %settlement%.",
    "translation": "",
    "context": ""
  },
  {
    "key": "dbdcacc0cb0c8c306f6d3d091f2fe21a63c40db5844ac9f856748296bafc53f8",
    "original": "Oh, hey sellsword! Were you at the siege of %settlement%? Well, fucking congratulations. How many did you kill? How many did you rape? ",
    "translation": "",
    "context": ""
  },
  {
    "key": "d20b8712fb4390741dc8558569c2ab53720408f194c93fb657d7e67cc9fe4494",
    "original": "This place has recently been conquered. Many lives were lost, and the survivors had to endure the conquerors taking their spoils of war. Much of the settlement is still damaged, and spirits are low.",
    "translation": "",
    "context": "this.m.Description = \"This place has recently been conquered. Many lives were lost, and the survivors had to endure the conquerors taking their spoils of war. Much of the settlement is still damaged, and spirits are low.\""
  }
]