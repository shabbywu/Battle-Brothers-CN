    "key": "56097107e959cadec5cff0c1f9506c5230a26a8ce3395e6b1c56eb93c04fd2f8",
    "original": "A once proud fortress now lying in ruins.",
    "translation": "",
    "context": "getDescription = function getDescription(){\n    local isSouthern = this.getTile().Type == this.Const.World.TerrainType.Steppe || this.getTile().Type == this.Const.World.TerrainType.Oasis || this.getTile().TacticalType == this.Const.World.TerrainTacticalType.DesertHills;\n    local isSouthern = this.getTile().Type == this.Const.World.TerrainType.Desert || isSouthern;\n    if (isSouthern) {\n        return \"These ancient ruins cast their shadows far over the surrounding sands.\";\n    } else {\n        return \"A once proud fortress now lying in ruins.\";\n    };\n    return;\n}"
  },
