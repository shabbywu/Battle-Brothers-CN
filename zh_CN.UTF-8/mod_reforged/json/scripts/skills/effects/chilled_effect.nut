  {
    "key": "f8bc7e249d425ad55c0ac4353a5ea9689b3f66611111c7ffa52e20c51cd464dc",
    "original": "This character has been chilled to the bone by cold. With their limbs frozen stiff, it takes a great deal of effort to move in a coordinated fashion. The effect will slowly wear off over [color=",
    "translation": "",
    "context": "\"This character has been chilled to the bone by cold. With their limbs frozen stiff, it takes a great deal of effort to move in a coordinated fashion. The effect will slowly wear off over [color=\" + this.Const.UI.Color.NegativeValue + \"]\" + this.m.TurnsLeft + \"[/color] more turn(s).\""
  },
  {
    "key": "6303af0614ff1ba5a1ca3d3dafd0dc09965fe98a21faf0762ff8a185d5ab38dc",
    "original": "[/color] Action Points",
    "translation": "",
    "context": "\"[color=\" + this.Const.UI.Color.NegativeValue + \"]-\" + 1 + this.m.TurnsLeft + \"[/color] Action Points\""
  },
  {
    "key": "32e5a4727d02c6c49fbe468fad52f5618f59f7ac88a2401cb71bdb9de4c40fad",
    "original": "[/color] Initiative",
    "translation": "",
    "context": "\"[color=\" + this.Const.UI.Color.NegativeValue + \"]-\" + 10 + 20 * this.m.TurnsLeft + \"[/color] Initiative\""
  },
  {
    "key": "4f552fa686bb050bb93b5828ba3b3fbe251cee2041e10ea3928745ae9b690adf",
    "original": "[/color] more turn(s).",
    "translation": "",
    "context": "\"This character has been chilled to the bone by cold. With their limbs frozen stiff, it takes a great deal of effort to move in a coordinated fashion. The effect will slowly wear off over [color=\" + this.Const.UI.Color.NegativeValue + \"]\" + this.m.TurnsLeft + \"[/color] more turn(s).\""
  }
