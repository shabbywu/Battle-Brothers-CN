  },
  {
    "key": "34a27d8af04480936f74a106b8a0cd456e4e9e89d9db9720c249d7bb3c8b11f2",
    "original": "Not uncommon for someone living the hardships of mercenary life, this character isn't quite satisfied and is hoping for things to improve.",
    "translation": "",
    "context": "text = \"Not uncommon for someone living the hardships of mercenary life, this character isn't quite satisfied and is hoping for things to improve.\""
  },
  {
    "key": "1a729ff20a7d163a273d56be705df3d28056b457d436ee836ed843ae7bdc1a5e",
    "original": "Recent events have left this character angry and vengeful towards those around him. If things don't improve very quickly, this character may decide to desert the company!",
    "translation": "",
    "context": "text = \"Recent events have left this character angry and vengeful towards those around him. If things don't improve very quickly, this character may decide to desert the company!\""
  },
  {
    "key": "e4a2cc776710580defdab5ca9535b775fd34e5182345a056b17c6818fd452db6",
    "original": "Recent events have left this character disgruntled and disappointed how things are going. It may fade, or it may get a lot worse if other events tip him over the edge.",
    "translation": "",
    "context": "text = \"Recent events have left this character disgruntled and disappointed how things are going. It may fade, or it may get a lot worse if other events tip him over the edge.\""
  },
  {
    "key": "bddfc536754436309f274345538398521d69e46d1574ead37bb8815ae0399e37",
    "original": "Recent events have left this character eager to fight with the company, pleased with how things are going and motivating to those around him.",
    "translation": "",
    "context": "text = \"Recent events have left this character eager to fight with the company, pleased with how things are going and motivating to those around him.\""
  },
  {
    "key": "10e6878d3b190eca1209e0a8c1555226d25adbf0a60a410e9f284cd886f1d639",
    "original": "Recent events have left this character in a state of euphoria, happy to spend his time in service of the company and sure of victory against any foe. It's bordering on the annoying, really.",
    "translation": "",
    "context": "text = \"Recent events have left this character in a state of euphoria, happy to spend his time in service of the company and sure of victory against any foe. It's bordering on the annoying, really.\""
  },
  {
    "key": "43c4c5999971e33772943f0d4a7d58464a271d7d407c4fe6dccab139ad81ebef",
    "original": "Recent events have left this character in good spirit. It will probably pass as reality takes a grip again, but for now, things are looking well.",
    "translation": "",
    "context": "text = \"Recent events have left this character in good spirit. It will probably pass as reality takes a grip again, but for now, things are looking well.\""
  },
  {
    "key": "7dff982e83cde008a538b1bcf055965acebef50975aa536203f7329806a963f1",
    "original": "This character is content with how things are going. Could be better, could be worse.\n\nMood will always trend towards this state over time.",
    "translation": "",
    "context": "text = \"This character is content with how things are going. Could be better, could be worse.\\n\\nMood will always trend towards this state over time.\""
  },
