  },
  {
    "key": "757044aa7f8824164d52c67d78a11509828f821baed85a7576f5a070399fb180",
    "original": "The Greenskin Invasion is threatening to sweep away our world.\nWe shall stand strong and fend it off, for this is how legends are born!",
    "translation": "",
    "context": "this.m.ButtonText = \"The Greenskin Invasion is threatening to sweep away our world.\\nWe shall stand strong and fend it off, for this is how legends are born!\""
