    "context": "this.m.UIText = \"Defeat the Greenskin Invasion\""
  },
  {
    "key": "bb3f7a8c67e80aff825f4adbd235f1cf93140503e5050fa4f55c79d29172da69",
    "original": "Defeat the Greenskin Invasion! Every contract against them, and every army or location destroyed, will bring you closer to saving the world of man.",
    "translation": "",
    "context": "this.m.TooltipText = \"Defeat the Greenskin Invasion! Every contract against them, and every army or location destroyed, will bring you closer to saving the world of man.\""
  },
  {
    "key": "f360bc04a7af7e162f83a7c43d01e83f08860626bbe51499d5673ec0a271aa6a",
