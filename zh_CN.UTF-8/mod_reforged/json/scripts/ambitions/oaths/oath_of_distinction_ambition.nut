[
  {
    "key": "ab1f0c4201ecfbf18513f05cb8772305a8d3cba52fe1ee878f3c082c5457a609",
    "original": " times (",
    "translation": "",
    "context": "\"You gain extra Renown if one of your men levels up \" + this.getBonusObjectiveGoal() + \" times (\" + this.getBonusObjectiveProgress() + \"/\" + this.getBonusObjectiveGoal() + \").\""
  },
  {
    "key": "658abdcc674f12e91a965f189af8934108d396cdcbdb05ca68e7bacd671d3127",
    "original": "Oath of Distinction",
    "translation": "",
    "context": "this.m.OathName = \"Oath of Distinction\""
  },
  {
    "key": "77a6f58cb9a683422a20bfc3b5e5b17480b74ca0efdbdfbb64b17e66557b9ae8",
    "original": "Truly distinguished are those who can follow Young Anselm's teachings.\nLet us take an Oath of Distinction and prove ourselves worthy to walk in his path!",
    "translation": "",
    "context": "this.m.ButtonText = \"Truly distinguished are those who can follow Young Anselm's teachings.\\nLet us take an Oath of Distinction and prove ourselves worthy to walk in his path!\""
  },
  {
    "key": "260bdf9868cf3ed23a2c53202588d511b368be528b3b5e4a0cca929fdfebeae6",
    "original": "You gain extra Renown if one of your men levels up ",
    "translation": "",
    "context": "\"You gain extra Renown if one of your men levels up \" + this.getBonusObjectiveGoal() + \" times (\" + this.getBonusObjectiveProgress() + \"/\" + this.getBonusObjectiveGoal() + \").\""
  },
  {
    "key": "097aa950715784f8819a9aeb78231c3c1c29550875b1ddcb7bdeec447f72e7a6",
    "original": "Young Anselm frequently pursued solitude, sometimes even on the battlefield. \"Prove yourself worthy in such a manner that not even the old gods may claim their eyes have erred in what glories they have seen.\"",
    "translation": "",
    "context": "this.m.TooltipText = \"Young Anselm frequently pursued solitude, sometimes even on the battlefield. \\\"Prove yourself worthy in such a manner that not even the old gods may claim their eyes have erred in what glories they have seen.\\\"\""
  },
  {
    "key": "1ee1be19c0fbe02a986986a83d1786b7b5e70290038288d2e2a004330e0f63a7",
    "original": "Your men gain no experience for allied kills.",
    "translation": "",
    "context": "this.m.OathBurdenText = \"Your men gain no experience for allied kills.\""
  },
  {
    "key": "73fe45b3176c829a85abb0e1f664a8459d8e81592aa20278ec10feb9756baafa",
    "original": "Your men get [color=",
    "translation": "",
    "context": "\"Your men get [color=\" + this.Const.UI.Color.PositiveValue + \"]+10[/color] Resolve, [color=\" + this.Const.UI.Color.PositiveValue + \"]+3[/color] Fatigue Recovery per turn, and deal [color=\" + this.Const.UI.Color.PositiveValue + \"]+10%[/color] damage if there are no allies on adjacent tiles.\""
  },
  {
    "key": "3b944bb42dfc7cda7f1cc5abc291414f3bde66f5b07da326a6eede31b1dc333c",
    "original": "[img]gfx/ui/events/event_180.png[/img]{Many swordmasters practice solitude. The thought is that they are not fighting the men in front of them, they are fighting for the spaces in between. While you cannot possibly understand the small nuances which differentiate a swordmaster from a would be sellsword hacking at air, you realize the kernel of truth in the axiom. Oathtakers, though honorable and diligent, are still at heart brutally courageous and absurdly overconfident. The Oath of Distinction followed the swordmaster's art in spirit, and the Oathtaker's in mind. Standing out on their own, each man sought to prove himself to his own accord and prove himself worthy of others' praise. And if any unbiased laity happened to be watching, then it'd be damn impossible to say the %companyname% did not distinguish itself as a fine outfit.\n\nBut distinction be damned. We can't be glory hogging for all our days! Onto the next Oath!}",
    "translation": "",
    "context": "this.m.SuccessText = \"[img]gfx/ui/events/event_180.png[/img]{Many swordmasters practice solitude. The thought is that they are not fighting the men in front of them, they are fighting for the spaces in between. While you cannot possibly understand the small nuances which differentiate a swordmaster from a would be sellsword hacking at air, you realize the kernel of truth in the axiom. Oathtakers, though honorable and diligent, are still at heart brutally courageous and absurdly overconfident. The Oath of Distinction followed the swordmaster's art in spirit, and the Oathtaker's in mind. Standing out on their own, each man sought to prove himself to his own accord and prove himself worthy of others' praise. And if any unbiased laity happened to be watching, then it'd be damn impossible to say the %companyname% did not distinguish itself as a fine outfit.\\n\\nBut distinction be damned. We can't be glory hogging for all our days! Onto the next Oath!}\""
  },
  {
    "key": "11ef4db10641ad7d6b0ee6ad1f9218887a13eb65742449459fe4349102f1c230",
    "original": "]+10%[/color] damage if there are no allies on adjacent tiles.",
    "translation": "",
    "context": "\"Your men get [color=\" + this.Const.UI.Color.PositiveValue + \"]+10[/color] Resolve, [color=\" + this.Const.UI.Color.PositiveValue + \"]+3[/color] Fatigue Recovery per turn, and deal [color=\" + this.Const.UI.Color.PositiveValue + \"]+10%[/color] damage if there are no allies on adjacent tiles.\""
  },
