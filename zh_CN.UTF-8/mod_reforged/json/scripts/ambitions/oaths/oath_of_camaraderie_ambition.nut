  },
  {
    "key": "df2c30f0b389caa63bc90ed224d274a03a6bcf2a03c59e21cf128c704990914f",
    "original": "You can take up to [color=",
    "translation": "",
    "context": "\"You can take up to [color=\" + this.Const.UI.Color.PositiveValue + \"]14[/color] men into battle.\""
