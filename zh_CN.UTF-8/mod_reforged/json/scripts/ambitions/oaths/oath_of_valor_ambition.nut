[
  {
    "key": "9cbd953fca762c82a35065ef898eb5512719ead3e6e2964bd0cb3fa0ccb46e7b",
    "original": "\"Remember in times of peril that courage can overcome skill. While little can be learned through bravery alone, sheer determination shall keep you alive and that is well enough as any conclusion to the lessons of battle.\" - Young Anselm",
    "translation": "",
    "context": "this.m.TooltipText = \"\\\"Remember in times of peril that courage can overcome skill. While little can be learned through bravery alone, sheer determination shall keep you alive and that is well enough as any conclusion to the lessons of battle.\\\" - Young Anselm\""
  },
  {
    "key": "861f925bddd01b3a7520939bc4563e50dbfc77e6d349beb6930a67a40be785ad",
    "original": "Oath of Valor",
    "translation": "",
    "context": "this.m.OathName = \"Oath of Valor\""
  },
  {
    "key": "cc5e859c2e1c12098ac355b1ee4b515de786b584aa924cd2f9c79ea190101f20",
    "original": "We must have the courage to face down any challenge, no matter how daunting.\nLet us take an Oath of Valor and prove our bravery to all!",
    "translation": "",
    "context": "this.m.ButtonText = \"We must have the courage to face down any challenge, no matter how daunting.\\nLet us take an Oath of Valor and prove our bravery to all!\""
  },
  {
    "key": "0008ae3f5e4098c57d4516714ebdd68d668d8e2506319541451cde50f825b101",
    "original": "You gain extra Renown for winning battles where you are outnumbered (",
    "translation": "",
    "context": "\"You gain extra Renown for winning battles where you are outnumbered (\" + this.getBonusObjectiveProgress() + \"/\" + this.getBonusObjectiveGoal() + \").\""
  },
  {
    "key": "0cb138a6f19030d0da2e178e656b5a6057ef0afd26b15ff7dc8a9eaa8a2caed4",
    "original": "Your men gain [color=",
    "translation": "",
    "context": "\"Your men gain [color=\" + this.Const.UI.Color.NegativeValue + \"]15%[/color] less experience.\""
  },
  {
    "key": "b340b58c77b7bfc87bc96e38e8110412a7d2c283a950ce4c8d7af1ae25811cd6",
    "original": "Your men will never flee while in battle.",
    "translation": "",
    "context": "this.m.OathBoonText = \"Your men will never flee while in battle.\""
  },
  {
    "key": "704a96f1ed90afbf0da28d8d2deeb34bc718c18113fa11c6b7f55242e7018cd4",
    "original": "[img]gfx/ui/events/event_180.png[/img]{A man cannot thrive merely on skill and capability. Many know how to swing a sword, heft an axe, or loose an arrow. It is not in martial matters where man is molded, but within himself, within the corridors of his own heart. The steel forged there can't ever be defeated, for even a felled man of valor shall find himself eternal in the tomes of this world, celebrated in awe, and his name carried on the lips of those like him.\n\nNow that the company has proven itself of the firmest element, it is ready to accept another Oath!}",
    "translation": "",
    "context": "this.m.SuccessText = \"[img]gfx/ui/events/event_180.png[/img]{A man cannot thrive merely on skill and capability. Many know how to swing a sword, heft an axe, or loose an arrow. It is not in martial matters where man is molded, but within himself, within the corridors of his own heart. The steel forged there can't ever be defeated, for even a felled man of valor shall find himself eternal in the tomes of this world, celebrated in awe, and his name carried on the lips of those like him.\\n\\nNow that the company has proven itself of the firmest element, it is ready to accept another Oath!}\""
  },
  {
    "key": "ba405a6f772a2da3889391934669d81fde22194676b05154bcb4ce3dabbd5fc2",
    "original": "]15%[/color] less experience.",
    "translation": "",
    "context": "\"Your men gain [color=\" + this.Const.UI.Color.NegativeValue + \"]15%[/color] less experience.\""
  },
  {
    "key": "ee78e316cc24b76e6e417f0d97ce33e8e44a96625eab8c08200c8740cb34b214",
    "original": "{For Young Anselm! | As Oathtakers! | And death to the Oathbringers!}",
    "translation": "",
    "context": "this.m.SuccessButtonText = \"{For Young Anselm! | As Oathtakers! | And death to the Oathbringers!}\""
  }
]