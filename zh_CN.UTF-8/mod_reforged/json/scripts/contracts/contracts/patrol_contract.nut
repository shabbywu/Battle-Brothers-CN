    "key": "8ed103ea9ab8c165c75a2c8f10dd5bf6ccb0d9c9a9da920e526467f48ac985b8",
    "original": "This is clearly a trap. Let's wait.",
    "translation": "",
    "context": "Text = \"This is clearly a trap. Let's wait.\""
  },
