  },
  {
    "key": "e3eca9cd483c425bc47c5e1adead7777b66ac0581e8188a277a5d12e0be191c8",
    "original": "Don't stray too far away",
    "translation": "",
    "context": ""
  },
  {
    "key": "f399387ea235987c1fdfc8d6c7fc8a1b91f14fd55a430c0605c52510553408a7",
    "original": "Everyone, get ready. They'll soon attack in full force.",
    "translation": "",
    "context": "Text = \"Everyone, get ready. They'll soon attack in full force.\""
  },
  {
    "key": "bc7b9fa5ffbe0104ce5c2f9f984ca59f88caa9b76afeb2682b43180d75c634cf",
    "original": "Failed to defend a holy site",
    "translation": "",
    "context": ""
  },
  {
    "key": "31901af715ab87a66e29ef7e44926369c03514c1255f5a43471c2ee5172c9524",
    "original": "I need you and your men to fight at our side, lieutenant.",
    "translation": "",
    "context": "Text = \"I need you and your men to fight at our side, lieutenant.\""
  },
  {
    "key": "93722b3898f011a49c77eda60072f2dbd59d4707baa59a0ed91e9a2ba52647ea",
    "original": "I need you and your men to flank their arbalesters, lieutenant.",
    "translation": "",
    "context": "Text = \"I need you and your men to flank their arbalesters, lieutenant.\""
  },
  {
    "key": "1b8364a3c27a407cb85bd2a40594a392ff4037457bda80585c35078689466ef7",
    "original": "I need you and your men to lure away some of their infantry, lieutenant.",
    "translation": "",
    "context": "Text = \"I need you and your men to lure away some of their infantry, lieutenant.\""
  },
  {
    "key": "38dcdf6397f97b64fccec5961ac3e9392cbe7af19d9fdfa4474a9decb3a588f4",
    "original": "Move to %holysite% and defend it against northern heathens",
    "translation": "",
    "context": ""
  },
  {
