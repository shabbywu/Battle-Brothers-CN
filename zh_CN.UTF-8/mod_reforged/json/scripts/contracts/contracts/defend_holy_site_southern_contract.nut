    "translation": "",
    "context": "Title = \"Negotiations\""
  },
  {
    "key": "49962491bd9e943434ed5386e746eefd79c7ae85b3fef45a2286479c4eef2567",
    "original": "Now we wait again.",
    "translation": "",
    "context": "Text = \"Now we wait again.\""
  },
  {
    "key": "4f396acc94abbea2ff72c1ccdaac7b4246518673d860bdcc23ac50ebc304dc3e",
    "original": "Now we wait.",
    "translation": "",
