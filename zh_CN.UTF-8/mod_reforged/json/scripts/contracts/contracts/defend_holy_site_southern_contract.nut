  },
  {
    "key": "1d522c1890fe9ed8d3774b7a34d7816ebe4ae08d9f56b28a59320a9f7562dbac",
    "original": "On your return...",
    "translation": "",
    "context": "Title = \"On your return...\""
  },
  {
    "key": "fd42b8a0256129ec3df173a9c577015547580f1c524d90a9d29ebb07bc779b05",
    "original": "Professional soldiers in service to local lords.",
    "translation": "",
    "context": ""
  },
  {
    "key": "6eb4f0367c24a66c816fb62339227843a3b9e7318b35eb84e2188e1a26e540bb",
    "original": "Rally! Rally! Get ready!",
    "translation": "",
    "context": "Text = \"Rally! Rally! Get ready!\""
  },
  {
    "key": "faea1db35cfaa468708c72967773a1fe8be40903c07b9d5360557ade256a1d17",
    "original": "Recruit some of the faithful to help us in the defense!",
    "translation": "",
    "context": "Text = \"Recruit some of the faithful to help us in the defense!\""
  },
  {
    "key": "6ce1b48c8314ae800a6517012a86951c90fc463ef9c19677cc4887deaa33ace2",
    "original": "Regiment of ",
    "translation": "",
    "context": "\"Regiment of \" + candidates[this.Math.rand(0, candidates.len() - 1)].getNameOnly()"
  },
  {
    "key": "353f0e89403fe7497bd325b52b09dcff03cfd78d78704b4ae195ff9ee5b3a6f1",
    "original": "Return to ",
    "translation": "",
    "context": "\"Return to \" + this.Contract.m.Home.getName()"
  },
  {
    "key": "0eaa29d74a613ccb18def2c867aed61da2957b5ffe411de5f630d6d8d2190e8a",
    "original": "Search these grounds for anything that could be of use to us!",
    "translation": "",
    "context": "Text = \"Search these grounds for anything that could be of use to us!\""
  },
  {
    "key": "29724ffbb946db8426482306f2698e7263133aa5e73b5ad6790c6f2010610917",
    "original": "Take formation!",
    "translation": "",
    "context": "Text = \"Take formation!\""
  },
  {
    "key": "21b5c6969a49a4089bc2ac4f96786b832b51425431878fe09d5365c2a081ae0a",
    "original": "These should come in handy.",
    "translation": "",
    "context": "Text = \"These should come in handy.\""
  },
  {
    "key": "1b48480759955e2d2b60fe3abc7162a757285fb353e10769a8806f00d20ac0d8",
    "original": "Took sides in the war",
    "translation": "",
    "context": ""
  },
  {
    "key": "f990be6289b09bad7c01febdaef7af58c0f38477602c97778044a3a55920837c",
    "original": "Very good.",
    "translation": "",
    "context": "Text = \"Very good.\""
  },
  {
    "key": "d32cecd931e0b8acbdc9d8ccc72eccfdb9363121481fa2a346785afa2137c5bb",
    "original": "Victory!",
    "translation": "",
    "context": "Text = \"Victory!\""
  },
  {
    "key": "df2acce8d04eb8c64e3cc69ba11d2fc1fcce6faf38f92c425456ee466b50cb58",
    "original": "We have a defensible position here. We stay put.",
    "translation": "",
    "context": "Text = \"We have a defensible position here. We stay put.\""
  },
  {
    "key": "62316ab577fc64110723e15d9eb07d66958f0c1a0ef03f99599cf20a84ecae93",
    "original": "We have all that we need.",
    "translation": "",
    "context": "Text = \"We have all that we need.\""
  },
  {
    "key": "e5b1b8e54d795f6a7ef602e2fb36d0b6893bfbbe959a415d4ce548a3129e9141",
    "original": "We need to seize this opportunity. Prepare the men to sally forth!",
    "translation": "",
    "context": "Text = \"We need to seize this opportunity. Prepare the men to sally forth!\""
  },
  {
    "key": "992278fc1c6c2508e7e3faca4850f1408c002c8050d89fc83aa469568938ba54",
    "original": "We'll fight our way out of this!",
    "translation": "",
    "context": "Text = \"We'll fight our way out of this!\""
  },
  {
    "key": "6fb6fe92a609cdd408af37136ca33c09ab4c068003b71a2340c7257ebe3056af",
    "original": "We'll set up camp here.",
    "translation": "",
    "context": "Text = \"We'll set up camp here.\""
  },
  {
    "key": "feefcb58f8f2f7c4d09ef022b8d014a7f9d9757e8842c13d0c4ffa9023f3b2aa",
    "original": "We'll take the fire pots.",
    "translation": "",
    "context": "Text = \"We'll take the fire pots.\""
  },
  {
    "key": "2852b300c8d371ed7f20cbe691400d0b5970b06fb73c6115641aeadd0147e48a",
    "original": "We'll take the flash pots.",
    "translation": "",
    "context": "Text = \"We'll take the flash pots.\""
  },
  {
    "key": "b4d0b2601ab66f3e2974dc9cc6800a868cd609676b9022231a576710f20cf169",
    "original": "We'll take the smoke pots.",
    "translation": "",
    "context": "Text = \"We'll take the smoke pots.\""
  },
  {
    "key": "85d13cf4d5f8d972cb9d6de67c9cc3128758d8462dd3293693b2bcc94257ec0e",
    "original": "You gain ",
    "translation": "",
    "context": "\"You gain \" + item.getName()"
  },
  {
    "key": "75c45e6b8866c7aacf8d3a14cae5d644d278d2f53ab2cc835118e64cc9d12404",
    "original": "You gain [color=",
    "translation": "",
    "context": "\"You gain [color=\" + this.Const.UI.Color.PositiveEventValue + \"]\" + this.Contract.m.Payment.getOnCompletion() + \"[/color] Crowns\""
  },
