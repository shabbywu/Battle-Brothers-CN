    "context": ""
  },
  {
    "key": "a13fe5411cacd783f255c572bdc6c56739d54be420a516b38fb8ae49baa5a6d3",
    "original": "You spend [color=",
    "translation": "",
    "context": "\"You spend [color=\" + this.Const.UI.Color.NegativeEventValue + \"]\" + _event.m.Payment + \"[/color] Crowns\""
  },
  {
    "key": "a13fe5411cacd783f255c572bdc6c56739d54be420a516b38fb8ae49baa5a6d3",
