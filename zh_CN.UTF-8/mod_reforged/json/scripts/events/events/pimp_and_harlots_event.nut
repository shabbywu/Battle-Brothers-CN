  },
  {
    "key": "23a45267f5bc617a5c718da1f1bdbd78bd5a34668c6c95957fdb1123836144b1",
    "original": "Yes, yes. Go.",
    "translation": "",
    "context": "Text = \"Yes, yes. Go.\""
  },
