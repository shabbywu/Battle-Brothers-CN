    "context": "getResult = function getResult(_event){\n    local r = this.Math.rand(1, 100);\n    if (r <= 60) {\n        return \"C\";\n    } else {\n        return \"D\";\n    };\n    return;\n}"
  },
  {
    "key": "3f39d5c348e5b79d06e842c114e6cc571583bbf44e4b0ebfda1a01ec05745d43",
