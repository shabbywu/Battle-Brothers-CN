    "context": "start = function start(_event){\n    if (_event.m.Houndmaster != null) {\n        function getResult(_event){\n            return \"G\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"%houndmaster%, you're trained to handle dogs, right?\"\n            getResult = function getResult(_event){\n                return \"G\";;\n                return;\n            }\n        })\n    };\n    return;\n}"
  },
