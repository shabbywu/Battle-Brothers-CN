    "original": "The Peasant Militia",
    "translation": "",
    "context": "this.m.Title = \"The Peasant Militia\""
  },
  {
    "key": "e81708e31bb3fd87142bf6e5b36f14bcc052a143301e490693d550cd00be8cf4",
    "original": "We are our own lords.",
    "translation": "",
