  {
    "key": "bdb515f65a3a8645f4fbcbba58a6e704df2849d1a4208dc26eb6643813da4221",
    "original": "%monk%, you speak for the old gods. What say you?",
    "translation": "",
    "context": "Text = \"%monk%, you speak for the old gods. What say you?\""
  },
  {
    "key": "850b0ff65bcba4dbc2811f1a27d9c689889991149ee88a26e897e353e57ffe4e",
    "original": "%walker%, you've travelled up there. Say something.",
    "translation": "",
    "context": "Text = \"%walker%, you've travelled up there. Say something.\""
  },
  {
    "key": "285db421dde6f5bb8b0df2eb451a601f6425d4083ee4ded41980c845a8d30c76",
    "original": "Along the road...",
    "translation": "",
    "context": "this.m.Title = \"Along the road...\""
  },
  {
    "key": "bcac107018e34d508b381bcb5cc1d5bd13d64c00c025e759f8189602de105e46",
    "original": "Eat dirt, you little runts.",
    "translation": "",
    "context": "Text = \"Eat dirt, you little runts.\""
  },
  {
    "key": "a86440a3880fa7eb07923b7597eacc3b45b9483f38919db136cc52b67308dfca",
    "original": "Glad that ",
    "translation": "",
    "context": "\"Glad that \" + _event.m.Monk.getName() + \" saved children from certain doom\""
  },
  {
    "key": "a86440a3880fa7eb07923b7597eacc3b45b9483f38919db136cc52b67308dfca",
    "original": "Glad that ",
    "translation": "",
    "context": "\"Glad that \" + _event.m.Traveller.getName() + \" saved children from certain doom\""
  },
  {
    "key": "3cff56ee83df2dc0ccb9543782a2f13d90a23526920396dfd06ee9dc4d289f19",
    "original": "Godspeed.",
    "translation": "",
    "context": "Text = \"Godspeed.\""
  },
  {
    "key": "66c988dfafee458c881ad8da44cdd15b88a723ad67cf1cc085ba0f48465661de",
    "original": "Good luck, I guess.",
    "translation": "",
    "context": "Text = \"Good luck, I guess.\""
  },
  {
    "key": "5087eaa5b4cc5c09a7d33e8c20d7bd0a8ddd4685e06297e04e4f7efa58381473",
    "original": "I'll save you the long walk and rid you of any valuables right here.",
    "translation": "",
    "context": "Text = \"I'll save you the long walk and rid you of any valuables right here.\""
  },
  {
    "key": "ec2eea872d1a8029eb4882263c93dcfbc35d62ce0ff86982e8eebab219fdd51c",
    "original": "Saved some children from certain doom",
    "translation": "",
    "context": ""
  },
  {
    "key": "1ddace22c4de706d1eb71aae82de66e485ea12e9ec92f1dfe124a28336f4231e",
    "original": "Stupid kids.",
    "translation": "",
    "context": "Text = \"Stupid kids.\""
  },
  {
    "key": "97970408291306f4e80a6b06270d8b7a35ecad6aad740d330ffa09d3a262dcf7",
    "original": "Was appalled by your order to rob children",
    "translation": "",
    "context": ""
  },
  {
    "key": "85d13cf4d5f8d972cb9d6de67c9cc3128758d8462dd3293693b2bcc94257ec0e",
    "original": "You gain ",
