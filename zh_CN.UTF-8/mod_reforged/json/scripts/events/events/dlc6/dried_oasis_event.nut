  {
    "key": "df7e70e5021544f4834bbee64a9e3789febc4be81470df629cad6ddb03320a5c",
    "original": "B",
    "translation": "",
    "context": "start = function start(_event){\n    function getResult(_event){\n        return this.Math.rand(1, 100) <= 50 ? \"B\" : \"C\";;\n        return;\n    };\n    this.Options.push({\n        Text = \"Someone go fetch it!\"\n        getResult = function getResult(_event){\n            return this.Math.rand(1, 100) <= 50 ? \"B\" : \"C\";;\n            return;\n        }\n    });\n    if (_event.m.Slayer != null) {\n        function getResult(_event){\n            return \"D\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"%beastslayer% can handle this puny monster.\"\n            getResult = function getResult(_event){\n                return \"D\";;\n                return;\n            }\n        })\n    };\n    function getResult(_event){\n        return \"E\";;\n        return;\n    };\n    this.Options.push({\n        Text = \"This is not worth our trouble.\"\n        getResult = function getResult(_event){\n            return \"E\";;\n            return;\n        }\n    });\n    return;\n}"
  },
  {
    "key": "df7e70e5021544f4834bbee64a9e3789febc4be81470df629cad6ddb03320a5c",
    "original": "B",
    "translation": "",
    "context": "ID = \"B\""
  },
  {
    "key": "df7e70e5021544f4834bbee64a9e3789febc4be81470df629cad6ddb03320a5c",
    "original": "B",
    "translation": "",
    "context": "getResult = function getResult(_event){\n    return this.Math.rand(1, 100) <= 50 ? \"B\" : \"C\";;\n    return;\n}"
  },
  {
    "key": "df7e70e5021544f4834bbee64a9e3789febc4be81470df629cad6ddb03320a5c",
