[
  {
    "key": "ae31efc9bb7ce0a89c17317e6d702b0584f6bd73fe7518a2ae9d3464a76b1d5b",
    "original": "Along the way...",
    "translation": "",
    "context": "this.m.Title = \"Along the way...\""
  },
  {
    "key": "5192b6b3feef785ca2ea8f335cb3ffba912063d1a8ee10566b945fe6b7b718b6",
    "original": "And I'm about to make even more after you're dead.",
    "translation": "",
    "context": "Text = \"And I'm about to make even more after you're dead.\""
  },
  {
    "key": "638422a7bf453c36921e74b69be31c3c6c67890851f8d67afe5485330765387b",
    "original": "Disliked that you killed and robbed your hosts",
    "translation": "",
    "context": ""
  },
  {
    "key": "83892f624e04e1dcb527a8c4a4a1baf6069619fd6ae5d9976ace8a991ec6d7d0",
    "original": "Enjoyed the hospitality of nomads",
    "translation": "",
    "context": ""
  },
  {
    "key": "1d36d32c4021a3073036afd4515a274033e999dfa9cf973087596615227f82bf",
    "original": "Take anything we can use.",
    "translation": "",
    "context": "Text = \"Take anything we can use.\""
  },
  {
    "key": "5a6ad6cd60819fe4741682d0706d14f78be482d7fa795d9be72ca8fdd0569724",
    "original": "Thank you for your generosity.",
    "translation": "",
    "context": "Text = \"Thank you for your generosity.\""
  },
  {
    "key": "5a7b4582547c2e7d2127c8319619665c15da49be49d2ebe2c1ae2fb1e60bc8cf",
    "original": "Thank you for your hospitality.",
    "translation": "",
    "context": "Text = \"Thank you for your hospitality.\""
  },
  {
    "key": "0a2d21c42683b4f98fe55092855e57dfb5219e0275611e32df3d88f560acd6cb",
    "original": "What is %wildmanfull% doing over there?",
    "translation": "",
    "context": "Text = \"What is %wildmanfull% doing over there?\""
  },
  {
    "key": "97c2cadf5fa3325750e5ea41ea1332bbb32ac8c3dd80ad44b61bf8854bf6af98",
    "original": "You don't follow the beliefs of your countrymen?",
    "translation": "",
    "context": "Text = \"You don't follow the beliefs of your countrymen?\""
  },
  {
    "key": "85d13cf4d5f8d972cb9d6de67c9cc3128758d8462dd3293693b2bcc94257ec0e",
    "original": "You gain ",
    "translation": "",
    "context": "\"You gain \" + item.getName()"
  },
  {
    "key": "75c45e6b8866c7aacf8d3a14cae5d644d278d2f53ab2cc835118e64cc9d12404",
    "original": "You gain [color=",
    "translation": "",
    "context": "\"You gain [color=\" + this.Const.UI.Color.PositiveEventValue + \"]\" + money + \"[/color] Crowns\""
  },
  {
    "key": "4c7191ec29bcad5f88c9782f841c0151bf3019e2218c080ea4787ee82639d2e1",
    "original": "[/color] Crowns",
    "translation": "",
    "context": "\"You gain [color=\" + this.Const.UI.Color.PositiveEventValue + \"]\" + money + \"[/color] Crowns\""
  },
  {
    "key": "ce0003d3c71819d323ed046bc424f0f19e92d7e3a5983dfd5a22a4699a1046fa",
    "original": "[img]gfx/ui/events/event_170.png[/img]{%wildman% the wildman steps beneath the umbrella. The nomad stares at him, and the wildman at the nomad. You ask if they know each other. The nomad smiles.%SPEECH_ON%No, but yes. We've kindred spirits. I can see it in his eyes.%SPEECH_OFF%The wildman hoots and grunts, then turns and leaves. When you return your gaze to the nomad he is holding out a gilded dagger.%SPEECH_ON%Treasures, golds, those things which shine and catch a man's eye, they carry little value to me. I found this upon one of the Vizier's guards. We had slain him and his caravan for their food and water, the things which I believe most important. You may have the dagger, as nothing more than a gift.%SPEECH_OFF%You take it, but warn him that if he ambushes you the way he did the Vizier's men that you will perhaps use the very same dagger against him. The nomad nods.%SPEECH_ON%And yet it is still my gift. I would find the occasion to be of such irony that it could only be a pleasure to die in such a manner. There are worse ways to go here in the desert, friend.%SPEECH_OFF%}",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_170.png[/img]{%wildman% the wildman steps beneath the umbrella. The nomad stares at him, and the wildman at the nomad. You ask if they know each other. The nomad smiles.%SPEECH_ON%No, but yes. We've kindred spirits. I can see it in his eyes.%SPEECH_OFF%The wildman hoots and grunts, then turns and leaves. When you return your gaze to the nomad he is holding out a gilded dagger.%SPEECH_ON%Treasures, golds, those things which shine and catch a man's eye, they carry little value to me. I found this upon one of the Vizier's guards. We had slain him and his caravan for their food and water, the things which I believe most important. You may have the dagger, as nothing more than a gift.%SPEECH_OFF%You take it, but warn him that if he ambushes you the way he did the Vizier's men that you will perhaps use the very same dagger against him. The nomad nods.%SPEECH_ON%And yet it is still my gift. I would find the occasion to be of such irony that it could only be a pleasure to die in such a manner. There are worse ways to go here in the desert, friend.%SPEECH_OFF%}\""
  },
  {
    "key": "4755e2bd8fa9a8e82af81ab45ef1365f384465421c1322d7c336afaafa20ceb3",
    "original": "[img]gfx/ui/events/event_170.png[/img]{The nomad laughs.%SPEECH_ON%In matters of faith, why would anyone think alike?%SPEECH_OFF%He gathers up his rugs and umbrellas.%SPEECH_ON%I have heard in the north that there are wildmen like us.%SPEECH_OFF%You purse your lips, holding back a laugh.%SPEECH_ON%We've men of the forest who have absconded civilization, aye. But they're a more... peculiar sort compared to you and yours. They are not so much like you.%SPEECH_OFF%Nodding, the nomad gives you a gift.%SPEECH_ON%But maybe they are and you just have not been listening to them.%SPEECH_OFF%He touches his chest with a fist then the nomads continue on their journey.}",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_170.png[/img]{The nomad laughs.%SPEECH_ON%In matters of faith, why would anyone think alike?%SPEECH_OFF%He gathers up his rugs and umbrellas.%SPEECH_ON%I have heard in the north that there are wildmen like us.%SPEECH_OFF%You purse your lips, holding back a laugh.%SPEECH_ON%We've men of the forest who have absconded civilization, aye. But they're a more... peculiar sort compared to you and yours. They are not so much like you.%SPEECH_OFF%Nodding, the nomad gives you a gift.%SPEECH_ON%But maybe they are and you just have not been listening to them.%SPEECH_OFF%He touches his chest with a fist then the nomads continue on their journey.}\""
  },
  {
    "key": "13adeb12dc140eb2aac1039eb4a9354e6d0538746c594c84a5fb54bfbf0c17e8",
    "original": "[img]gfx/ui/events/event_170.png[/img]{You come across a band of nomads. Despite the severity of a war going on, they do not treat you as a threat. One welcomes you with a drink and the shade of an umbrella which you accept.%SPEECH_ON%I hope your travels have been kind, Crownling. You share a similarity with us dune runners, that of the interloper. The grievances between the north and south need not concern us.%SPEECH_OFF%He sips his own drink and nods.%SPEECH_ON%Though I suspect you have made a great deal of coin in the conflict. Some of my countrymen would consider you most faithful to the Gilder because of it.%SPEECH_OFF%}",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_170.png[/img]{You come across a band of nomads. Despite the severity of a war going on, they do not treat you as a threat. One welcomes you with a drink and the shade of an umbrella which you accept.%SPEECH_ON%I hope your travels have been kind, Crownling. You share a similarity with us dune runners, that of the interloper. The grievances between the north and south need not concern us.%SPEECH_OFF%He sips his own drink and nods.%SPEECH_ON%Though I suspect you have made a great deal of coin in the conflict. Some of my countrymen would consider you most faithful to the Gilder because of it.%SPEECH_OFF%}\""
  },
  {
    "key": "880858625dcff83f0c4827e506fb9c6a4f546b7edb9ddb78ad9bd7594317c49b",
    "original": "[img]gfx/ui/events/event_170.png[/img]{You finish your drink and tell the man your time with him was all very interesting. He goes to shake your hand at which point you put the sword through him. The rest of the company joins in and the battle is as short-lived as your sense of hospitality. The nomads have little worthwhile in their holding, but no one will know of what you've done here, though it's unlike they would care anyway.}",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_170.png[/img]{You finish your drink and tell the man your time with him was all very interesting. He goes to shake your hand at which point you put the sword through him. The rest of the company joins in and the battle is as short-lived as your sense of hospitality. The nomads have little worthwhile in their holding, but no one will know of what you've done here, though it's unlike they would care anyway.}\""
  }
]