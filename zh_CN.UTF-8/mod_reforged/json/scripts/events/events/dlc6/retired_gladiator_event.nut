[
  {
    "key": "60c07a91ce9973d4b0fc310b7bbf3515e0ecd7ae7c2588be00c796e9d9f646ff",
    "original": "%name%, also known as Wolf of Arena Alley, is a retired gladiator, but an active sellsword. He's been earning crowns by killing for a long time, and it shows both in his experience and his age.",
    "translation": "",
    "context": "_event.m.Dude.getBackground().m.RawDescription = \"%name%, also known as Wolf of Arena Alley, is a retired gladiator, but an active sellsword. He's been earning crowns by killing for a long time, and it shows both in his experience and his age.\""
  },
  {
    "key": "684c6e7aea36be8c727ef981537a008fcff58f4e3fbbd41a74ef0ab46ca5f362",
    "original": "At %townname%...",
    "translation": "",
    "context": "this.m.Title = \"At %townname%...\""
  },
  {
    "key": "75fd49f1abb977a16aac443600e413fccbe5d9310770f65a0057730737e888ec",
    "original": "Had a good laugh at a retired gladiator",
    "translation": "",
    "context": ""
  },
  {
    "key": "c87c200e02c54c3512a326efaae3513b3bf8ee57118ee5820883f10659e35922",
    "original": "No, thanks, we're good.",
    "translation": "",
    "context": "Text = \"No, thanks, we're good.\""
  },
  {
    "key": "b91d613f300c3bcc2c23ef2b53de52452a7b0e297e3e615026872452e27a2116",
    "original": "No, thanks.",
    "translation": "",
    "context": "Text = \"No, thanks.\""
  },
  {
    "key": "26b820f6102334b551222f444afa1a13301feeed3ccea56e9983304ea3dabc40",
    "original": "Perhaps %gladiator% can convince you to join us.",
    "translation": "",
    "context": "Text = \"Perhaps %gladiator% can convince you to join us.\""
  },
  {
    "key": "fc88e188961386f7e215ac1961f8868581097f0287c3ef8653567963d029d933",
    "original": "Safe travels.",
    "translation": "",
    "context": "Text = \"Safe travels.\""
  },
  {
    "key": "9f7d79d9b6a23846d45c57a0e6f66e3bc2721ff5656d9a00f8c1ba8e9dc1b114",
    "original": "Sorry.",
    "translation": "",
    "context": "Text = \"Sorry.\""
  },
  {
    "key": "d1f08a56e7e75a16008c93fbd774f31df4302c7b629aab9f2b123f824a558614",
    "original": "We'd have use of you.",
    "translation": "",
    "context": "Text = \"We'd have use of you.\""
  },
  {
    "key": "2c4a7b0eeb864ef60019a6d3eab4ab77701853aa7bccac483ff153bab33113e0",
    "original": "We'll take the armor for 1,000 crowns.",
    "translation": "",
    "context": "Text = \"We'll take the armor for 1,000 crowns.\""
  },
  {
    "key": "0d7f44886abaf159aa2739a70ad84f256396a9f08e5c6e3ec6fed447b1ffb98a",
    "original": "Welcome aboard.",
    "translation": "",
    "context": "Text = \"Welcome aboard.\""
  },
  {
    "key": "087c13597b0ef12b59495aaa3465d9b6bdef8e9a4ba7bc349440f96af45ce125",
    "original": "Well, good luck to you.",
    "translation": "",
    "context": "Text = \"Well, good luck to you.\""
  },
  {
    "key": "c57fe8da5de00cf30a423646a22c8e5ec5f28150ff01fba0b8fdd83307843cc1",
    "original": "Wolf of Arena Alley? Ah, alright.",
    "translation": "",
    "context": "Text = \"Wolf of Arena Alley? Ah, alright.\""
  },
  {
    "key": "4fc168f02a85b9131170c0b43b40d5b3b7fb00c57a68a6aa12d90efa77e97a90",
    "original": "You gain a ",
    "translation": "",
    "context": "\"You gain a \" + a.getName()"
  },
  {
    "key": "41eb00b728bb1f7d4f1c2c460ae754d1549736419b7e3c28dc49a7f1bfd47b78",
    "original": "You lose [color=",
    "translation": "",
    "context": "\"You lose [color=\" + this.Const.UI.Color.NegativeEventValue + \"]1,000[/color] Crowns\""
  },
  {
    "key": "e2dd7a4d587ea23bc6399fc6197b1ab5b6ffe94b243856ccca86a749d16e54fb",
    "original": "[img]gfx/ui/events/event_163.png[/img]{%gladiator% laughs.%SPEECH_ON%Friend, I was once a gladiator. Come with us and treat the whole world as your arena. I know you have that itch. I know it's somewhere down in there. Find it. That glee of the kill. That energy from victory. Share it with us, a band of battle brothers.%SPEECH_OFF%The elder gladiator stares at his equipment. His reflection stares back, albeit muddled and warbled from dirt and dents. He nods.%SPEECH_ON%You're right. What in the Gilder's name am I thinking? I've been piss poor and pissed on and pissed off for far too long. If your company will have me, then I shall end my days going out the way I lived it: killing!%SPEECH_OFF%}",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_163.png[/img]{%gladiator% laughs.%SPEECH_ON%Friend, I was once a gladiator. Come with us and treat the whole world as your arena. I know you have that itch. I know it's somewhere down in there. Find it. That glee of the kill. That energy from victory. Share it with us, a band of battle brothers.%SPEECH_OFF%The elder gladiator stares at his equipment. His reflection stares back, albeit muddled and warbled from dirt and dents. He nods.%SPEECH_ON%You're right. What in the Gilder's name am I thinking? I've been piss poor and pissed on and pissed off for far too long. If your company will have me, then I shall end my days going out the way I lived it: killing!%SPEECH_OFF%}\""
  },
  {
    "key": "f62a6afafd8115e6c9a7b6e880d9450bd90edcba006addf2dc4a0da24adffc21",
    "original": "[img]gfx/ui/events/event_163.png[/img]{The gladiator sits back down.%SPEECH_ON%Well, what the fuck was all that big bravado speech for?%SPEECH_OFF%%gladiator% apologizes, throwing you a glare between words whlie the rest of the company laughs.}",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_163.png[/img]{The gladiator sits back down.%SPEECH_ON%Well, what the fuck was all that big bravado speech for?%SPEECH_OFF%%gladiator% apologizes, throwing you a glare between words whlie the rest of the company laughs.}\""
  },
  {
    "key": "ec1ca7441b720e8c4462450fd9768f0abb4adea03c76cd25788b26ba0872186e",
    "original": "[img]gfx/ui/events/event_163.png[/img]{You come across an old man in the street. He wouldn't be particularly remarkable, except for the fact that he is owner of a particularly nice set of equipment. A bit worn and torn, but nice. And, of course, the fact he's an elder and hasn't had these items stolen from him is evidence of something else going on here.%SPEECH_ON%The Crownling stares, the Crownling wonders.%SPEECH_OFF%The man says as he bites in a loaf of bread. He looks up at you.%SPEECH_ON%My name is %retired%. I once fought in the arenas, but retired five years ago. Not by choice, mind. I was tasked with throwing a match, but instead I cut the opponent's head off. Said opponent was the son of a Vizier. This particular detail was not shared with me at the time. Those five years I spoke of? Spent them in a dungeon.%SPEECH_OFF%}",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_163.png[/img]{You come across an old man in the street. He wouldn't be particularly remarkable, except for the fact that he is owner of a particularly nice set of equipment. A bit worn and torn, but nice. And, of course, the fact he's an elder and hasn't had these items stolen from him is evidence of something else going on here.%SPEECH_ON%The Crownling stares, the Crownling wonders.%SPEECH_OFF%The man says as he bites in a loaf of bread. He looks up at you.%SPEECH_ON%My name is %retired%. I once fought in the arenas, but retired five years ago. Not by choice, mind. I was tasked with throwing a match, but instead I cut the opponent's head off. Said opponent was the son of a Vizier. This particular detail was not shared with me at the time. Those five years I spoke of? Spent them in a dungeon.%SPEECH_OFF%}\""
  },
  {
    "key": "6b823d7677261f66ff60d7f9972a54c96921a207650f1e9322c6899f6d50acd2",
    "original": "[img]gfx/ui/events/event_163.png[/img]{You hand him the gold and he gives you the armor. He weighs the purse of crowns.%SPEECH_ON%I suppose this will be enough to retire away on. The weapons are better left to me. This is not a particularly safe land, after all, and even an old man as dangerous as myself might need protection.%SPEECH_OFF%He's right about that. You wish him well and put the armor into inventory.}",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_163.png[/img]{You hand him the gold and he gives you the armor. He weighs the purse of crowns.%SPEECH_ON%I suppose this will be enough to retire away on. The weapons are better left to me. This is not a particularly safe land, after all, and even an old man as dangerous as myself might need protection.%SPEECH_OFF%He's right about that. You wish him well and put the armor into inventory.}\""
  },
  {
    "key": "9ea3815c6f5342f3ef4b9b6b3579942497279210b84dddc511ad33be53e5650b",
    "original": "[img]gfx/ui/events/event_163.png[/img]{You tell him that you'd have use for him in the %companyname%. He laughs.%SPEECH_ON%Fighting days are a bit beyond me. I'm looking to sell this armor at cost and leave this city forever.%SPEECH_OFF%He tilts armor forward.%SPEECH_ON%You won't find equipment like this anywhere. All I ask is 1,000 crowns for it, a gladiator's harness the likes of which you'd be hard pressed to find in any ordinary blacksmith's shop.%SPEECH_OFF%}",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_163.png[/img]{You tell him that you'd have use for him in the %companyname%. He laughs.%SPEECH_ON%Fighting days are a bit beyond me. I'm looking to sell this armor at cost and leave this city forever.%SPEECH_OFF%He tilts armor forward.%SPEECH_ON%You won't find equipment like this anywhere. All I ask is 1,000 crowns for it, a gladiator's harness the likes of which you'd be hard pressed to find in any ordinary blacksmith's shop.%SPEECH_OFF%}\""
  },
  {
    "key": "12592d9fef764d6ff4a35f4bee3f1256205c72ab8ae390c83681621c90063d73",
    "original": "[img]gfx/ui/events/event_163.png[/img]{You welcome the man aboard. He gets to his feet.%SPEECH_ON%I'd like to fight with my own gear, but I'm not partial to it. After all, I was just trying to sell it, right? Give me what you think is best and point me in the right direction. I'll show them what the Wolf of Arena Alley has to show!%SPEECH_OFF%}",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_163.png[/img]{You welcome the man aboard. He gets to his feet.%SPEECH_ON%I'd like to fight with my own gear, but I'm not partial to it. After all, I was just trying to sell it, right? Give me what you think is best and point me in the right direction. I'll show them what the Wolf of Arena Alley has to show!%SPEECH_OFF%}\""
  },
  {
    "key": "8db3640a5239f25ecee9436ee7958cff5818f7fa36c71a4fc1e9548880b52afd",
    "original": "]1,000[/color] Crowns",
    "translation": "",
    "context": "\"You lose [color=\" + this.Const.UI.Color.NegativeEventValue + \"]1,000[/color] Crowns\""
  },
  {
    "key": "694d081b06634f96e530fe0e857eeffffd3560aef18f95a126069073fb28a100",
    "original": "the Wolf",
    "translation": "",
    "context": ""
  }
]