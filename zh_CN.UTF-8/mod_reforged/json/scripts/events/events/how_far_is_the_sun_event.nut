    "context": "start = function start(_event){\n    if (_event.m.Historian != null) {\n        function getResult(_event){\n            return \"Historian\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"%historianfull%, what have you to say?\"\n            getResult = function getResult(_event){\n                return \"Historian\";;\n                return;\n            }\n        })\n    };\n    if (_event.m.Monk != null) {\n        function getResult(_event){\n            return \"Monk\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"I bet %monkfull% knows the truth.\"\n            getResult = function getResult(_event){\n                return \"Monk\";;\n                return;\n            }\n        })\n    };\n    if (_event.m.Cultist != null) {\n        function getResult(_event){\n            return \"Cultist\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"I see you thinking, %cultistfull%. What say you?\"\n            getResult = function getResult(_event){\n                return \"Cultist\";;\n                return;\n            }\n        })\n    };\n    if (_event.m.Archer != null) {\n        function getResult(_event){\n            return \"Archer\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"%archerfull%, why don't you take a shot?\"\n            getResult = function getResult(_event){\n                return \"Archer\";;\n                return;\n            }\n        })\n    };\n    function getResult(_event){\n        return 0;;\n        return;\n    };\n    this.Options.push({\n        Text = \"Enough star talk. Back to the road.\"\n        getResult = function getResult(_event){\n            return 0;;\n            return;\n        }\n    });\n    return;\n}"
