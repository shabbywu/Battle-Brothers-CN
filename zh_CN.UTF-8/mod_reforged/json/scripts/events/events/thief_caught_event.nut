[
  {
    "key": "20045ed6dceda53a08840593921a721b31c38ebee09d1fc223d40fc7d595a40d",
    "original": "Damn thieves!",
    "translation": "",
    "context": "Text = \"Damn thieves!\""
  },
  {
    "key": "d957862ff89a0372fd9180c47f5927e41cfd3d1f1b1062cf64978e67d5d72f16",
    "original": "Die with some dignity at last.",
    "translation": "",
    "context": "Text = \"Die with some dignity at last.\""
  },
  {
    "key": "5ba916722880e9f2fe0278249d34c9b18081ea49eba04dec5c22f696886360ec",
    "original": "During camp...",
    "translation": "",
    "context": "this.m.Title = \"During camp...\""
  },
  {
    "key": "0394b3341918cd86ca2bf3e68e6ea253d984108d8bc6e303e816c44a2cb85a47",
    "original": "Felt for a thief killed by you",
    "translation": "",
    "context": ""
  },
  {
    "key": "85717d5ac052e5b967252031065ac6b1c532472374303cb01fd8ae5af45a3454",
    "original": "Fine. I'll spare your life  if you work for me.",
    "translation": "",
    "context": "Text = \"Fine. I'll spare your life  if you work for me.\""
  },
  {
    "key": "e684f68611b2480310d05bb519788f31144c7a02bfd43336a45ce1773ec5b59d",
    "original": "Give him a good beating.",
    "translation": "",
    "context": "Text = \"Give him a good beating.\""
  },
  {
    "key": "e16d0b2b9d98cc211ef1ec635d2edad189b60afce25f08dc9ed9dd496c3097cc",
    "original": "Give that poor guy some food and water.",
    "translation": "",
    "context": "Text = \"Give that poor guy some food and water.\""
  },
  {
    "key": "36862945898cd61ca0397fef5c38d500985874c3fa8ab3d8da818edddade57da",
    "original": "It's better this way.",
    "translation": "",
    "context": "Text = \"It's better this way.\""
  },
  {
    "key": "a07940860b1de030da9541b11fdbb5b9de8317515b7a77c02a71d63428032401",
    "original": "Let this be a lesson to you!",
    "translation": "",
    "context": "Text = \"Let this be a lesson to you!\""
  },
  {
    "key": "34be2555b9d43b76e88de96c3712883ac362e1be711af23e1136d3450352fca4",
    "original": "Not everyone will be this lenient...",
    "translation": "",
    "context": "Text = \"Not everyone will be this lenient...\""
  },
  {
    "key": "93b5f859efd2d786e0bce56934a6474c74acba5d6e5deb55a23714c9905cd691",
    "original": "Put him to the sword.",
    "translation": "",
    "context": "Text = \"Put him to the sword.\""
  },
  {
    "key": "a2a7a04ebb304dff6d3fa8481f9c59d490560c16e219391225eb6154ba7c7dac",
    "original": "That damn scoundrel!",
    "translation": "",
    "context": "Text = \"That damn scoundrel!\""
  },
  {
    "key": "5dc779a9405bb3d0e21bb32f507d08abfe27fa20a14ff5c2ffe8453cef1449a5",
    "original": "We need fighting men, not underfed thieves.",
    "translation": "",
    "context": "Text = \"We need fighting men, not underfed thieves.\""
  },
  {
    "key": "8b2502ce0faf8ef11701a928bce9e9d5aaafcae548f10a186304bac47f999700",
    "original": "Well, fine, you might as well join us.",
    "translation": "",
    "context": "Text = \"Well, fine, you might as well join us.\""
  },
  {
    "key": "206a22ae79743f3b9862628939132ec211d951f223ce6d2a7b925ba56a76f2d9",
    "original": "You lose ",
    "translation": "",
    "context": "\"You lose \" + food.getName()"
  },
  {
    "key": "41eb00b728bb1f7d4f1c2c460ae754d1549736419b7e3c28dc49a7f1bfd47b78",
    "original": "You lose [color=",
    "translation": "",
    "context": "\"You lose [color=\" + this.Const.UI.Color.NegativeEventValue + \"]-\" + amount + \"[/color] Medical Supplies\""
  },
  {
    "key": "41eb00b728bb1f7d4f1c2c460ae754d1549736419b7e3c28dc49a7f1bfd47b78",
    "original": "You lose [color=",
    "translation": "",
    "context": "\"You lose [color=\" + this.Const.UI.Color.NegativeEventValue + \"]-\" + amount + \"[/color] Tools and Supplies\""
  },
  {
    "key": "41eb00b728bb1f7d4f1c2c460ae754d1549736419b7e3c28dc49a7f1bfd47b78",
    "original": "You lose [color=",
    "translation": "",
    "context": "\"You lose [color=\" + this.Const.UI.Color.NegativeEventValue + \"]-\" + amount + \"[/color] Ammunition\""
  },
  {
    "key": "b8e7345d9e7e48fd3808f319051565806f34ae591f012b8d41385ab82e447a3e",
    "original": "You lose some ",
    "translation": "",
    "context": "\"You lose some \" + food.getName()"
  },
  {
    "key": "88916b630270dd394cb882ad1e0e33c236e955039eee15e561afe46950ea2e0e",
    "original": "[/color] Ammunition",
    "translation": "",
    "context": "\"You lose [color=\" + this.Const.UI.Color.NegativeEventValue + \"]-\" + amount + \"[/color] Ammunition\""
  },
  {
    "key": "a66ebf68b41a42c42344f1e6d21da6ee774c2ad1cde31e11a872713160e87ea7",
    "original": "[/color] Medical Supplies",
    "translation": "",
    "context": "\"You lose [color=\" + this.Const.UI.Color.NegativeEventValue + \"]-\" + amount + \"[/color] Medical Supplies\""
  },
  {
    "key": "5200f9e430d81871e9a59e77c996544f2acab92154c168015a1d6a67a0c59890",
    "original": "[/color] Tools and Supplies",
    "translation": "",
    "context": "\"You lose [color=\" + this.Const.UI.Color.NegativeEventValue + \"]-\" + amount + \"[/color] Tools and Supplies\""
  },
  {
    "key": "56f80b5795e9ee5ebcf2271477cca6fe8b4792a164d0f4127995bff83e6349a1",
    "original": "[img]gfx/ui/events/event_05.png[/img]You lower your weapon and the man crawls to you and hugs your legs. He kisses your feet until you draw away.\n\nTo get things straight, you give him a long list of orders and how it is to work in the company. You also give him a contract which he signs with a jagged 'x'. A few of the brothers then spend the rest of the day teaching him the ropes and introducing him to the rest of the company. By night's end, it seems like he's already beginning to fit in. By next morning, you wake to see a great number of supplies are missing and the new man is nowhere in sight. It appears that, although you stayed the thief's execution, he went on ahead and stole things anyway. Let that be a lesson to you.",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_05.png[/img]You lower your weapon and the man crawls to you and hugs your legs. He kisses your feet until you draw away.\\n\\nTo get things straight, you give him a long list of orders and how it is to work in the company. You also give him a contract which he signs with a jagged 'x'. A few of the brothers then spend the rest of the day teaching him the ropes and introducing him to the rest of the company. By night's end, it seems like he's already beginning to fit in. By next morning, you wake to see a great number of supplies are missing and the new man is nowhere in sight. It appears that, although you stayed the thief's execution, he went on ahead and stole things anyway. Let that be a lesson to you.\""
  },
  {
    "key": "faba72ff43c31f52c60e776c82a68807689f74ab565545c93f64d2d7b4fa4e34",
    "original": "[img]gfx/ui/events/event_33.png[/img] You tell the men to get back to marching. The thief wipes his mouth and stands up, wobbling as his weak legs take a few steps after you. He asks if maybe he could join the company. He'll give his life for you, if he must, just anything to not have to steal anymore.",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_33.png[/img] You tell the men to get back to marching. The thief wipes his mouth and stands up, wobbling as his weak legs take a few steps after you. He asks if maybe he could join the company. He'll give his life for you, if he must, just anything to not have to steal anymore.\""
  },
  {
    "key": "7c0cef5fc5f2255097b29d665ce82f1ba50f90f4608db37a1aa218d3f92f2840",
    "original": "[img]gfx/ui/events/event_33.png[/img]%SPEECH_ON%The punishment for thievery is death.%SPEECH_OFF%You plunge the sword down, cutting off the thief's last words with a quick stab into his chest. He seizes up, speechless save for the scratching of his thin hands grabbing that which is killing him, and then he falls back, dead within moment. You retrieve your weapon and clean it off in the nook of your elbow. The dead man's head turns to a side as blood pools quietly beneath him.",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_33.png[/img]%SPEECH_ON%The punishment for thievery is death.%SPEECH_OFF%You plunge the sword down, cutting off the thief's last words with a quick stab into his chest. He seizes up, speechless save for the scratching of his thin hands grabbing that which is killing him, and then he falls back, dead within moment. You retrieve your weapon and clean it off in the nook of your elbow. The dead man's head turns to a side as blood pools quietly beneath him.\""
  },
  {
    "key": "05af48195b1637828f3dfb32e3bf29a86aae01e5bffb955dd894feb3ecbfded6",
    "original": "[img]gfx/ui/events/event_33.png[/img]%randombrother% gives the thief a proper beating with a short cane. The shaft lands viciously hard and you can hear the sound of the blows passing through the man's almost hollow frame. He wilts and turns and tries hard to get away, but the sellsword is persistent in meting out the punishment. When it's all said and done, you leave the beaten man behind, wimpering and clutching the dirt between his frail fingers.",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_33.png[/img]%randombrother% gives the thief a proper beating with a short cane. The shaft lands viciously hard and you can hear the sound of the blows passing through the man's almost hollow frame. He wilts and turns and tries hard to get away, but the sellsword is persistent in meting out the punishment. When it's all said and done, you leave the beaten man behind, wimpering and clutching the dirt between his frail fingers.\""
  },
  {
    "key": "dd0782d12910041625b13f363c90d6a12156b895621fba732eae3cae4a7f103b",
    "original": "[img]gfx/ui/events/event_33.png[/img]As the thief cowers, you draw your sword. He begs for mercy as his mirrored face ripples over the blade's fuller and edges. You raise the weapon. The man screams out that he'll work for you, that he'll work for free, anything to spare his life. You hesitate, your sword still lingering in the air.",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_33.png[/img]As the thief cowers, you draw your sword. He begs for mercy as his mirrored face ripples over the blade's fuller and edges. You raise the weapon. The man screams out that he'll work for you, that he'll work for free, anything to spare his life. You hesitate, your sword still lingering in the air.\""
  },
  {
    "key": "99ed73f3c8531cc653d873c7d9948a897065286da86fbd80aac9557160636ead",
    "original": "[img]gfx/ui/events/event_33.png[/img]During a short rest, your men managed to catch a man that tried to make off with some of your supplies. His clothes are but rags and he looks more skeleton than man. What are you going to do with him?",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_33.png[/img]During a short rest, your men managed to catch a man that tried to make off with some of your supplies. His clothes are but rags and he looks more skeleton than man. What are you going to do with him?\""
  },
  {
    "key": "c023002eaecea82ed73291e1b726636826b7d0cb9093a9b0b23db512841217a0",
    "original": "[img]gfx/ui/events/event_33.png[/img]Feeling bad for the feeble man, you decide to give him some water and food. He almost snatches the meal away from you and drives his famished face into it. The thief thanks you between every bite.",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_33.png[/img]Feeling bad for the feeble man, you decide to give him some water and food. He almost snatches the meal away from you and drives his famished face into it. The thief thanks you between every bite.\""
  },
  {
    "key": "7cb1cef070b73082996ef31e7e2d3c78db22b449cd33f2d66c106af0e7e3bdb4",
    "original": "[img]gfx/ui/events/event_33.png[/img]Under the cloak of night some thief managed to nick some of your supplies. He will probably offer them back to you in the next settlement...",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_33.png[/img]Under the cloak of night some thief managed to nick some of your supplies. He will probably offer them back to you in the next settlement...\""
  }
]