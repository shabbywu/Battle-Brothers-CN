    "context": "onDetermineStartScreen = function onDetermineStartScreen(){\n    if (!this.isSomethingToSee() && this.Math.rand(1, 100) <= 75) {\n        return \"A\";\n    } else {\n        return \"B\";\n    };\n    return;\n}"
  },
