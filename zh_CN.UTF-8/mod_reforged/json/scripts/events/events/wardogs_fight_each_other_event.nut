    "context": "getResult = function getResult(_event){\n    local r = this.Math.rand(1, 100);\n    if (r <= 10) {\n        return \"E\";\n    } else {\n        if (r <= 50) {\n            return \"F\";\n        } else {\n            if (r <= 90) {\n                return \"G\";\n            } else {\n                return \"H\";\n            }\n        }\n    };\n    return;\n}"
  },
