  {
    "key": "da2508780c58d3f83006327eba890c6814dad3278c4ae2fa6e5e5f5f4b9c1c5f",
    "original": "Sure, %wildman%, I'll take some of those.",
    "translation": "",
    "context": "Text = \"Sure, %wildman%, I'll take some of those.\""
