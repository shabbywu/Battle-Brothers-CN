  {
    "key": "942e033426d8ef304e34de3e6b3269a962905b8d91628bca21560f687912ca3d",
    "original": "%oldguard% shows little mercy and has the men running again and again in the days to come. After all, he says, it's for their own damn good.",
    "translation": "",
    "context": "Text = \"%oldguard% shows little mercy and has the men running again and again in the days to come. After all, he says, it's for their own damn good.\""
  },
