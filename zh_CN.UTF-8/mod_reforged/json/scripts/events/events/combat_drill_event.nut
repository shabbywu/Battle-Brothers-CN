  },
  {
    "key": "5e5721750d41879840fb727b75c887420e9f5d09e4952af8f83ad39baefcb782",
    "original": "Let's see if you lot can hit anything.",
    "translation": "",
    "context": "Text = \"Let's see if you lot can hit anything.\""
  },
  {
    "key": "638905ec40670fe1fc355a297a2eefb66a6a9a28f295df491b93a8b831521a1f",
    "original": "No, they need to keep what little strength they have for battle.",
    "translation": "",
    "context": "Text = \"No, they need to keep what little strength they have for battle.\""
  },
  {
    "key": "94a2547493db99e580752e206dddbbdfda1c580b095c585342ccecdb2b381214",
    "original": "Show me what you can do!",
    "translation": "",
    "context": "Text = \"Show me what you can do!\""
  },
  {
    "key": "968f67ea351b23d7704fb3d40a1cb9b1722753efe0cdc4d5d0c8fa790766857b",
    "original": "Very well, get them in shape to carry real armor.",
    "translation": "",
    "context": "Text = \"Very well, get them in shape to carry real armor.\""
  },
  {
    "key": "f07de7abf6d1a89f3ca5a01a5820a94e61f8df5a7a2dd7d7ec9e519a6d0132bf",
    "original": "Very well, see if you can teach them to fight man against man.",
    "translation": "",
    "context": "Text = \"Very well, see if you can teach them to fight man against man.\""
  },
  {
    "key": "b0063efef6a76a29451c79ca31dce5105e2795051a14cde213028d320e66b626",
    "original": "Very well, see that they can put bow and arrow to use.",
    "translation": "",
    "context": "Text = \"Very well, see that they can put bow and arrow to use.\""
  },
  {
    "key": "95db6cd3e84119fd82ea59b45c5bb8445bb342950f8c899e5293b9bb85ac762b",
    "original": "We'll do that again, tomorrow!",
    "translation": "",
    "context": "Text = \"We'll do that again, tomorrow!\""
  },
  {
    "key": "a4e70b52b37c66b16046a9e7424f378acde06601a5ecc762b4b7e60a83fd6128",
