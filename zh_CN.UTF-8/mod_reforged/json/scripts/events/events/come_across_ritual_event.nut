[
  {
    "key": "25dab86f9978e1c853e40569d426572b7e2588b3eb352793e59f7d38d80f622c",
    "original": "%cultist%, is this not your cult?",
    "translation": "",
    "context": "Text = \"%cultist%, is this not your cult?\""
