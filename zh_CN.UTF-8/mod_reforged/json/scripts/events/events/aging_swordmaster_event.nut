[
  {
    "key": "4d6b35ab179b69dedcfdab71c5f1b05ddcecc64e7186f6259fe329179ec7f415",
    "original": " has gotten older",
    "translation": "",
    "context": "_event.m.Swordmaster.getName() + \" has gotten older\""
  },
  {
    "key": "559aead08264d5795d3909718cdd05abd49572e84fe55590eef31a88a08fdffd",
