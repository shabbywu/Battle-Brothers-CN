    "key": "d6706d23ff3550dcabf958aef670d263982622e833ca1acd0dc84c9e18b11df2",
    "original": "Vagabond",
    "translation": "",
    "context": "start = function start(_event){\n    if (_event.m.Tailor != null) {\n        function getResult(_event){\n            return \"Tailor\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"Maybe we can fashion some fresh wrappings from what we've got?\"\n            getResult = function getResult(_event){\n                return \"Tailor\";;\n                return;\n            }\n        })\n    };\n    if (_event.m.Vagabond != null) {\n        function getResult(_event){\n            return \"Vagabond\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"You've traveled the world, %travelbro%. Suggestions?\"\n            getResult = function getResult(_event){\n                return \"Vagabond\";;\n                return;\n            }\n        })\n    };\n    if (_event.m.Thief != null) {\n        function getResult(_event){\n            return \"Thief\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"Wait. %streetrat%, you look like you have something to say?\"\n            getResult = function getResult(_event){\n                return \"Thief\";;\n                return;\n            }\n        })\n    };\n    return;\n}"
  },
