[
  {
    "key": "b8b5f2947d16f972379644bb3bac083a3bbb79b657a69a92b735aa3c998b02a8",
    "original": " has died",
    "translation": "",
    "context": "_event.m.Addict.getName() + \" has died\""
  },
  {
    "key": "559aead08264d5795d3909718cdd05abd49572e84fe55590eef31a88a08fdffd",
    "original": "A",
