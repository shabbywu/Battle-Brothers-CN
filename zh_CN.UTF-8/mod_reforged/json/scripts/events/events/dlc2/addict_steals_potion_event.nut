  {
    "key": "bf141049f1f7c9983d207a4e9296f4c22f21026ffee102d0ca9d401c9c26c558",
    "original": "Appalled by your order to have ",
    "translation": "",
    "context": "\"Appalled by your order to have \" + _event.m.Addict.getName() + \" flogged\""
  },
  {
    "key": "5ba916722880e9f2fe0278249d34c9b18081ea49eba04dec5c22f696886360ec",
    "original": "During camp...",
    "translation": "",
    "context": "this.m.Title = \"During camp...\""
  },
  {
    "key": "b9c0118ed904d8d22b28ae047debc079468d05916df3ae1169396715f677f9fd",
    "original": "Enough. I'll have this bloody demon whipped out of you!",
    "translation": "",
    "context": "Text = \"Enough. I'll have this bloody demon whipped out of you!\""
  },
  {
    "key": "fa67cec9c67af5c3f2b4753d49658dbec914614f0a03d6ffc49a7f4af33bcdff",
    "original": "Get him out of my sight.",
    "translation": "",
    "context": "Text = \"Get him out of my sight.\""
  },
  {
    "key": "2b42eb2d1982ee5b3aa7aae6234890879a0ea65904d00a99fe8d29ef2e5ec018",
    "original": "Goddammit.",
    "translation": "",
    "context": "Text = \"Goddammit.\""
  },
  {
    "key": "d4f31166efde05e70276aadaeaf40393717ab27e1f764b9c6912088dcab200f8",
    "original": "I just hope you'll heal in time.",
    "translation": "",
    "context": "Text = \"I just hope you'll heal in time.\""
  },
  {
    "key": "d67caa08ea5b4d8da5647cd018cd1d476768845e1ca8545c18a98059ca58a855",
    "original": "Nice talking.",
    "translation": "",
    "context": "Text = \"Nice talking.\""
  },
  {
    "key": "0f7984c0efeb1f722d5bd814cf5c05ddd3a37239edc4448b7204ace79720c342",
    "original": "This needs to stop now, %addict%.",
    "translation": "",
    "context": "Text = \"This needs to stop now, %addict%.\""
  },
