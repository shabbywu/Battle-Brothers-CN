    "key": "fc335536e5a69a5252a673c94a39e9f081c082a846033e00067cc11ff9a67053",
    "original": "]+200[/color] Experience",
    "translation": "",
    "context": "_event.m.Expendable.getName() + \" gains [color=\" + this.Const.UI.Color.PositiveEventValue + \"]+200[/color] Experience\""
  }
