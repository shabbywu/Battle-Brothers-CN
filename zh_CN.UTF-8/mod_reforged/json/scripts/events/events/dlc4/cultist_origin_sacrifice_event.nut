    "context": "bro.getName() + \" is now \" + this.Const.Strings.getArticle(skill.getName()) + skill.getName()"
  },
  {
    "key": "5658fb6e53993421659729c9db28bb269814d33b10f3a66b4380534099101242",
    "original": "%sac1% will have the honor to meet Davkul.",
