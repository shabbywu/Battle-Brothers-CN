    "context": "start = function start(_event){\n    if (_event.m.Fat != null) {\n        function getResult(_event){\n            return \"D\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"Looks like %fat% is volunteering.\"\n            getResult = function getResult(_event){\n                return \"D\";;\n                return;\n            }\n        })\n    };\n    if (_event.m.Blind != null) {\n        function getResult(_event){\n            return \"E\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"Looks like %shortsighted% is volunteering.\"\n            getResult = function getResult(_event){\n                return \"E\";;\n                return;\n            }\n        })\n    };\n    function getResult(_event){\n        return 0;;\n        return;\n    };\n    this.Options.push({\n        Text = \"We have more important things to take care of.\"\n        getResult = function getResult(_event){\n            return 0;;\n            return;\n        }\n    });\n    return;\n}"
  },
