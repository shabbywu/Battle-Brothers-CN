    "key": "3f39d5c348e5b79d06e842c114e6cc571583bbf44e4b0ebfda1a01ec05745d43",
    "original": "D",
    "translation": "",
    "context": "start = function start(_event){\n    if (_event.m.Monk != null) {\n        function getResult(_event){\n            return \"D\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"Have %monk% the monk take a look instead.\"\n            getResult = function getResult(_event){\n                return \"D\";;\n                return;\n            }\n        })\n    };\n    if (_event.m.Sorcerer != null) {\n        function getResult(_event){\n            return \"E\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"Have %sorcerer% the sorcerer take a look instead.\"\n            getResult = function getResult(_event){\n                return \"E\";;\n                return;\n            }\n        })\n    };\n    this.Characters.push(_event.m.Cursed.getImagePath());\n    return;\n}"
  },
  {
    "key": "3f39d5c348e5b79d06e842c114e6cc571583bbf44e4b0ebfda1a01ec05745d43",
