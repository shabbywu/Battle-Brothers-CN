  },
  {
    "key": "55a220d497be0c72790b3b9d26683ead02765fc75765e047efb023e173cf8d5d",
    "original": "Exciting!",
    "translation": "",
    "context": "Text = \"Exciting!\""
  },
  {
    "key": "d33522a8ab796f289cdf3cfaec75dcf39e76cb97adfea78ba44b25a30f1dbabc",
    "original": "Get back to work!",
    "translation": "",
    "context": "Text = \"Get back to work!\""
  },
  {
    "key": "cba3204214bcc26c4252b1ddab87e8ac46886da78066ece79cb72607c9bbc5d2",
    "original": "Huzzah!",
    "translation": "",
    "context": "Text = \"Huzzah!\""
  },
  {
    "key": "2d4bb49a17e544245702c34dfc8d82cb2b96551e8869a9e8e94c3ce4d2c02369",
    "original": "I don't gamble.",
    "translation": "",
    "context": "Text = \"I don't gamble.\""
  },
  {
    "key": "e5dbd47c79938a9ff9fbf80fe5a258d4b25672c2ab76085ae307005551e46099",
    "original": "No, we have more important matters to attend to.",
    "translation": "",
    "context": "Text = \"No, we have more important matters to attend to.\""
  },
  {
    "key": "36cb47059fd1ea5eb6b729604830b98baabf19f7770ae79703d2da023d8b3018",
