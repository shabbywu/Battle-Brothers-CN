  {
    "key": "ae31efc9bb7ce0a89c17317e6d702b0584f6bd73fe7518a2ae9d3464a76b1d5b",
    "original": "Along the way...",
    "translation": "",
    "context": "this.m.Title = \"Along the way...\""
  },
  {
    "key": "b0f0198d0f2c10e65cad72490920c28a1def6ab45b92a4381cd8a652d3de50ad",
    "original": "Better wise up, wiseacre.",
    "translation": "",
    "context": "Text = \"Better wise up, wiseacre.\""
  },
  {
    "key": "a410d4fd457cea0e650bd4fe52b0500992ecfc599ccd1a378aadb60bd7839503",
    "original": "Damn scamps.",
    "translation": "",
    "context": "Text = \"Damn scamps.\""
  },
  {
    "key": "733fd348c4f62900d049275919b1fa4211a62a78dddccb0f22e1310d49069f98",
    "original": "Does %minstrel% the minstrel know something?",
    "translation": "",
    "context": "Text = \"Does %minstrel% the minstrel know something?\""
  },
  {
    "key": "f44991f3bed02299350c6b5f25c2825949d1f3d26fe9b09bcf7a012fcd7ffc75",
    "original": "Get it together, %anatomist%.",
    "translation": "",
    "context": "Text = \"Get it together, %anatomist%.\""
  },
  {
    "key": "603d79881bb94026451fe389503cebd4c7a890ccc246064db1596fc5b5ba54e1",
    "original": "I'm going with you.",
    "translation": "",
    "context": "Text = \"I'm going with you.\""
  },
  {
    "key": "26449f3fa2238f9a8c82141e114a0a881c16abaf16ebc16cbf50ab8af5a2793a",
    "original": "It is what it allegedly is.",
    "translation": "",
    "context": "Text = \"It is what it allegedly is.\""
  },
  {
    "key": "72a030941e76ca70a7c0f2ee4600f49dab5871cc5dbd2e76d0efefa1712fc279",
    "original": "Learned how to better deal with the laity",
    "translation": "",
    "context": ""
  },
  {
    "key": "97b45e39fa5708efc53a123e4268f4ebdad0c3139d58a0ab09fd6d03672cc960",
    "original": "Let's get out of here.",
    "translation": "",
    "context": "Text = \"Let's get out of here.\""
  },
  {
    "key": "709ffff784fbc922a350d81da9d24f2ccc2b15281a43528fb10e8fac81047a00",
    "original": "Sure, he can come along.",
    "translation": "",
    "context": "Text = \"Sure, he can come along.\""
  },
  {
    "key": "da571627fe87ff8abb2d532c465dee188e709536572c8e826ff5dc925d5139d0",
    "original": "This is far too suspicious.",
    "translation": "",
    "context": "Text = \"This is far too suspicious.\""
  },
  {
    "key": "7f839ce0a69686ef803c1a9dca85ac784c94da8d55724179ad49a23a0c925683",
    "original": "Wait, where is our resident murderer %killer%?",
    "translation": "",
    "context": "Text = \"Wait, where is our resident murderer %killer%?\""
  },
  {
    "key": "942657daa26712768c52f6b315aaa20765457941fffe6d93772b262e196f541a",
    "original": "Was denied a research opportunity",
    "translation": "",
    "context": ""
  },
  {
    "key": "8c2db57635aa839999cf31bf283d784313d4f0e90a6fb4181bc13c397741164b",
    "original": "We have no need of yet another charlatan.",
    "translation": "",
    "context": "Text = \"We have no need of yet another charlatan.\""
  },
  {
    "key": "f24747f37fcbe27aaeaf43606485b073d09cd5fb5af0f61a198fe60d53b18b02",
    "original": "Witnessed a brutal murder",
    "translation": "",
    "context": ""
  },
