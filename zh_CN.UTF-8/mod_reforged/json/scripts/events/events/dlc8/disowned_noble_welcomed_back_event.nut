    "translation": "",
    "context": "_event.m.Disowned.getName() + \" leaves the \" + this.World.Assets.getName()"
  },
  {
    "key": "1f1b8deaf876a9e0b37464f3a4181fc449364378095fb6adb35a1c8ab00ccc67",
    "original": "At %townname%",
    "translation": "",
    "context": "this.m.Title = \"At %townname%\""
  },
  {
    "key": "ef7ff064b16125be6f91a78d953e29cc5f0bdeded3629e21a72b04729d862cdf",
    "original": "I think you should stay with us.",
    "translation": "",
    "context": "Text = \"I think you should stay with us.\""
  },
  {
    "key": "4b5401f4a6f87cdc33206e7fcde073ccc0b7e1d0d098bb0ccfda58f25e6c1500",
    "original": "I'll burn the letter.",
    "translation": "",
    "context": "Text = \"I'll burn the letter.\""
  },
  {
    "key": "9d8048e825df48712fee15658f2f06033962359df8209b90c05d13cdac290eb2",
    "original": "I'll show him the letter.",
    "translation": "",
    "context": "Text = \"I'll show him the letter.\""
  },
  {
    "key": "d872e8e4176213ea84ebc76d8fb621c31b4ca116fd0a51258813e804fe110ca4",
    "original": "Nothing to see here.",
    "translation": "",
    "context": "Text = \"Nothing to see here.\""
  },
  {
    "key": "404cba15a4acdcfea85caa97d009b1042d20f0967c26f9a1abf59aecbeddf9bd",
    "original": "Of course.",
    "translation": "",
    "context": "Text = \"Of course.\""
  },
  {
    "key": "eb293d577c62e7806daa830ded3d3fedab134b43d97016a3570f11b1d9e35a94",
    "original": "The company gained renown",
    "translation": "",
    "context": "text = \"The company gained renown\""
  },
  {
    "key": "85d13cf4d5f8d972cb9d6de67c9cc3128758d8462dd3293693b2bcc94257ec0e",
    "original": "You gain ",
    "translation": "",
    "context": "\"You gain \" + this.Const.Strings.getArticle(item.getName()) + item.getName()"
  },
  {
    "key": "1ef88b6e29a3e6cc08a944d9818ea54727928cc3b631d4e62b580b02a599d88e",
    "original": "You should go home to your family.",
    "translation": "",
    "context": "Text = \"You should go home to your family.\""
  },
  {
    "key": "de42c9af5b265e953d1eb19a6a0480e069239a659f034c41f496653e926ff44c",
    "original": "You're alright, %disowned%.",
    "translation": "",
    "context": "Text = \"You're alright, %disowned%.\""
  },
  {
    "key": "32e5a4727d02c6c49fbe468fad52f5618f59f7ac88a2401cb71bdb9de4c40fad",
