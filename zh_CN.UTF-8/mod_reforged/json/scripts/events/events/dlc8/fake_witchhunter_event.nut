[
  {
    "key": "b7bc905957708d55178221afa8341e37cfc0312b758eb88e1a3ea8b3e2fee3c6",
    "original": " suffers light wounds",
    "translation": "",
    "context": "bro.getName() + \" suffers light wounds\""
  },
  {
    "key": "72b154575b6ccc293504a8aeaaad93a0e9a903221776ebd66f4ea4421703c087",
    "original": "%witchhunter%, do you know this man?",
    "translation": "",
    "context": "Text = \"%witchhunter%, do you know this man?\""
  },
  {
    "key": "559aead08264d5795d3909718cdd05abd49572e84fe55590eef31a88a08fdffd",
    "original": "A",
