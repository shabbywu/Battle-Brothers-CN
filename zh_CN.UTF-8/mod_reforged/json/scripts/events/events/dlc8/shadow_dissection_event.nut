ion getResult(_event){\n            return \"G\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"Naturally, %minstrel% the minstrel is ready to talk.\"\n            getResult = function getResult(_event){\n                return \"G\";;\n                return;\n            }\n        })\n    };\n    if (_event.m.Killer != null && this.Options.len() < 6) {\n        function getResult(_event){\n            return \"H\";;\n            return;\n        };\n        this.Options.push({\n            Text = \"What's that noise?\"\n            getResult = function getResult(_event){\n                return \"H\";;\n                return;\n            }\n        })\n    };\n    return;\n}"
