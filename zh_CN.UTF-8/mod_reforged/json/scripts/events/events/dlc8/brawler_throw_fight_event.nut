    "context": "this.m.Title = \"At %townname%\""
  },
  {
    "key": "2842d66ade8c2b5e27430b090b1e484b9d3b5c8def379da22ca457f3caa279d9",
    "original": "Damn.",
    "translation": "",
    "context": "Text = \"Damn.\""
  },
  {
    "key": "eeee187cbc0fbba0438af67050ac42ccbefce68dfaf726e1e26d957bb34d77fa",
    "original": "Got badly beaten in a fighting tournament",
    "translation": "",
    "context": ""
  },
  {
    "key": "3bfb25955f8029b3c59abcd969121a91d6dd317207de4759e1a4b1d8c81b8287",
    "original": "Handily won a fighting tournament",
    "translation": "",
    "context": ""
  },
  {
    "key": "53ca75075d927855e6e5de77ae3e3869c589d93f72836e0f61f0e740537deea8",
    "original": "He'll get over it.",
    "translation": "",
    "context": "Text = \"He'll get over it.\""
  },
  {
    "key": "ff8154aa5a8b105f43d8bdac5296067a03b133551f8db083a8ae183e5e478df0",
    "original": "He's not taking a fall.",
    "translation": "",
    "context": "Text = \"He's not taking a fall.\""
  },
  {
    "key": "2db1c9e0f7261a9f05da7102387a0bdb72a7881923a2818aea9b0bc87cb909f8",
    "original": "I've had quite enough betting for now, myself.",
    "translation": "",
    "context": "Text = \"I've had quite enough betting for now, myself.\""
  },
  {
    "key": "8f58fa93c71d3710c11385b9783478efd3dd6e606b15f09b3662a5434b3ab47a",
    "original": "Lost a fighting tournament",
    "translation": "",
    "context": ""
  },
  {
    "key": "81bf5c82d9c4ccebab973d5a59f67c475f59d8a01f5170c78e2affeaa7dfdb2a",
    "original": "That could have gone better.",
    "translation": "",
    "context": "Text = \"That could have gone better.\""
  },
  {
    "key": "163302cd37140a5fee23561c41206bcb75fa27f9020047df4164fb43a3597482",
    "original": "There'll be plenty of other opportunities to fight, %brawler%.",
    "translation": "",
    "context": "Text = \"There'll be plenty of other opportunities to fight, %brawler%.\""
  },
  {
    "key": "d3b2f6c275a4ad3380b984be1bb9fc8c57c4e82aed5e17493aa291e724739839",
    "original": "Was allowed to fight on his own terms",
    "translation": "",
    "context": ""
  },
  {
    "key": "6b5027620e999c98b2cc8b8bd4642c7b9b3b6618ccec30a0c90f36f239d2c23e",
    "original": "Was denied participation in a fighting tournament",
    "translation": "",
    "context": ""
  },
  {
    "key": "98ac84443f4e629f38cd2dc819fc3711aafbc688404092fd2c8beff17085f2ea",
    "original": "Was told to throw a fight",
    "translation": "",
    "context": ""
  },
  {
    "key": "462164a0645e1ed27e1b1970082fe070d84b343179217a59cfc2d788999c225e",
    "original": "Well done!",
    "translation": "",
    "context": "Text = \"Well done!\""
  },
  {
    "key": "e08e9b3efbb7c793521ec0668ef44eb913fe2260a8e4c32a9bf657c0ec3942be",
    "original": "What? There won't be a fight at all!",
    "translation": "",
    "context": "Text = \"What? There won't be a fight at all!\""
  },
  {
    "key": "75c45e6b8866c7aacf8d3a14cae5d644d278d2f53ab2cc835118e64cc9d12404",
    "original": "You gain [color=",
    "translation": "",
    "context": "\"You gain [color=\" + this.Const.UI.Color.PositiveEventValue + \"]400[/color] Crowns\""
  },
  {
    "key": "2a45d84c0699109c7afd611e454a966fff1ef180330a53ef4fbb6ac1f0bccc60",
    "original": "You need to take a fall.",
    "translation": "",
    "context": "Text = \"You need to take a fall.\""
  },
  {
    "key": "32e5a4727d02c6c49fbe468fad52f5618f59f7ac88a2401cb71bdb9de4c40fad",
    "original": "[/color] Initiative",
    "translation": "",
    "context": "_event.m.Brawler.getName() + \" gains [color=\" + this.Const.UI.Color.PositiveEventValue + \"]+\" + initiative_boost + \"[/color] Initiative\""
  },
