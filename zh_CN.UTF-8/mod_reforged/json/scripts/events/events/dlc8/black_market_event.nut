    "context": "Text = \"I'll pay the 200 crowns for that...some kind of gland?\""
  },
  {
    "key": "21caa946188ea5e756619d1cc4439e23e1eb6cb3c6cd36475c906a906a4f2fce",
    "original": "I'll take the big heart for...550 crowns, is it?",
    "translation": "",
    "context": "Text = \"I'll take the big heart for...550 crowns, is it?\""
  },
  {
    "key": "d9aa1a6b6b8b66f81f456ead92741c8d1af890bb5516370b73495eb91aadb97a",
    "original": "Let's get that brain-looking thing for 100 crowns.",
    "translation": "",
    "context": "Text = \"Let's get that brain-looking thing for 100 crowns.\""
  },
  {
    "key": "17d6cc0353f8382eb7cec695c7ea45afd493af209a458abb71c1f8a6d507e440",
    "original": "Look at 'em fight over it.",
    "translation": "",
    "context": "Text = \"Look at 'em fight over it.\""
  },
  {
    "key": "9cb3fb063e081fbf0200f74867f3c2980b79a205aaec15e8b94cdc41a012b9a7",
    "original": "Remember, bend with your knees.",
    "translation": "",
    "context": "Text = \"Remember, bend with your knees.\""
  },
  {
    "key": "74468033842dd619036a89b9fe621c7f86c34f4313a63861631f57a9a564a82a",
    "original": "We can't afford such indulgences.",
