  {
    "key": "5ba916722880e9f2fe0278249d34c9b18081ea49eba04dec5c22f696886360ec",
    "original": "During camp...",
    "translation": "",
    "context": "this.m.Title = \"During camp...\""
  },
  {
    "key": "5291cb3c89739ed8da1a61bebf090f3101e9e2880ae24188b57dc1da3d957433",
    "original": "Everybody makes mistakes.",
    "translation": "",
    "context": "Text = \"Everybody makes mistakes.\""
  },
  {
    "key": "fa67cec9c67af5c3f2b4753d49658dbec914614f0a03d6ffc49a7f4af33bcdff",
    "original": "Get him out of my sight.",
    "translation": "",
    "context": "Text = \"Get him out of my sight.\""
  },
  {
    "key": "498e0f4ff9ef742fe310d57e243c84dc4e50a33e9888559192c35dcac197dea8",
    "original": "If he won't put down the drink I'll force him to. Get the whip.",
    "translation": "",
    "context": "Text = \"If he won't put down the drink I'll force him to. Get the whip.\""
  },
  {
    "key": "7d96ac237de937a373efed0d98a910c34539307353376cc344bdecb50a638999",
    "original": "Latrine duty for a month!",
    "translation": "",
    "context": "Text = \"Latrine duty for a month!\""
  },
  {
