  },
  {
    "key": "6099934a61468b73cf3ea530c9c77f1557450f82cbdeca4779c7467b84946e84",
    "original": "[img]gfx/ui/events/event_26.png[/img] %SPEECH_ON%May the old gods have mercy for if my damned mother-in-law walks the earth she'll certainly have none for me.%SPEECH_OFF%",
