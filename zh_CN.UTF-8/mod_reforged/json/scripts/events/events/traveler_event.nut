                        } else {\n                                                            if (n == 15) {\n                                                                return \"P1\";\n                                                            } else {\n                                                                if (n == 16) {\n                                                                    return \"Q1\";\n                                                                } else {\n                                                                    if (n == 17) {\n                                                                        return \"R1\";\n                                                                    } else {\n                                                                        if (n == 18) {\n                                                                            return \"S1\";\n                                                                        }\n                                                                    }\n                                                                }\n                                                            }\n                                                        }\n                                                    }\n                                                }\n                                            }\n                                        }\n                                    }\n                                }\n                            }\n                        }\n                    }\n                }\n            }\n        }\n    };\n    return;\n}"
