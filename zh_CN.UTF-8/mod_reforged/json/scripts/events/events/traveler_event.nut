    "context": "getResult = function getResult(_event){\n    this.World.Assets.removeRandomFood(3);\n    local n = this.Math.rand(1, 18);\n    if (n == 1) {\n        return \"B1\";\n    } else {\n        if (n == 2) {\n            return \"C1\";\n        } else {\n            if (n == 3) {\n                return \"D1\";\n            } else {\n                if (n == 4) {\n                    return \"E1\";\n                } else {\n                    if (n == 5) {\n                        return \"F1\";\n                    } else {\n                        if (n == 6) {\n                            return \"G1\";\n                        } else {\n                            if (n == 7) {\n                                return \"H1\";\n                            } else {\n                                if (n == 8) {\n                                    return \"I1\";\n                                } else {\n                                    if (n == 9) {\n                                        return \"J1\";\n                                    } else {\n                                        if (n == 10) {\n                                            return \"K1\";\n                                        } else {\n                                            if (n == 11) {\n                                                return \"L1\";\n                                            } else {\n                                                if (n == 12) {\n                                                    return \"M1\";\n                                                } else {\n                                                    if (n == 13) {\n                                                        return \"N1\";\n                                                    } else {\n                                                        if (n == 14) {\n                                                            return \"O1\";\n                                                        } else {\n                                                            if (n == 15) {\n                                                                return \"P1\";\n                                                            } else {\n                                                                if (n == 16) {\n                                                                    return \"Q1\";\n                                                                } else {\n                                                                    if (n == 17) {\n                                                                        return \"R1\";\n                                                                    } else {\n                                                                        if (n == 18) {\n                                                                            return \"S1\";\n                                                                        }\n                                                                    }\n                                                                }\n                                                            }\n                                                        }\n                                                    }\n                                                }\n                                            }\n                                        }\n                                    }\n                                }\n                            }\n                        }\n                    }\n                }\n            }\n        }\n    };\n    return;\n}"
