  {
    "key": "7db40749d1ebcbc790af2eb088aeda7f903521c7230f34fec7ef7e976941ad79",
    "original": "They'll get over it.",
    "translation": "",
    "context": "Text = \"They'll get over it.\""
  },
  {
    "key": "ca1aebeccaccf7c5cbdcb18ffce70698c9d5c421661bb2beeb17f9aa22cc3649",
    "original": "[img]gfx/ui/events/event_64.png[/img]%dismissed%'s injuries proved too much: the man didn't die, but in your mind he might as well have for he was no longer fit for combat. You let him go. While this may have been an altruistic move that spared the sellsword's life, the rest of the company doesn't see it the same way. All they see is that one injury is all it took for you to cut a man loose. Now they worry that if they get wounded you might do the same to them, like a selfish man ridding himself of a lame horse.",
    "translation": "",
    "context": "Text = \"[img]gfx/ui/events/event_64.png[/img]%dismissed%'s injuries proved too much: the man didn't die, but in your mind he might as well have for he was no longer fit for combat. You let him go. While this may have been an altruistic move that spared the sellsword's life, the rest of the company doesn't see it the same way. All they see is that one injury is all it took for you to cut a man loose. Now they worry that if they get wounded you might do the same to them, like a selfish man ridding himself of a lame horse.\""
  },
