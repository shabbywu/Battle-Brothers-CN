    "original": "Spirits lifted by ",
    "translation": "",
    "context": "\"Spirits lifted by \" + _event.m.Cripple.getName()"
  },
  {
    "key": "5c7221371af29e2960ae81273b052eb7406c0af652db1bfb92bc6d867041095c",
    "original": "Suffered a permanent injury",
