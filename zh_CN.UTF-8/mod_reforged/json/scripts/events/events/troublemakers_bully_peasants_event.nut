  {
    "key": "cab051c36a38d9eeef9e99fcba8ea798d4d21d5baf2750896991604e8f35a8dd",
    "original": "Enjoyed raiding and pillaging",
    "translation": "",
    "context": ""
  },
  {
    "key": "f67ab10ad4e4c53121b6a5fe4da9c10ddee905b978d3788d2723d7bfacbe28a9",
    "original": "F",
    "translation": "",
    "context": "getResult = function getResult(_event){\n    return this.Math.rand(1, 100) <= 70 ? \"E\" : \"F\";;\n    return;\n}"
