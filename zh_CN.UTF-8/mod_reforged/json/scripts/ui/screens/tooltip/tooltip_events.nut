    "context": "text = \"Will heal by tomorrow\""
  },
  {
    "key": "a895cdf58ec9441880f9a465e48315e97746d8e1b0249a9848c1d1439e82d7c8",
    "original": "Will heal in [color=",
    "translation": "",
    "context": "\"Will heal in [color=\" + this.Const.UI.Color.NegativeValue + \"]\" + entity.getDaysWounded() + \"[/color] days\""
  },
  {
    "key": "f75a5059b64431d448d122465260864091ea554cf3d9f7f78a71ed0fc5d2426e",
    "original": "You already have a contract!",
    "translation": "",
    "context": "text = \"You already have a contract!\""
  },
  {
    "key": "cb6d146c071e439ff148b2ee749e00bd0594bb3b5c20a6e6e10133ae7a16aec0",
    "original": "You can only have one contract active at a time. Contract offers will remain while you fulfill your current contract, as long as the problem doesn't go away in the meantime.",
    "translation": "",
    "context": "text = \"You can only have one contract active at a time. Contract offers will remain while you fulfill your current contract, as long as the problem doesn't go away in the meantime.\""
  },
  {
    "key": "4e936c24f188baee068e8726a2b73c16e6c35a6b32395a5e1e58bdb5c999e6ba",
    "original": "You cannot fight in the arena while contracted to do other work",
    "translation": "",
    "context": "text = \"You cannot fight in the arena while contracted to do other work\""
  },
  {
    "key": "b48385388cee62712b152aacf567334554025248316b60d4ae2c4fd20d2622d5",
    "original": "You cannot retreat from this particular fight",
    "translation": "",
    "context": "text = \"You cannot retreat from this particular fight\""
  },
  {
    "key": "b1630347bfff3df6e0a8b65b024e50cbe86818a6d7ae2cb8240a23d49f418339",
    "original": "You cannot use the harbor while contracted to escort a caravan",
    "translation": "",
    "context": "text = \"You cannot use the harbor while contracted to escort a caravan\""
  },
  {
    "key": "c370c3e76968fb6a922067353128c9bc11813cc8e65c09de61d834ed2755961b",
    "original": "You have not announced any ambition for your company to pursue. You'll be asked to do so as the game progresses.",
    "translation": "",
    "context": "text = \"You have not announced any ambition for your company to pursue. You'll be asked to do so as the game progresses.\""
  },
  {
    "key": "5378332075f62a050503f3a51eda85f27710813d20a7544c1df675e5506938e3",
    "original": "You need at least 3 empty inventory slots to fight in the arena",
    "translation": "",
    "context": "text = \"You need at least 3 empty inventory slots to fight in the arena\""
  },
  {
    "key": "f487f43b6b6dc3fe1e79bac5da8d4bee187558016c609cbc42b798de866d172a",
    "original": "You need at least 5 empty inventory slots to fight in the ongoing tournament",
    "translation": "",
    "context": "text = \"You need at least 5 empty inventory slots to fight in the ongoing tournament\""
  },
  {
    "key": "b2885d0b6b4fad656e4882ed21a42c9f3ac80b2b208fb9da27c6d3fd5e43e786",
    "original": "You'll face fewer and less challenging opponents, your men gain experience slightly faster, and retreating from battle is easier.\n\nYour men get a small bonus to hit chance, and the enemy gets a small penalty, to ease you into the game.\n\nRecommended for players new to the game.",
    "translation": "",
    "context": "text = \"You'll face fewer and less challenging opponents, your men gain experience slightly faster, and retreating from battle is easier.\\n\\nYour men get a small bonus to hit chance, and the enemy gets a small penalty, to ease you into the game.\\n\\nRecommended for players new to the game.\""
  },
  {
    "key": "36569cc2ccfece5a3c2f7feacd038075ef5ecfd27511486ccdc2e281957046d1",
    "original": "You'll start with fewer crowns and resources.\n\nRecommended for expert players.",
    "translation": "",
    "context": "text = \"You'll start with fewer crowns and resources.\\n\\nRecommended for expert players.\""
  },
  {
    "key": "fee965d1edaee532081fefc8ad3c4ef86bfe7af13d75b5aab12c0b37e07167cd",
    "original": "You'll start with more crowns and resources.\n\nRecommended for new players.",
    "translation": "",
    "context": "text = \"You'll start with more crowns and resources.\\n\\nRecommended for new players.\""
  },
  {
    "key": "659ba8cc1cff064bcf07f02b37f9f283536afffba7f44e37d90a25dbef727d1e",
    "original": "Your Lookout reports",
    "translation": "",
    "context": "text = \"Your Lookout reports\""
  },
  {
    "key": "97be77cd121dcc8e5bf393d928367b9b0aebd79854a77bb8e6252b1891386700",
    "original": "Your company lacks the renown necessary to hire more non-combat followers. Attain at least ",
    "translation": "",
    "context": "\"Your company lacks the renown necessary to hire more non-combat followers. Attain at least \" + renown + \" renown in order to unlock this seat. Gain renown by completing ambitions and contracts, as well as by winning battles.\""
  },
  {
    "key": "fcf73dd8990a2d93b65fc4e3fab5dfaffa30572eadf364dc384b4bf5bdfc14b1",
    "original": "Your opponents will be more challenging and numerous.\n\nRecommended for experts in the game who want an even deadlier challenge.",
    "translation": "",
    "context": "text = \"Your opponents will be more challenging and numerous.\\n\\nRecommended for experts in the game who want an even deadlier challenge.\""
  },
  {
    "key": "9f91fc33ff6411f940f4c6dd52e1e4b48c61ec5f729a08ed330f978f9fe577b4",
    "original": "Your relations with a faction determine whether they'll fight or deal peacefully with you, their willingness to hire you for contracts, as well as the prices they give you and the number of recruits available to you at their settlements.\n\nRelations increase when working successfully for factions, and decrease on failing to do so, betraying or attacking them. Over time, relations slowly trend back towards neutral.",
    "translation": "",
    "context": "text = \"Your relations with a faction determine whether they'll fight or deal peacefully with you, their willingness to hire you for contracts, as well as the prices they give you and the number of recruits available to you at their settlements.\\n\\nRelations increase when working successfully for factions, and decrease on failing to do so, betraying or attacking them. Over time, relations slowly trend back towards neutral.\""
  },
  {
    "key": "4f33bfaa0ee79a524fc10ac894f1d6c272c1a509968c658e45c9f2e25e1029e3",
    "original": "Your renown is your repute as a professional mercenary company and reflects how reliable and competent people judge you to be. The higher your renown, the higher-paid and more difficult contracts people will entrust you with. Renown increases on successfully completing ambitions and contracts, and winning battles, and decreases on failing to do so.",
    "translation": "",
    "context": "text = \"Your renown is your repute as a professional mercenary company and reflects how reliable and competent people judge you to be. The higher your renown, the higher-paid and more difficult contracts people will entrust you with. Renown increases on successfully completing ambitions and contracts, and winning battles, and decreases on failing to do so.\""
  },
  {
    "key": "8d36003fd62c99c6d53d60a3308a022400b37fb3b9bdee2ddec5f21bc45e8b12",
    "original": "Your reputation reflects how people in the world judge your mercenary company to conduct itself based on past actions. Do you show mercy to your enemies? Do you burn down farmsteads and massacre the peasantry? Based on your reputation, people may offer you different kinds of contracts, and both contracts and events may play out differently.",
    "translation": "",
    "context": "text = \"Your reputation reflects how people in the world judge your mercenary company to conduct itself based on past actions. Do you show mercy to your enemies? Do you burn down farmsteads and massacre the peasantry? Based on your reputation, people may offer you different kinds of contracts, and both contracts and events may play out differently.\""
  },
  {
    "key": "90d1d1e14419b406685545b01911e77412785eb04fc068851ba296e038243087",
    "original": "[/color] Medical Supplies.",
    "translation": "",
    "context": "desc + heal.MedicineMax + \"[/color] Medical Supplies.\""
  },
  {
    "key": "f865ee93de048fcd6807709bd1090040ae1d1ffbdd34ffd6122e69d10b397a8b",
    "original": "[/color] and ",
    "translation": "",
    "context": "desc + heal.MedicineMin + \"[/color] and \""
  },
  {
    "key": "169bf2b1caf67e37d02fbb05de1bd9f483a31c23fc9e32b6cbb72cef410d89fc",
    "original": "[/color] and [color=",
    "translation": "",
    "context": "desc + \"\\n\\nHealing up all your men will take between [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + heal.DaysMin + \"[/color] and [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + heal.DaysMax + \"[/color] days and requires between \""
  },
  {
    "key": "b5a39bf56e70bae9702627edef07299763a054c965dcebdac3c0721e647c85e6",
    "original": "[/color] armor damage",
    "translation": "",
    "context": "\"Received [color=\" + this.Const.UI.Color.NegativeValue + \"]\" + combatStats.DamageReceivedArmor + \"[/color] armor damage\""
  },
  {
    "key": "a7bbdb9008a1d97d29150a5fd026eb77ed5dd0550b99f62c62659a1c8d142861",
    "original": "[/color] crowns per day.\n\n[color=",
    "translation": "",
    "context": "\"The amount of coin your mercenary company has. Used to pay every man daily, as well as to hire new men and purchase equipment.\\n\\nYou pay out [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + dailyMoney + \"[/color] crowns per day.\\n\\n[color=\" + this.Const.UI.Color.NegativeValue + \"]You have no more crowns to pay your men with! Earn some crowns fast or let some people go before they desert you one by one.[/color]\""
  },
  {
    "key": "796f2653d0b1c8a15b703ffdb58eb111e2dd5d58a03b7cb973dd15d448f3dcca",
    "original": "[/color] crowns per day. Your [color=",
    "translation": "",
    "context": "\"The amount of coin your mercenary company has. Used to pay every man daily at noon, as well as to hire new people and purchase equipment.\\n\\nYou pay out [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + dailyMoney + \"[/color] crowns per day. Your [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + money + \"[/color] crowns will last you for [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + time + \"[/color] more days.\""
  },
  {
    "key": "e96ff933c51cb302a9bfd3f637ee53f774ade0105ec0c1bd1c99edfcf07f45e0",
    "original": "[/color] crowns will last you for [color=",
    "translation": "",
    "context": "\"The amount of coin your mercenary company has. Used to pay every man daily at noon, as well as to hire new people and purchase equipment.\\n\\nYou pay out [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + dailyMoney + \"[/color] crowns per day. Your [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + money + \"[/color] crowns will last you for [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + time + \"[/color] more days.\""
  },
  {
    "key": "9d430eae66be62c67bd35c43bb969a22e15fb3f873cc5ec56ac3d45282283c79",
    "original": "[/color] damage to armor",
    "translation": "",
    "context": "\"Dealt [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + combatStats.DamageDealtArmor + \"[/color] damage to armor\""
  },
  {
    "key": "6a70fcd30f8591f240f6051eff75592cc872c47d4e00381f548b32772367822f",
    "original": "[/color] damage to hitpoints",
    "translation": "",
    "context": "\"Dealt [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + combatStats.DamageDealtHitpoints + \"[/color] damage to hitpoints\""
  },
  {
    "key": "834a48a59ff2c485fb67d6794bd671a11bde2de36f9955aa72da346e4bac4dee",
    "original": "[/color] days",
    "translation": "",
    "context": "\"Will heal in [color=\" + this.Const.UI.Color.NegativeValue + \"]\" + entity.getDaysWounded() + \"[/color] days\""
  },
  {
    "key": "75398e066ff06e63c6643e3e585c906dca6846b01a4944dc093c9349f6d6c3d8",
    "original": "[/color] days and requires between ",
    "translation": "",
    "context": "desc + \"\\n\\nHealing up all your men will take between [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + heal.DaysMin + \"[/color] and [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + heal.DaysMax + \"[/color] days and requires between \""
  },
  {
    "key": "e8f76962722bea372ce26d87a261b68d225de6f87ca62ff005badfdbaa2971f9",
    "original": "[/color] hitpoint damage",
    "translation": "",
    "context": "\"Received [color=\" + this.Const.UI.Color.NegativeValue + \"]\" + combatStats.DamageReceivedHitpoints + \"[/color] hitpoint damage\""
  },
  {
    "key": "70059de0ea47062e8972fd3e22bd42681ad51dfc68252c7341722fc34577cea5",
    "original": "[/color] hours and requires ",
    "translation": "",
    "context": "desc + \"\\n\\nRepairing all your equipment will take [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + repair.Hours + \"[/color] hours and requires \""
  },
  {
    "key": "bfd31a20e99149901af238807591eee15ada4920d1010c5321c1e14cb40fd6c1",
    "original": "[/color] more days at most. Keep in mind that individual provisions will eventually turn bad!",
    "translation": "",
    "context": "\"The total amount of provisions you carry. The average man requires 2 provisions per day and more on difficult terrain. Your men will eat the provisions closest to expiring first. Running out of provisions will lower morale and will eventually lead to your people deserting you before dying of starvation.\\n\\nYou use [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + dailyFood + \"[/color] provisions per day. Your [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + food + \"[/color] provisions will last you for [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + time + \"[/color] more days at most. Keep in mind that individual provisions will eventually turn bad!\""
  },
  {
    "key": "bb4c5191ce51f79132d3bef9d298bb2d26019f30487bd0ba2bcf29a716c8361b",
    "original": "[/color] more days.",
    "translation": "",
    "context": "\"The amount of coin your mercenary company has. Used to pay every man daily at noon, as well as to hire new people and purchase equipment.\\n\\nYou pay out [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + dailyMoney + \"[/color] crowns per day. Your [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + money + \"[/color] crowns will last you for [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + time + \"[/color] more days.\""
  },
  {
    "key": "1f02569a69eabaeff3b4e54d0c3eebe4e911910bd4be52871f8bc7025581267c",
    "original": "[/color] provisions per day.\n\n[color=",
    "translation": "",
    "context": "\"The total amount of provisions you carry. The average man requires 2 provisions per day and more on difficult terrain. Your men will eat the provisions closest to expiring first. Running out of provisions will lower morale and will eventually lead to your people deserting you before dying of starvation.\\n\\nYou use [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + dailyFood + \"[/color] provisions per day.\\n\\n[color=\" + this.Const.UI.Color.NegativeValue + \"]You are almost out of provisions to feed your men! Buy new provisions as fast as possible or your men will desert you one by one before they starve![/color]\""
  },
  {
    "key": "1f02569a69eabaeff3b4e54d0c3eebe4e911910bd4be52871f8bc7025581267c",
    "original": "[/color] provisions per day.\n\n[color=",
    "translation": "",
    "context": "\"The total amount of provisions you carry. The average man requires 2 provisions per day and more on difficult terrain. Your men will eat the provisions closest to expiring first. Running out of provisions will lower morale and will eventually lead to your people deserting you before dying of starvation.\\n\\nYou use [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + dailyFood + \"[/color] provisions per day.\\n\\n[color=\" + this.Const.UI.Color.NegativeValue + \"]You have no more provisions to feed your men! Buy new provisions as fast as possible or your men will desert you one by one before they starve![/color]\""
  },
  {
    "key": "88f9ab258fb5d9d66716b7bcc540e3d54b4998bbc20a095da5572777862d3e19",
    "original": "[/color] provisions per day. Your [color=",
    "translation": "",
    "context": "\"The total amount of provisions you carry. The average man requires 2 provisions per day and more on difficult terrain. Your men will eat the provisions closest to expiring first. Running out of provisions will lower morale and will eventually lead to your people deserting you before dying of starvation.\\n\\nYou use [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + dailyFood + \"[/color] provisions per day. Your [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + food + \"[/color] provisions will last you for [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + time + \"[/color] more days at most. Keep in mind that individual provisions will eventually turn bad!\""
  },
  {
    "key": "e3b7a3889b7f564bb71a31d5143476077c7b5436633f2f1472850b20d968be21",
    "original": "[/color] provisions will last you for [color=",
    "translation": "",
    "context": "\"The total amount of provisions you carry. The average man requires 2 provisions per day and more on difficult terrain. Your men will eat the provisions closest to expiring first. Running out of provisions will lower morale and will eventually lead to your people deserting you before dying of starvation.\\n\\nYou use [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + dailyFood + \"[/color] provisions per day. Your [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + food + \"[/color] provisions will last you for [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + time + \"[/color] more days at most. Keep in mind that individual provisions will eventually turn bad!\""
  },
  {
    "key": "27e780afe843fad5f1b047b64007acafce314415413afb52f14872ded39467bb",
    "original": "[/color] tools and supplies.",
    "translation": "",
    "context": "desc + repair.ArmorParts + \"[/color] tools and supplies.\""
  },
  {
    "key": "14016b681d605ea88dce1f532c73d0fb4a81b873200dd36fe3e4252df296845f",
    "original": "[/color][/b] AP and [b][color=",
    "translation": "",
    "context": "\"Costs [b][color=\" + this.Const.UI.Color.PositiveValue + \"]\" + actor.getActionPointCosts()[lastTileHovered.Type] + \"[/color][/b] AP and [b][color=\" + this.Const.UI.Color.PositiveValue + \"]\" + actor.getFatigueCosts()[lastTileHovered.Type] + \"[/color][/b] Fatigue to traverse\""
  },
  {
    "key": "14016b681d605ea88dce1f532c73d0fb4a81b873200dd36fe3e4252df296845f",
    "original": "[/color][/b] AP and [b][color=",
    "translation": "",
    "context": "\"Costs [b][color=\" + this.Const.UI.Color.PositiveValue + \"]\" + actor.getActionPointCosts()[lastTileHovered.Type] + \"+\" + actor.getLevelActionPointCost() + \"[/color][/b] AP and [b][color=\" + this.Const.UI.Color.PositiveValue + \"]\" + actor.getFatigueCosts()[lastTileHovered.Type] + \"+\" + actor.getLevelFatigueCost() + \"[/color][/b] Fatigue to traverse because it is at a different height level\""
  },
  {
    "key": "3922616804ee526623cf94551de6e052331664dc2a0c7654aa311ad1c005efe7",
    "original": "[/color][/b] AP)",
    "translation": "",
    "context": "\"Place item in bag ([b][color=\" + this.Const.UI.Color.PositiveValue + \"]\" + _activeEntity.getItems().getActionCost([_item]) + \"[/color][/b] AP)\""
  },
  {
    "key": "3922616804ee526623cf94551de6e052331664dc2a0c7654aa311ad1c005efe7",
    "original": "[/color][/b] AP)",
    "translation": "",
    "context": "\"Equip item ([b][color=\" + this.Const.UI.Color.PositiveValue + \"]\" + _activeEntity.getItems().getActionCost([_item,_entity.getItems().getItemAtSlot(_item.getSlotType()),_entity.getItems().getItemAtSlot(_item.getBlockedSlotType())]) + \"[/color][/b] AP)\""
  },
  {
    "key": "3922616804ee526623cf94551de6e052331664dc2a0c7654aa311ad1c005efe7",
    "original": "[/color][/b] AP)",
    "translation": "",
    "context": "\"Drop item on ground ([b][color=\" + this.Const.UI.Color.PositiveValue + \"]\" + _activeEntity.getItems().getActionCost([_item]) + \"[/color][/b] AP)\""
  },
