  },
  {
    "key": "e1c70f72a853d7f1355b53c53a7aa7af6a539aead03eca64de35605b8435f216",
    "original": "The Beasts & Exploration DLC adds a variety of new beasts roaming the wilds, a new crafting system to create items from trophies, legendary locations with unique rewards to discover, many new contracts and events, a new system of armor attachments, new weapons, armor and usable items, and more.",
    "translation": "",
    "context": "text = \"The Beasts & Exploration DLC adds a variety of new beasts roaming the wilds, a new crafting system to create items from trophies, legendary locations with unique rewards to discover, many new contracts and events, a new system of armor attachments, new weapons, armor and usable items, and more.\""
  },
  {
    "key": "7c4cbf674f13fa5e1d0ed6810588ac0d2b7c242b17e6ede8581dbc4a035690cd",
    "original": "The Blazing Deserts DLC adds a new desert region to the south inspired by medieval Arabic and Persian cultures, a new late game crisis involving a holy war, a retinue of non-combat followers with which to customize your company, alchemical contraptions and primitive firearms, new human and beastly opponents, new contracts and events, and more.",
    "translation": "",
    "context": "text = \"The Blazing Deserts DLC adds a new desert region to the south inspired by medieval Arabic and Persian cultures, a new late game crisis involving a holy war, a retinue of non-combat followers with which to customize your company, alchemical contraptions and primitive firearms, new human and beastly opponents, new contracts and events, and more.\""
  },
  {
    "key": "f393d915e6c2fbd7a8079f49f3f415e0ad89339d0058a0985ee5f38968767d5e",
    "original": "The Warriors of the North DLC adds a new human faction of northern barbarians with their own fighting style and equipment, different starting scenarios for your company, new nordic and rus inspired equipment, as well as new contracts and events.",
    "translation": "",
    "context": "text = \"The Warriors of the North DLC adds a new human faction of northern barbarians with their own fighting style and equipment, different starting scenarios for your company, new nordic and rus inspired equipment, as well as new contracts and events.\""
  },
  {
    "key": "b96d8f5539092d4a42d96187a20e9e46a5143e5833c3611b0032085bfcef2c1b",
    "original": "The amount of coin your mercenary company has. Used to pay every man daily at noon, as well as to hire new people and purchase equipment.\n\nYou currently don't pay anyone.",
    "translation": "",
    "context": "text = \"The amount of coin your mercenary company has. Used to pay every man daily at noon, as well as to hire new people and purchase equipment.\\n\\nYou currently don't pay anyone.\""
  },
  {
    "key": "b950d9f3b21d201f96412232f485250ae81e17879ccd08c7e47fb0b1a1195278",
    "original": "The amount of coin your mercenary company has. Used to pay every man daily at noon, as well as to hire new people and purchase equipment.\n\nYou pay out [color=",
    "translation": "",
    "context": "\"The amount of coin your mercenary company has. Used to pay every man daily at noon, as well as to hire new people and purchase equipment.\\n\\nYou pay out [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + dailyMoney + \"[/color] crowns per day. Your [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + money + \"[/color] crowns will last you for [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + time + \"[/color] more days.\""
  },
  {
    "key": "8260bc86fd2c3179bef6968e4f89688838e9f659fed56c70d6220fd19d86b218",
    "original": "The amount of coin your mercenary company has. Used to pay every man daily, as well as to hire new men and purchase equipment.\n\nYou pay out [color=",
    "translation": "",
    "context": "\"The amount of coin your mercenary company has. Used to pay every man daily, as well as to hire new men and purchase equipment.\\n\\nYou pay out [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + dailyMoney + \"[/color] crowns per day.\\n\\n[color=\" + this.Const.UI.Color.NegativeValue + \"]You have no more crowns to pay your men with! Earn some crowns fast or let some people go before they desert you one by one.[/color]\""
  },
  {
    "key": "6a6072a192a2674486af52c8749998b96b612b8cf4f9cf41de55456055da8f36",
    "original": "The amount of provisions a man requires each day. Running out of provisions will lower morale and will eventually lead to your men deserting you before dying of starvation.",
    "translation": "",
    "context": "text = \"The amount of provisions a man requires each day. Running out of provisions will lower morale and will eventually lead to your men deserting you before dying of starvation.\""
  },
  {
    "key": "d5432d7c353e8135d4c85135ea8035cd19dbdfde5c61e44e71b33d59a7bd8af9",
    "original": "The arena offers an opportunity to earn gold and fame in fights that are to the death, and in front of crowds that cheer for the most gruesome manner in which lives are dispatched.",
    "translation": "",
    "context": "text = \"The arena offers an opportunity to earn gold and fame in fights that are to the death, and in front of crowds that cheer for the most gruesome manner in which lives are dispatched.\""
  },
  {
    "key": "d0dde2da84b2dab03d9899d7ab471b8902beaaded54fddfd7b46ab36e243d37d",
    "original": "The base damage the currently equipped weapon does. Will be applied in full against hitpoints if no armor is protecting the target. If the target is protected by armor, the damage is applied to armor instead based on the weapon's effectiveness against armor. The actual damage done is modified by the skill used and the target hit.",
    "translation": "",
    "context": "text = \"The base damage the currently equipped weapon does. Will be applied in full against hitpoints if no armor is protecting the target. If the target is protected by armor, the damage is applied to armor instead based on the weapon's effectiveness against armor. The actual damage done is modified by the skill used and the target hit.\""
  },
  {
    "key": "ffb48c53b154fa775b61cae2b79b0a95a8c3eaf0be3c640e0e86862cb3c63fc0",
    "original": "The base percentage chance to hit a target's head for increased damage. The final chance can be modified by the skill used.",
    "translation": "",
    "context": "text = \"The base percentage chance to hit a target's head for increased damage. The final chance can be modified by the skill used.\""
  },
  {
    "key": "8ecad01cc646cfae5c68860c572a00910c8ed8c99b9dfc2d7203442038038c3f",
    "original": "The base percentage of damage that will be applied when hitting a target protected by armor. Once the armor is destroyed, the weapon damage applies at 100% to hitpoints. The actual damage done is modified by the skill used and the target hit.",
    "translation": "",
    "context": "text = \"The base percentage of damage that will be applied when hitting a target protected by armor. Once the armor is destroyed, the weapon damage applies at 100% to hitpoints. The actual damage done is modified by the skill used and the target hit.\""
  },
  {
    "key": "4e2743961e7b8b06841b1d206a054a95b9623eb83bcca917026769442c989e74",
    "original": "The character's level measures experience in battle. Characters rise in levels as they gain experience and are able to increase their attributes and gain perks that make them better at the mercenary profession.\n\nBeyond the 11th character level, characters are veterans and will no longer gain perk points, but can still continue to improve.",
    "translation": "",
    "context": "text = \"The character's level measures experience in battle. Characters rise in levels as they gain experience and are able to increase their attributes and gain perks that make them better at the mercenary profession.\\n\\nBeyond the 11th character level, characters are veterans and will no longer gain perk points, but can still continue to improve.\""
  },
  {
    "key": "eb40d6da122985007875635e125b6020950cee105b58ef1fb20d2b0e4e565b4b",
    "original": "The character's name.",
    "translation": "",
    "context": "text = \"The character's name.\""
  },
  {
    "key": "8f4ea7372a8627babb943d6e39415217f51c0998b64da6b39b209b5bcb9177c8",
    "original": "The daily wage will be paid every single day as payment for serving under your command. The wage is increased automatically by a cumulative 10% per level until the 11th, and then 3% afterwards.",
    "translation": "",
    "context": "text = \"The daily wage will be paid every single day as payment for serving under your command. The wage is increased automatically by a cumulative 10% per level until the 11th, and then 3% afterwards.\""
  },
  {
    "key": "ae2f2a876fac7a2a327d2cde81f755749963ccccf46a3dd2e60fa07ad03cea19",
    "original": "The damage dealt by this character during battle, against hitpoints and against armor.",
    "translation": "",
    "context": "text = \"The damage dealt by this character during battle, against hitpoints and against armor.\""
  },
  {
    "key": "7fc8532a436a5c9d4784294d5b0282a69858e9fa85971561dedb36f792b55023",
    "original": "The damage received by this character, split into damage to hitpoints and damage to armor. The value is after any possible damage reduction.",
    "translation": "",
    "context": "text = \"The damage received by this character, split into damage to hitpoints and damage to armor. The value is after any possible damage reduction.\""
  },
  {
    "key": "8024dcfbd18606443b49dd83ce2ba25191de05cf214ca69db1dc129de6b02ef0",
    "original": "The first late game crisis will be a holy war between northern and southern cultures. If you survive for long enough, the following ones will be chosen at random.",
    "translation": "",
    "context": "text = \"The first late game crisis will be a holy war between northern and southern cultures. If you survive for long enough, the following ones will be chosen at random.\""
  },
  {
    "key": "52b965fb74752bf1387743b1e49ea2ba337e8a8774aa419a15a8350a44333245",
    "original": "The first late game crisis will be a ruthless war for power between noble houses. If you survive for long enough, the following ones will be chosen at random.",
    "translation": "",
    "context": "text = \"The first late game crisis will be a ruthless war for power between noble houses. If you survive for long enough, the following ones will be chosen at random.\""
  },
  {
    "key": "c041fdfce2fc086f273e7c0ae2a0fd7e891bd80aa9ad79614065aab4f9fae285",
    "original": "The first late game crisis will be an invasion of greenskin hordes threatening to sweep away the world of man. If you survive for long enough, the following ones will be chosen at random.",
    "translation": "",
    "context": "text = \"The first late game crisis will be an invasion of greenskin hordes threatening to sweep away the world of man. If you survive for long enough, the following ones will be chosen at random.\""
  },
  {
    "key": "fbdfb253faf12ff71775739c192f1c667db699cb03eb17c38a6a55758125f66f",
    "original": "The first late game crisis will be the ancient dead arising again to take back what was once theirs. If you survive for long enough, the following ones will be chosen at random.",
    "translation": "",
    "context": "text = \"The first late game crisis will be the ancient dead arising again to take back what was once theirs. If you survive for long enough, the following ones will be chosen at random.\""
  },
  {
    "key": "8581ae867da599a2b65a4714ac886c37ad865234e39f041b8f4dc6fb230568ca",
    "original": "The free Lindwurm DLC adds a challenging new beast, a new player banner, as well as a new famed armor, helmet and shield.",
    "translation": "",
    "context": "text = \"The free Lindwurm DLC adds a challenging new beast, a new player banner, as well as a new famed armor, helmet and shield.\""
  },
  {
    "key": "5d3f9244360e64a1ef823b54684b661f654b9a489b8ea8032f19168dbd7d3cce",
    "original": "The free Of Flesh and Faith DLC adds two new and very unique origins for you to play as: The Anatomists and the Oathtakers. In addition, there's two new banners, new equipment, new backgrounds to hire and lots of new events.",
    "translation": "",
    "context": "text = \"The free Of Flesh and Faith DLC adds two new and very unique origins for you to play as: The Anatomists and the Oathtakers. In addition, there's two new banners, new equipment, new backgrounds to hire and lots of new events.\""
  },
  {
    "key": "fc33e4409ee35259ea820e22c0bff1aa5288844e3b33563682ce5a52344f698c",
    "original": "The higher this value, the earlier the position in the turn order. Initiative is reduced by the current fatigue, as well as any penalty to maximum fatigue (such as from heavy armor). In general, someone in light armor will act before someone in heavy armor, and someone fresh will act before someone fatigued.",
    "translation": "",
    "context": "text = \"The higher this value, the earlier the position in the turn order. Initiative is reduced by the current fatigue, as well as any penalty to maximum fatigue (such as from heavy armor). In general, someone in light armor will act before someone in heavy armor, and someone fresh will act before someone fatigued.\""
  },
  {
    "key": "29896e6e9d9b50dd064b45e276de39cec31dd53a27eafecb0a9b8f21c508ba77",
    "original": "The hiring fee will be paid immediately on hiring a man for signing up and proving you can back up your words with coin.",
    "translation": "",
    "context": "text = \"The hiring fee will be paid immediately on hiring a man for signing up and proving you can back up your words with coin.\""
  },
  {
    "key": "c5c710acf835cad4848e3dd2d51a05e09fa23427f2423ea6be3406e699106a86",
    "original": "The name your mercenary company will be known by throughout the lands.",
    "translation": "",
    "context": "text = \"The name your mercenary company will be known by throughout the lands.\""
  },
  {
    "key": "239a46c5d4a677f93e278be440e289cc97fbb55b233625a5c0ab8e8d8a7319d6",
    "original": "The number of Battle Brothers controlled by you and allies controlled by the AI on the battlefield.",
    "translation": "",
    "context": "text = \"The number of Battle Brothers controlled by you and allies controlled by the AI on the battlefield.\""
  },
  {
    "key": "cbb0046fd0f83bf5c015bcb9ddfa72bc3120945d554dc3753e5923576defbead",
    "original": "The number of battles that the character fought in until their demise.",
    "translation": "",
    "context": "text = \"The number of battles that the character fought in until their demise.\""
  },
  {
    "key": "dc4b54c607edff1e390a91db66e6e5efa11e07953224007a204aabc18e417e83",
    "original": "The number of days that the character served in the company until their demise.",
    "translation": "",
    "context": "text = \"The number of days that the character served in the company until their demise.\""
  },
  {
    "key": "217d1c1b06e4655b949f2f456bee3faac147719d82e358458e514e9a4d28284e",
    "original": "The number of experience points gained during the battle from fighting and killing opponents. Gaining enough experience points will allow this man to level up, increase attributes and gain new perks.",
    "translation": "",
    "context": "text = \"The number of experience points gained during the battle from fighting and killing opponents. Gaining enough experience points will allow this man to level up, increase attributes and gain new perks.\""
  },
  {
    "key": "cb8ae3b6efdc9146997e327b3480af02a2210ac1834ab90926705ebe586d47e3",
    "original": "The number of kills that the character scored in battle until their demise.",
    "translation": "",
    "context": "text = \"The number of kills that the character scored in battle until their demise.\""
  },
  {
    "key": "b9837a7537082412ef3f20f2cf24ae649fb2397057db3078c2207487df421fd2",
    "original": "The number of kills this character had during the battle.",
    "translation": "",
    "context": "text = \"The number of kills this character had during the battle.\""
  },
  {
    "key": "6c392a8d71facfdce5952ce139a4fea82863760e089f248b28ff2231bb4f93bd",
    "original": "The number of opponents currently on the battlefield.",
    "translation": "",
    "context": "text = \"The number of opponents currently on the battlefield.\""
  },
  {
    "key": "c4547b79f4af447a11a4d80da1733f8089b1971664b7cfc18ce3ea1de9a65686",
    "original": "The number of rounds played since the battle began.",
    "translation": "",
    "context": "text = \"The number of rounds played since the battle began.\""
  },
  {
    "key": "04da5582922615aee8cb3ef52cd4c4c3f905ec1ef5743bd89ac494f497eee750",
    "original": "The terms of this contract have been negotiated. All that's left is for you to sign it.",
    "translation": "",
    "context": "text = \"The terms of this contract have been negotiated. All that's left is for you to sign it.\""
  },
  {
    "key": "501fa1383e3085d46a46f7011b93e28114516464a2c53c7300506b4a59dd5948",
    "original": "The total amount of provisions you carry. The average man requires 2 provisions per day and more on difficult terrain. Your men will eat the provisions closest to expiring first. Running out of provisions will lower morale and will eventually lead to your people deserting you before dying of starvation.\n\nYou use [color=",
    "translation": "",
    "context": "\"The total amount of provisions you carry. The average man requires 2 provisions per day and more on difficult terrain. Your men will eat the provisions closest to expiring first. Running out of provisions will lower morale and will eventually lead to your people deserting you before dying of starvation.\\n\\nYou use [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + dailyFood + \"[/color] provisions per day. Your [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + food + \"[/color] provisions will last you for [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + time + \"[/color] more days at most. Keep in mind that individual provisions will eventually turn bad!\""
  },
  {
    "key": "501fa1383e3085d46a46f7011b93e28114516464a2c53c7300506b4a59dd5948",
    "original": "The total amount of provisions you carry. The average man requires 2 provisions per day and more on difficult terrain. Your men will eat the provisions closest to expiring first. Running out of provisions will lower morale and will eventually lead to your people deserting you before dying of starvation.\n\nYou use [color=",
    "translation": "",
    "context": "\"The total amount of provisions you carry. The average man requires 2 provisions per day and more on difficult terrain. Your men will eat the provisions closest to expiring first. Running out of provisions will lower morale and will eventually lead to your people deserting you before dying of starvation.\\n\\nYou use [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + dailyFood + \"[/color] provisions per day.\\n\\n[color=\" + this.Const.UI.Color.NegativeValue + \"]You are almost out of provisions to feed your men! Buy new provisions as fast as possible or your men will desert you one by one before they starve![/color]\""
  },
  {
    "key": "501fa1383e3085d46a46f7011b93e28114516464a2c53c7300506b4a59dd5948",
    "original": "The total amount of provisions you carry. The average man requires 2 provisions per day and more on difficult terrain. Your men will eat the provisions closest to expiring first. Running out of provisions will lower morale and will eventually lead to your people deserting you before dying of starvation.\n\nYou use [color=",
    "translation": "",
    "context": "\"The total amount of provisions you carry. The average man requires 2 provisions per day and more on difficult terrain. Your men will eat the provisions closest to expiring first. Running out of provisions will lower morale and will eventually lead to your people deserting you before dying of starvation.\\n\\nYou use [color=\" + this.Const.UI.Color.PositiveValue + \"]\" + dailyFood + \"[/color] provisions per day.\\n\\n[color=\" + this.Const.UI.Color.NegativeValue + \"]You have no more provisions to feed your men! Buy new provisions as fast as possible or your men will desert you one by one before they starve![/color]\""
  },
  {
    "key": "7430d0bf0e1eba2485eefed95b39be89cedcea66489dc68ca09e0b56943aa4f0",
    "original": "There will be no late game crisis, and you can keep on playing the sandbox experience forever. Note that with this option selected, a significant part of the game's content and late game challenge won't be accessible. Not recommended for the best experience.",
    "translation": "",
    "context": "text = \"There will be no late game crisis, and you can keep on playing the sandbox experience forever. Note that with this option selected, a significant part of the game's content and late game challenge won't be accessible. Not recommended for the best experience.\""
  },
  {
    "key": "444e3f9073e52946f34cdc324bb979225d63f17f853a643704af7ec560d28e46",
    "original": "There's space here to add another non-combat follower to your company.",
    "translation": "",
    "context": "text = \"There's space here to add another non-combat follower to your company.\""
  },
  {
    "key": "ef3bfe660d3b2c53eb05a9968e49a0e58e72894db9bf6e20ec6f16a381557518",
    "original": "This armorer's workshop is the right place to look for well-made and durable protection. Damaged equipment can also be repaired here for a price.",
    "translation": "",
    "context": "text = \"This armorer's workshop is the right place to look for well-made and durable protection. Damaged equipment can also be repaired here for a price.\""
  },
  {
    "key": "08928f3fbd2e99bd1df3bced7cd35b29d98fa3e4ca4c50a21f5e5a4c3f7221ac",
    "original": "This character already has experience in combat and starts with a higher level.",
    "translation": "",
    "context": "text = \"This character already has experience in combat and starts with a higher level.\""
  },
  {
    "key": "e6a3e45e832a3a46f52e1744b3e54d4eaca67a02c4bc3915d0e0d1cf1c8a7a7c",
    "original": "This character has leveled up. Increase his attributes and select a perk!",
    "translation": "",
    "context": "text = \"This character has leveled up. Increase his attributes and select a perk!\""
  },
  {
    "key": "e56070e616c336d71b592453dab1be2e1125aaf54ca964581c82ca353c9dc0d8",
    "original": "This character just leveled up! Find him in your roster, accessible on the worldmap, to raise his attributes and select a perk.",
    "translation": "",
    "context": "text = \"This character just leveled up! Find him in your roster, accessible on the worldmap, to raise his attributes and select a perk.\""
  },
  {
    "key": "6bf3a211b1850a7d496419dd3de6a3775fb0d56cac879b24472439601f244580",
    "original": "This character may have unknown traits. You can pay for a tryout to reveal these.",
    "translation": "",
    "context": "text = \"This character may have unknown traits. You can pay for a tryout to reveal these.\""
  },
  {
    "key": "5f96d463c6611558fdb61350b89fb0f3607c5c4c547ac5a6576c1353291ba52d",
    "original": "This fee will be paid immediately on giving this recruit a proper inspection to reveal his character traits, if any.",
