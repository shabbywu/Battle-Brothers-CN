    "key": "4ef536cafa37ab5d9b6616363b5bf967c4a047e466ab76d959e8f42a1880335e",
    "original": " renown in order to unlock this seat. Gain renown by completing ambitions and contracts, as well as by winning battles.",
    "translation": "",
    "context": "\"Your company lacks the renown necessary to hire more non-combat followers. Attain at least \" + renown + \" renown in order to unlock this seat. Gain renown by completing ambitions and contracts, as well as by winning battles.\""
  },
  {
    "key": "993b08ae2c50ffff29e711d04d21f92e790005fa8d112a2a3fce477f3f56e137",
    "original": " to have it repaired",
    "translation": "",
    "context": "\"Pay [img]gfx/ui/tooltips/money.png[/img]\" + price + \" to have it repaired\""
  },
  {
    "key": "4550ca5828e99646f9ecfe87b63e60d670f420fc14493865bc0e7419594b836d",
    "original": " units at a time.",
    "translation": "",
    "context": "\"Assorted arrows, bolts and throwing weapons used to automatically refill quivers after battle. Replacing one arrow or bolt will take up one point of ammunition, replacing one shot of a Handgonne will take up two points, and replacing one throwing weapon or charge of a Fire Lance will take up three. Running out of ammunition will leave your quivers empty and your people with nothing to shoot with. You can carry no more than \" + this.Const.Difficulty.MaxResources[this.World.Assets.getEconomicDifficulty()].Ammo + this.World.Assets.m.AmmoMaxAdditional + \" units at a time.\""
  },
  {
    "key": "1a9c3dea5e40e17e6a9e82e72b980e217a9888713bd58ebbefa92efcca5904a8",
    "original": " units at most.",
    "translation": "",
    "context": "desc + \"  You can carry \" + this.Const.Difficulty.MaxResources[this.World.Assets.getEconomicDifficulty()].Medicine + this.World.Assets.m.MedicineMaxAdditional + \" units at most.\""
  },
  {
    "key": "1a9c3dea5e40e17e6a9e82e72b980e217a9888713bd58ebbefa92efcca5904a8",
    "original": " units at most.",
    "translation": "",
    "context": "desc + \"  You can carry \" + this.Const.Difficulty.MaxResources[this.World.Assets.getEconomicDifficulty()].ArmorParts + this.World.Assets.m.ArmorPartsMaxAdditional + \" units at most.\""
  },
  {
    "key": "59256a9043b646603c70c8652d5948d41b3e309e12d5e9f91a4d84d0b509b298",
    "original": " was slain here.",
    "translation": "",
    "context": "lastTileHovered.Properties.get(\"Corpse\").CorpseName + \" was slain here.\""
  },
  {
    "key": "239c9458ea0d3f87eca60a265d9abc670bb46326693a2086d1f0969eec61ec89",
    "original": "A fletcher offering all kinds of expertly crafted ranged weaponry.",
    "translation": "",
    "context": "text = \"A fletcher offering all kinds of expertly crafted ranged weaponry.\""
  },
  {
    "key": "46cafc9539084787bab28b31735dc92da0e3c6e9a1ee89bd2ea648ec3fba54bf",
    "original": "A harbor that serves both foreign trading ships and local fishermen. You'll likely be able to book passage by sea to other parts of the continent here.",
    "translation": "",
    "context": "text = \"A harbor that serves both foreign trading ships and local fishermen. You'll likely be able to book passage by sea to other parts of the continent here.\""
  },
  {
    "key": "a42a3aad28f55cba31c3c816261e71c364e505da004d1d2c565f51ea53d73474",
    "original": "A higher melee defense reduces the probability of being hit with a melee attack, such as the thrust of a spear. It can be increased as the character gains experience and by equipping a good shield.",
    "translation": "",
    "context": "text = \"A higher melee defense reduces the probability of being hit with a melee attack, such as the thrust of a spear. It can be increased as the character gains experience and by equipping a good shield.\""
  },
  {
    "key": "6ebdb43b2faa8120c89fc5e578bf01503cfb742fb6cacf306e7c1a9d37873e11",
    "original": "A higher ranged defense reduces the probability of being hit with a ranged attack, such as an arrow shot from afar. It can be increased as the character gains experience and by equipping a good shield.",
    "translation": "",
    "context": "text = \"A higher ranged defense reduces the probability of being hit with a ranged attack, such as an arrow shot from afar. It can be increased as the character gains experience and by equipping a good shield.\""
  },
  {
    "key": "b448ce02fbfea9415b5f3729525cf33c2d6a98fa55307ad0c5fc72da8dbd785d",
    "original": "A kennel where strong and fast dogs are bred for war.",
    "translation": "",
    "context": "text = \"A kennel where strong and fast dogs are bred for war.\""
  },
  {
    "key": "8a51c1c89322b60134c8339bf8bf044e8bb6ca8aace16599fc044ab4808b7bb0",
    "original": "A large tavern filled with patrons from all over the lands, offering beverages, food and a lively atmosphere in which to share news and rumors.",
    "translation": "",
    "context": "text = \"A large tavern filled with patrons from all over the lands, offering beverages, food and a lively atmosphere in which to share news and rumors.\""
  },
  {
    "key": "870d146c946ea9df949e915917957364ed955222dde6cb759ec21a9449a2483c",
    "original": "A lively market offering all sorts of goods common in the region. New wares will be on offer every few days, and when trading caravans reach this settlement.",
    "translation": "",
    "context": "text = \"A lively market offering all sorts of goods common in the region. New wares will be on offer every few days, and when trading caravans reach this settlement.\""
  },
  {
    "key": "4ffd362a9f5b2b11466692d6df3c6e8f3d943467092dea9a40e6bd65d4b64c05",
    "original": "A map seed is a unique string that determines how the world in your campaign will look like. You can see the seed of ongoing campaigns in the game menu accessible by pressing the Escape key, and then share it with friends to have them play in the same world.",
    "translation": "",
    "context": "text = \"A map seed is a unique string that determines how the world in your campaign will look like. You can see the seed of ongoing campaigns in the game menu accessible by pressing the Escape key, and then share it with friends to have them play in the same world.\""
  },
  {
    "key": "5fb527279e5890df13735c9481dcc6bac6408486052c38698f5984c2e18f90aa",
    "original": "A meeting point for those of the fighting profession. Have your men train with and learn from experienced fighters here, so you can mold them faster into hardened mercenaries.",
    "translation": "",
    "context": "text = \"A meeting point for those of the fighting profession. Have your men train with and learn from experienced fighters here, so you can mold them faster into hardened mercenaries.\""
  },
  {
    "key": "941231844e30cd0f3ea511dc4d4391d1caf1e7b15801dadf92a1c2425ad41699",
    "original": "A mercenary company has to carry a lot of equipment and supplies. By using carts and wagons, you can expand your available inventory space and carry even more.",
    "translation": "",
    "context": "text = \"A mercenary company has to carry a lot of equipment and supplies. By using carts and wagons, you can expand your available inventory space and carry even more.\""
  },
  {
    "key": "181efaf731a63a8517c6f9d33f3852a457dc01d681c661cee48fcfff6de238c1",
    "original": "A refuge from the harsh world outside. You can seek healing here for your wounded and pray for salvation of your eternal soul.",
    "translation": "",
    "context": "text = \"A refuge from the harsh world outside. You can seek healing here for your wounded and pray for salvation of your eternal soul.\""
  },
  {
    "key": "e794a16ceadb691cd3472435913f387004e6a02215dcdfdfbd5e3705f92418dd",
    "original": "A weapon smith's workshop displaying all kinds of well crafted weapons. Damaged equipment can also be repaired here for a price.",
    "translation": "",
    "context": "text = \"A weapon smith's workshop displaying all kinds of well crafted weapons. Damaged equipment can also be repaired here for a price.\""
  },
  {
    "key": "a92ba54fc2e9590b6b83c04496006ed45012438455560852a24814d00c7f5fb1",
    "original": "Action Points",
    "translation": "",
    "context": "text = \"Action Points\""
  },
  {
    "key": "1ac82a63d8e96acccec9490524875582910f1dd151b8cf43bfb967304e9aad30",
    "original": "Action Points (AP) are spent for every action, like moving or using a skill. Once all points are spent, the current character's turn ends automatically. AP are fully refreshed each turn.",
    "translation": "",
    "context": "text = \"Action Points (AP) are spent for every action, like moving or using a skill. Once all points are spent, the current character's turn ends automatically. AP are fully refreshed each turn.\""
  },
  {
    "key": "3d66150a4894784a21b07b327393916f1d573e8fc651d31699da826dc13a411b",
    "original": "Active Contract",
    "translation": "",
    "context": "text = \"Active Contract\""
  },
  {
    "key": "b8b1293f82fafb0f276e482da991c308ca142e4cf05bc18d84b08060311db441",
    "original": "Alchemist",
    "translation": "",
    "context": "text = \"Alchemist\""
  },
  {
    "key": "4b33fbb5835217b781660657c5a679c5ce033a3989e8982d913e26afbfb329d3",
    "original": "All crises will be randomly chosen between the options below.",
    "translation": "",
    "context": "text = \"All crises will be randomly chosen between the options below.\""
  },
