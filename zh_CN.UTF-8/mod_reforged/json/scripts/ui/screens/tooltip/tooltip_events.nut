    "context": "text = \"Ammunition\""
  },
  {
    "key": "90854cc465bc7c9da054a9a804987ec87647fe7ed596f279e5a2613a221e4d8a",
    "original": "An alchemist offering exotic and quite dangerous contraptions for a tidy sum.",
    "translation": "",
    "context": "text = \"An alchemist offering exotic and quite dangerous contraptions for a tidy sum.\""
  },
  {
    "key": "f80ebd57decb69b1cdee2800fec92b96c2c01885419249f5445a86012a1d8daa",
    "original": "An optional way to play the game where the map is entirely unexplored and not visible to you at the start of your campaign. You'll have to discover everything on your own, which makes your campaign more difficult, but potentially also more exciting.\n\nRecommended only for experienced players that know what they're doing.",
    "translation": "",
    "context": "text = \"An optional way to play the game where the map is entirely unexplored and not visible to you at the start of your campaign. You'll have to discover everything on your own, which makes your campaign more difficult, but potentially also more exciting.\\n\\nRecommended only for experienced players that know what they're doing.\""
  },
  {
    "key": "77d7cd99073bd654f4bc89d3231dcc74411ea08ce000218fda6220fd89a842fe",
    "original": "Arena",
    "translation": "",
    "context": "text = \"Arena\""
  },
  {
    "key": "635c4618f0a4975b2338a7b27b48d0f5242fc5d7de1a08a1d5d4487e983c719a",
    "original": "Armorer",
    "translation": "",
    "context": "text = \"Armorer\""
  },
  {
    "key": "4003c6438ed4d9421879c3009d218c0221bf22cb95e667d19ba2ba040a15e2bf",
    "original": "Assorted arrows, bolts and throwing weapons used to automatically refill quivers after battle. Replacing one arrow or bolt will take up one point of ammunition, replacing one shot of a Handgonne will take up two points, and replacing one throwing weapon or charge of a Fire Lance will take up three. Running out of ammunition will leave your quivers empty and your people with nothing to shoot with. You can carry no more than ",
    "translation": "",
    "context": "\"Assorted arrows, bolts and throwing weapons used to automatically refill quivers after battle. Replacing one arrow or bolt will take up one point of ammunition, replacing one shot of a Handgonne will take up two points, and replacing one throwing weapon or charge of a Fire Lance will take up three. Running out of ammunition will leave your quivers empty and your people with nothing to shoot with. You can carry no more than \" + this.Const.Difficulty.MaxResources[this.World.Assets.getEconomicDifficulty()].Ammo + this.World.Assets.m.AmmoMaxAdditional + \" units at a time.\""
  },
  {
    "key": "6c82847f5e1102a07771ba81b017c9cddb189efac42191dfc1657f4a95342fa3",
    "original": "Assorted tools and supplies to keep your weapons, armor, helmets and shields in good condition. One point is required to repair 15 points of item condition. Running out of supplies may result in weapons breaking in combat and will leave your armor damaged and useless.",
    "translation": "",
    "context": "local desc = \"Assorted tools and supplies to keep your weapons, armor, helmets and shields in good condition. One point is required to repair 15 points of item condition. Running out of supplies may result in weapons breaking in combat and will leave your armor damaged and useless.\""
  },
  {
    "key": "cc9981c1fa92c2eb2c06a0de61bb9f53d608e882dc117c8596f9e25af5883aac",
    "original": "Attribute Points",
    "translation": "",
    "context": "text = \"Attribute Points\""
  },
  {
    "key": "5f2bdd544703768eb1c5cb5f81d785d96304ddce01de8f4ef14aefc65797f158",
    "original": "Auto-Adjust Height Levels",
    "translation": "",
    "context": "text = \"Auto-Adjust Height Levels\""
  },
  {
    "key": "6ce636f8100e9c5018fbd50b85d0e50a5f483ff7fe484f0b61601f462852108f",
    "original": "Auto-End Turns",
    "translation": "",
    "context": "text = \"Auto-End Turns\""
  },
  {
    "key": "7afa210b9cc483d8d3de05a9d9a69ffb36ed018e72067ac02add4edc68fa36f8",
    "original": "Auto-Loot",
    "translation": "",
    "context": "text = \"Auto-Loot\""
  },
  {
    "key": "f6f14324464ac173b679a1caba43539f5325c331b3041bf2f6ed66127c1b4900",
    "original": "Auto-Pause After Leaving City",
    "translation": "",
    "context": "text = \"Auto-Pause After Leaving City\""
  },
  {
    "key": "74fc81fb4203787d71e08da1fca509f6a0697328c5fcb244c833f1131b6da438",
    "original": "Automatically adjust the camera's height level to see the currently active character in combat. Disabling this will prevent the camera from changing height levels when it isn't strictly necessary, but will also require manual adjustment of height levels when characters happen to be obstructed by terrain.",
    "translation": "",
    "context": "text = \"Automatically adjust the camera's height level to see the currently active character in combat. Disabling this will prevent the camera from changing height levels when it isn't strictly necessary, but will also require manual adjustment of height levels when characters happen to be obstructed by terrain.\""
  },
  {
    "key": "00658d52e93fa2c563744978aa25996f91f1cfbb06ce620f36681bc1e524c72a",
    "original": "Automatically end turns of characters controlled by you once you don't have any Action Points left to perform any action.",
    "translation": "",
    "context": "text = \"Automatically end turns of characters controlled by you once you don't have any Action Points left to perform any action.\""
  },
  {
    "key": "a2ab65a5b334ec88bd255f2d6361104e59ecd65c4455dc90656471c98acac891",
    "original": "Automatically pause the game after leaving a city so that you don't waste any time - but at the expense of having to manually unpause each time.",
    "translation": "",
    "context": "text = \"Automatically pause the game after leaving a city so that you don't waste any time - but at the expense of having to manually unpause each time.\""
  },
  {
    "key": "bb9d0d0f8defbf5e44a9676c7c0bc732dfb09e97861cfbd7b3782a862802e035",
    "original": "Automatically place equipment back into the inventory slot it was in before battle, if possible. For example, if a character starts battle with a crossbow, but changes to a pike during battle, they'll automatically have the crossbow in hand again when the battle is concluded.",
    "translation": "",
    "context": "text = \"Automatically place equipment back into the inventory slot it was in before battle, if possible. For example, if a character starts battle with a crossbow, but changes to a pike during battle, they'll automatically have the crossbow in hand again when the battle is concluded.\""
  },
  {
    "key": "f28b71198c870a5e605b27a740f9575aa28a3362d1420b846a4dfe2fba42778e",
    "original": "Available, but this character has no perk point to spend",
    "translation": "",
    "context": "text = \"Available, but this character has no perk point to spend\""
  },
  {
    "key": "072582f2416e532ee7ec614b097a5fc73b53efa097b2dcb5e9930d111685162b",
    "original": "Barber",
    "translation": "",
    "context": "text = \"Barber\""
  },
  {
    "key": "caa30902648eb8d527d4090be81ad9d03e34f7f8bb0adbd01739fdc8fee1af93",
    "original": "Battles",
    "translation": "",
    "context": "text = \"Battles\""
  },
  {
    "key": "85891ed836e52ed15703c0877366a7cb48e67ec0341a1fbb6b92ceb4a99c7023",
    "original": "Beasts & Exploration",
    "translation": "",
    "context": "text = \"Beasts & Exploration\""
