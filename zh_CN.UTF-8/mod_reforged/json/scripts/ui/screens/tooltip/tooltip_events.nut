    "translation": "",
    "context": "text = \"Always Show Hitpoint Bars\""
  },
  {
    "key": "05ed31f5d11fc0324af25bdcb20474ef7870346c61d3f5ca9ed1377877e9a436",
    "original": "Always and automatically loot everything found after combat once you close the loot screen - as long as you have the space to carry it.",
    "translation": "",
    "context": "text = \"Always and automatically loot everything found after combat once you close the loot screen - as long as you have the space to carry it.\""
  },
  {
    "key": "b3d4c0ec82601d3bfd8fc7034c7dc63868563bbbc131d53ca5e846cc97b2586a",
    "original": "Always have the camera centered on any AI movement visible to you.",
    "translation": "",
    "context": "text = \"Always have the camera centered on any AI movement visible to you.\""
  },
  {
    "key": "70416a4ba998cc26e8d91f30d378aca4329cc674d3ce0b9e37b3f07df641a981",
    "original": "Always render the top of trees and other large map objects semi-transparent, as opposed to only when they're actually occluding something.",
    "translation": "",
    "context": "text = \"Always render the top of trees and other large map objects semi-transparent, as opposed to only when they're actually occluding something.\""
  },
  {
    "key": "fb110708e5fc2a1d239ad0f82f7c54f57f0ebb4082d061b4b2681b2950b1e96f",
    "original": "Always show bars for hitpoints and armor floating above characters in combat, as opposed to only when characters get hit.",
    "translation": "",
    "context": "text = \"Always show bars for hitpoints and armor floating above characters in combat, as opposed to only when characters get hit.\""
  },
  {
    "key": "352086c0b39c6e53ae601ac359ecdfcaa4bb34159de0e402c2530a7314511f16",
    "original": "Ambition",
    "translation": "",
    "context": "text = \"Ambition\""
  },
  {
    "key": "f5ba1f5823a37525b7fb9faee0cba714d192048284c5f4f8d889300189b73c5c",
    "original": "Ammunition",
