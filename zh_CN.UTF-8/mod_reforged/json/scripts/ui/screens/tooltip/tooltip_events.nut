    "original": "Always Focus AI Movement",
    "translation": "",
    "context": "text = \"Always Focus AI Movement\""
  },
  {
    "key": "d303425d71150f68bd17c4a7b70328e4207073e401aca11fba224a4812d69a33",
    "original": "Always Hide Trees",
    "translation": "",
    "context": "text = \"Always Hide Trees\""
  },
  {
    "key": "d66a9ab0382499828983fbef035ca6b8970a74cafb91fccd41ac312da26e904f",
