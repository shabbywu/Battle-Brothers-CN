    "key": "e632b4d9eb31d7f0afb64ad7f5fa9ff6aa6f330750fac58aec2d4d06fb81700f",
    "original": "]+20%[/color] Experience Gain for the duration of five battles.",
    "translation": "",
    "context": "\"Have your man undergo a rigorous training regimen to shape him into a skilled fighter. The blood and sweat spent today will benefit him in the long run with [color=\" + this.Const.UI.Color.PositiveValue + \"]+20%[/color] Experience Gain for the duration of five battles.\""
  },
  {
    "key": "a9cec9503c7f380ae75cb0bad9316c042b61e0b3c4ee557e8ebcf6b028351ec0",
    "original": "]+35%[/color] Experience Gain for the duration of three battles.",
    "translation": "",
    "context": "\"Have your man learn valuable lessons and insights from a true veteran of the trade. The knowledge imparted will result in [color=\" + this.Const.UI.Color.PositiveValue + \"]+35%[/color] Experience Gain for the duration of three battles.\""
  },
  {
    "key": "8fad7c0571383daa13b664cef5c0bba79be0500aba60ff737f42e21b833ea17d",
    "original": "]+50%[/color] Experience Gain for the next battle.",
    "translation": "",
    "context": "\"Have your man participate in a sparring fight with experienced opponents and various fighting styles. The bruises collected and lessons learned will result in [color=\" + this.Const.UI.Color.PositiveValue + \"]+50%[/color] Experience Gain for the next battle.\""
  },
  {
    "key": "2cc1d1b60710c8ab163984b59f023c8b3a89d7e6b08ab93d68afffd405bcf742",
