[
  {
    "key": "c2daa1695de77ca167ba25290ab5301e4615115b6dae3f80e3f4a928ab1c137b",
    "original": "A Qatal Dagger is best used in combination with other weapons that can stun or daze opponents.",
    "translation": "",
    "context": ""
  },
  {
    "key": "4fc466b6151bcf7fa8d4c19e12effa714a793b73ad9d1b9dc164e09ad06f62a0",
    "original": "Always out of ammo and tools? Hire a scavenger to reclaim ammo you spent and gather tools from armor you destroyed.",
    "translation": "",
    "context": ""
  },
  {
    "key": "62740eed608580c30af1241a6ab7ee78122aa63e4138409419efffc9fabbb743",
    "original": "An Ifrit is a demonic entity possessing rocks, stone and shifting sands.",
    "translation": "",
    "context": ""
  },
  {
    "key": "a086ca30506b4d590d9286af9fe789364ca6c24499c2dfff4cbc396730442ca7",
    "original": "Arena matches offer a quick way to earn coin - but you can't retreat during matches or loot afterwards.",
    "translation": "",
    "context": ""
  },
  {
    "key": "523df5d45147e731a40a8b4349c96b9d5b31fc6fba331e750a4017c0e5f612fd",
    "original": "Arena tournaments are special events with different rules. Fight with five men over three consecutive rounds and win a famed item!",
    "translation": "",
    "context": ""
  },
  {
    "key": "0c8ffc17468868d41c8d6806089deaafa12da5caa0d0b9c31f0ec438fe12ac7c",
    "original": "Desert",
    "translation": "",
    "context": "!\"Desert\" || !this.Const.DLC.Desert"
  },
  {
    "key": "e91cb3e1e8d8edd82306bba209380924d3e204187914e5bb441e25ee76366c73",
    "original": "Every fifth arena match offers the chance to win a piece of gladiator equipment that can't be bought otherwise.",
    "translation": "",
    "context": ""
  },
  {
    "key": "4a7b03dd60121851aa869d09c4e521c8760d80f5965d6f5f1d65b35c75cfbe35",
    "original": "Facing too few enemy champions? Hire a bounty hunter to find more and even earn a bounty for every one you kill.",
    "translation": "",
    "context": ""
  },
  {
    "key": "ff84e415c22e2206ae63c0532a1c5342964fb911abf8e2408b3dd7afd3364e55",
    "original": "Ferocious hyenas roam the southern deserts, with strong jaws that can crush even metal armor and inflict bleeding wounds.",
    "translation": "",
    "context": ""
  },
  {
    "key": "b86a71e975a66b03a9729b2378f212a73373816899ef4bc19243357bb1ae1fbb",
    "original": "Fire Pots can be used not just to inflict damage on your opponents, but also to deny them access to tiles and delay them.",
    "translation": "",
    "context": ""
  },
  {
    "key": "2a4ececeae97eaa82e1732e532318b790f4f8336ffbfe462831d2f351c097286",
    "original": "Hire non-combat followers for your retinue to customize your campaign to your playstyle.",
    "translation": "",
    "context": ""
  },
  {
    "key": "cd004b19138240ad6eb45aacafba884b419c4ceaf463d9e9a5258edba6da54a7",
    "original": "Inventory full? Buy carts and wagons for your company in the Retinue screen.",
    "translation": "",
    "context": ""
  },
  {
    "key": "382cba7ae7c66f6097f0dc16b6cad5ebc882661ca0b462a6cb103faa6b6958da",
    "original": "Losing named shields to orcs? Hire a blacksmith for your retinue and repair any item, even if its durability reaches zero.",
    "translation": "",
    "context": ""
  },
  {
    "key": "6bbbe00b3ebace69229ce62370bcc49c11173dbfca5ed66b29c9bccb8dd55b1a",
    "original": "Mortars of the city states can only fire if an engineer is next to them to operate them.",
    "translation": "",
    "context": ""
  },
  {
    "key": "a6a167a3e51f67feba187ea7de05069d3d433642082b5725d4eee5097ac15062",
    "original": "Nomads are a southern people that are not subject to the rule of a city state.",
    "translation": "",
    "context": ""
  },
  {
    "key": "a88d2c6d9bfa974a0978f7e3c7e735eafd1b53cc7683339b1cdcbd2066e20420",
    "original": "Nomads are experts in desert warfare and using the environment to their advantage - including throwing it in your face.",
    "translation": "",
    "context": ""
  },
  {
    "key": "d5d934b93cafff39384e47a563e7b673e5df987f066644b83339e83a42a0c525",
    "original": "Paying too much in wages? Hire a paymaster to reduce the wages you have to pay.",
    "translation": "",
    "context": ""
  },
  {
    "key": "716778c0da320d747b9f7278f5a697538505a8e49ce4144673e5c5459caef028",
    "original": "Smoke Pots can be used for a safe retreat even if your men are already locked in melee.",
    "translation": "",
    "context": ""
  },
  {
    "key": "e58f2ef8ddcc0246c3f48157f652ddf7696e491e0cad087751351763229546ff",
    "original": "The 'indebted' are a social caste of de-facto slaves in the city states, made up of criminals, prisoners of war and violators of religous dogma.",
    "translation": "",
    "context": ""
  },
  {
    "key": "dc608b41d86be8274e53f207d863a8a67e53858ff61819d36e8acd65b026a74c",
    "original": "The Fire Lance is reloaded after every battle just like throwing weapons are.",
    "translation": "",
    "context": ""
  },
  {
    "key": "0006221c75c15b1f8d49e95baa21a2a64a9d33d15a19f46e3187a9cc3c433c13",
    "original": "The Handgonne is a ranged weapon that can hit up to 6 targets with a single attack, but has less range than either bows or crossbows.",
    "translation": "",
    "context": ""
  },
  {
    "key": "c452467d8957aff403914e8804247c342d79d359256449f769592749808ff868",
    "original": "The Handgonne takes a whole turn to reload - unless your character has the 'Crossbows & Firearms Mastery' perk.",
    "translation": "",
    "context": ""
  },
  {
    "key": "a1f7c9e62b2b75520d07e3226639f8101fd4cdd1bf8fa43deaeebf52251f77bd",
    "original": "The southern city states are built on the ruins of the Ancient Empire.",
    "translation": "",
    "context": ""
  },
  {
    "key": "41c3ecad3d46e885f789aab1baf22b8def4d0ddc1825fd335255d2d8c5fa772b",
    "original": "The southern city states have made unparalleled advancements in medicine, astrology and alchemy.",
    "translation": "",
    "context": ""
  },
  {
    "key": "cc484bd5f2b4d57c0e2f42569c10d6486c24c51d2d6a4503856ead084e6541bf",
    "original": "The southerners call themselves 'Gilded' after their god, in whose shine they bask day in and out.",
    "translation": "",
    "context": ""
  },
  {
    "key": "1ff61a2b7be83abdef0764c4519fba804d9d424fe7ddd855ee26f2a165623ef3",
    "original": "Training your new recruits takes too long? Hire a drill sergeant to have them gain experience faster.",
    "translation": "",
    "context": ""
  },
  {
    "key": "aa9fd3ffb6506823c92e6daa93f970fda6ebb4270f23ca28981c67f17c4057ed",
    "original": "Try out different retinue followers to find those that complement your playstyle and chosen company origin.",
    "translation": "",
    "context": ""
  },
  {
    "key": "f0cacd198d162780ce7e64838332b61e21057a3635715ac404a3fd045c41fb72",
    "original": "With the 'Gladiators' origin you start with three powerful characters, but losing all three will end your campaign.",
    "translation": "",
    "context": ""
  },
  {
    "key": "08a3e33f56d065f20c77fe8f6042cf4570b4a6a4a476ba5c77fa3a0251ba57f5",
    "original": "With the 'Manhunters' origin you can make prisoners after every battle against humans and force them to fight for you.",
    "translation": "",
    "context": ""
  },
  {
    "key": "6ce9a034c11b4de6e64e4febafc128397b580614326b70252155ddb04187de43",
    "original": "Wondering who went there? Hire a Lookout and get more information on any footprints on the world map.",
    "translation": "",
    "context": ""
  },
  {
    "key": "affa85cb21ce749926dbc67dac3870f44aabee6cdb7e13ba3ac0dfa46f35bea5",
    "original": "You unlock slots for your retinue of non-combat followers by gaining Renown.",
    "translation": "",
    "context": ""
  }
]