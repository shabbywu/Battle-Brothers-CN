[
  {
    "key": "a15d10e154093fa5eb9e2eab33e3fa3833259f566aa58b9620f8e1b8ac412e65",
    "original": "A Hexe appears as a youthful lady with radiant beauty to those she enthralls.",
    "translation": "",
    "context": ""
  },
  {
    "key": "d3ad6b446d34f929edf091b41e5db4d48018bdd79ee598f6c8c5590b3645a953",
    "original": "A Hexe can curse one of your men to suffer the same wounds as she does.",
    "translation": "",
    "context": ""
  },
  {
    "key": "a551087f8fa19f1b650b2d25f38658055b7d1a7c47d0329baa84e19fe016d390",
    "original": "A Lindwurm is a wingless bipedal dragon resembling a large snake.",
    "translation": "",
    "context": ""
  },
  {
    "key": "2d3eba52100c946b2e74a5181ecd5b491f1b7100fcb09e95a0265bbf4db63d42",
    "original": "A Schrat is a living tree, a being of bark and wood, with a mind truly alien.",
    "translation": "",
    "context": ""
  },
  {
    "key": "adba681333a0e7249f2cdf307f5862b4e72184cd1ea2e5f04d2b071d12b7795d",
    "original": "Alps are almost exclusively encountered at night.",
    "translation": "",
    "context": ""
  },
  {
    "key": "c69a600b8e63b9dba8b0988ac282d3ef823863aa8391c6143b56b698a39b1096",
    "original": "Alps feed on the fear and agony of people having nightmares.",
    "translation": "",
    "context": ""
  },
  {
    "key": "8a73590d75502f65d5d7d07c23f236b261369d0ef2beba31ace3b17696b0e483",
    "original": "Axes are particularly effective against trees.",
    "translation": "",
    "context": ""
  },
  {
    "key": "f6059670b19f47e9a26cec76a31a6b88ec1f6b9881e25e0bc214d61eb7aa708e",
    "original": "Collect trophies from slain beasts and have the taxidermist craft useful items from them.",
    "translation": "",
    "context": ""
  },
  {
    "key": "146980ab4e8f7df985f2759aecf0fda950c93bf9d37109c4537beae3b60e5336",
    "original": "Explore the world to find legendary locations with legendary treasure.",
    "translation": "",
    "context": ""
  },
  {
    "key": "91c1941fd0dbb6959ccc3e2911752d6b80f3edd4af2480fb42f10f0dcc3773db",
    "original": "Fencing swords are most powerful in the hands of characters with high initiative.",
    "translation": "",
    "context": ""
  },
  {
    "key": "51d02aec358404d415d8e6906a7d5c0099cd65d3721090c739fbf86b902d2138",
    "original": "Hexen are known to strike ill-omened deals that people come to regret.",
    "translation": "",
    "context": ""
  },
  {
    "key": "5e07fa3d079cde7aea723391a5b4bd458be48269865809703019fa5af627add6",
    "original": "Nachzehrers are found more often in the southern parts of the world.",
    "translation": "",
    "context": ""
  },
  {
    "key": "8327a26be0f03b3ef0a38f486b84a4fd3fe2f8613e8839d5fa31cdbd1bc3a1ae",
    "original": "Overdosing on potions can lead to characters vomiting and getting sick.",
    "translation": "",
    "context": ""
  },
  {
    "key": "10623159367f5158c470768ab2733c0387d201ad28041105a3385215b05687bd",
    "original": "Potions, despite their colorful descriptions, are essentially drugs, and characters can get addicted to them.",
    "translation": "",
    "context": ""
  },
  {
    "key": "3ec10553daed5d1b336f7f72f26465d45bed3dd4619093be09d974a50facf067",
    "original": "Selling trophies from slain beasts can be lucrative. You can always get new ones.",
    "translation": "",
    "context": ""
  },
  {
    "key": "5852247e64e4152781697c171dac67e0f92632afd6872feb18a221c5b3dd2d3f",
    "original": "The Webknecht is a large arachnid that lives in sizable colonies in the dark areas of forests throughout the world.",
    "translation": "",
    "context": ""
  },
  {
    "key": "037554b19ef30dadab9b24beb36040abf84b72f53b86290c03bd741dd745ca76",
    "original": "The frozen wasteland of the north is home to a giant beast not seen anywhere else.",
    "translation": "",
    "context": ""
  },
  {
    "key": "b3dadb1a6204a101803ee425d0c508a8a3916e752e30a64cea6277f8960ae549",
    "original": "The further away from civilization, the more dangerous the beasts that roam the land.",
    "translation": "",
    "context": ""
  },
  {
    "key": "1aafc11cbc3fa48419be7c0a86115aafae0e0686ffda64a5eaead56309899d2f",
    "original": "There are different regional variants of the Unhold.",
    "translation": "",
    "context": ""
  },
  {
    "key": "cddda6e3b23d160ce8d65f0aa5b4fc2478ef54b3d195dbe0e702700efb42cc4f",
    "original": "Trees move slowly.",
    "translation": "",
    "context": ""
  },
  {
    "key": "49359a37acb98341b2dcc9bb7884cb357abcb607ae32eac5214a96b82a195a08",
    "original": "Two-handed maces excel in disabling single opponents.",
    "translation": "",
    "context": ""
  },
  {
    "key": "8cf16e6782a7fb31b4658cec13c9179c480cbb29a167efe2cfa9e8d150eda1f0",
    "original": "Unhold",
    "translation": "",
    "context": "!\"Unhold\" || !this.Const.DLC.Unhold"
  },
  {
    "key": "c53b652373d7e21815d242e9e48d60e24a4da4b78ce04d854d545982b1f6f0ca",
    "original": "Unholds can heal wounds quickly, even in combat.",
    "translation": "",
    "context": ""
  },
  {
    "key": "7e47a0ddf5169ae6e8420aa4371ac7dc9fc1f407f2abedf544c167217f710f66",
    "original": "Use armor attachments to further improve and specialize the equipment of your men.",
    "translation": "",
    "context": ""
  },
  {
    "key": "99ee02f0ff7d0a4b3479d4b777cf752df732bbde90787930ff1c410b23db0168",
    "original": "Use throwing spears to destroy the shields of your most dangerous opponents from afar.",
    "translation": "",
    "context": ""
  },
  {
    "key": "69ec19c6ff3f29af24179fc8fa83a116fb691872814f17c30d1dbe8ffa3806cb",
    "original": "Webknechts are more confident, the larger the group they are in.",
    "translation": "",
    "context": ""
  },
  {
    "key": "943ef1d9b939206f514a73ac86fed9ad7d3d604e7b2b24e6d6f7431cde24cfcc",
    "original": "Webknechts inflict additional damage to targets trapped in their webs.",
    "translation": "",
    "context": ""
  },
  {
    "key": "2e6313750b9763694279ce448ee472a89dd719a48f05981badd8da801d62a052",
    "original": "With the 'Beast Slayers' origin you'll have an easier time tracking beasts and get more trophies from any of those you slay.",
    "translation": "",
    "context": ""
  }
]