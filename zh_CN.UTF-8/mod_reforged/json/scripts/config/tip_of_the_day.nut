[
  {
    "key": "def430aa56db0a3e3c30649b0a440c4a2f0b2667b334b76931156fdc3162b136",
    "original": "A 95% chance to hit is also a 5% chance to miss.",
    "translation": "",
    "context": ""
  },
  {
    "key": "3f1ac39522b9d542fe50bbd71432214701052a542720491af68172d75d48adec",
    "original": "A character with a height level advantage over their opponent is harder to hit.",
    "translation": "",
    "context": ""
  },
  {
    "key": "d680eea17a00609ce365362e7925cf23551450e23cfe97d3f2baafdcd326dd68",
    "original": "A goblin is no match for an adult human physically, so they rely on wit and dirty tricks.",
    "translation": "",
    "context": ""
  },
  {
    "key": "214fede0de07104c9f327c444002a65aeb843f087e07809e60b8c33f2691b0c2",
    "original": "A human is no match for an adult orc physically.",
    "translation": "",
    "context": ""
  },
  {
    "key": "cbfc6869274d0a60994c75f915e9f83dc80d516636166e70d8ed64d6da1850d3",
    "original": "A life can be worth little in this world.",
    "translation": "",
    "context": ""
  },
  {
    "key": "96809b2f460b62b03cb00f2ab5547956f67b0df14974bbd3a0cfb7fb30ddcec8",
    "original": "A missed ranged attack can hit nearby characters, especially if they are in the direct line of fire.",
    "translation": "",
    "context": ""
  },
  {
    "key": "4d481ed08d586cdb3563034167c7eb98d2034c019e82db1b0d6f349b85e9c282",
    "original": "Always keep a good stock of provisions - lest your men starve and desert you!",
    "translation": "",
    "context": ""
  },
  {
    "key": "9dab66810280ebade31e587aeab1419fec2ff2806e56b3e8bbef34bd41db0b3d",
    "original": "As brothers we fight, as brothers we die!",
    "translation": "",
    "context": ""
  },
  {
    "key": "10cbb5bebc427408a629aa0a18fdcd230a2f395a97c01e1cb5b06ee71de8b324",
    "original": "Betraying your employer can have repercussions in the long run.",
    "translation": "",
    "context": ""
  },
  {
    "key": "9e435b7b1fe1423c1f87a357fbf1b500ac78afe4a7f114ae6bb7057907a2095c",
    "original": "Bows can not be fired and crossbows not be reloaded while engaged in melee.",
    "translation": "",
    "context": ""
  },
  {
    "key": "2e35ac446653128fd6ed4757ba14990c98cb7d877e5ecd847c3e9327c83378e6",
    "original": "Bows perform better against unarmored targets.",
    "translation": "",
    "context": ""
  },
  {
    "key": "25c43d5ac2b89cbf1f507c1589d1ba952eab06cea4b5b7b773ace5f9e3825abf",
    "original": "Breaking a contract will anger your employer - especially if you've received advance payment.",
    "translation": "",
    "context": ""
  },
  {
    "key": "349c4f52eeeb600544c4af4dc7d44676cf68f276bccf6c5d6303c3b63c7df569",
    "original": "Characters can see farther, the higher they are positioned.",
    "translation": "",
    "context": ""
  },
  {
    "key": "41551d876a2ab797870c030b8b0494bb0c0141b48fc3dfe48e8170a0c9e021f7",
    "original": "Characters may sometimes be struck down during combat, but not outright killed, and will survive with a permanent injury.",
    "translation": "",
    "context": ""
  },
  {
    "key": "72756c89fb46c293949bd00581cdf362fea999a4d717c7fa0eb87b5dde64219d",
    "original": "Cleavers can inflict bleeding wounds.",
    "translation": "",
    "context": ""
  },
  {
    "key": "faeedb956fa429cd151333664f28a4497415c69f9fbecc6158ee6e40813c7f91",
    "original": "Clubs and maces can stun or incapacitate targets.",
    "translation": "",
    "context": ""
  },
  {
    "key": "4a9369a006fe0eb68cb9592fd54c75679b94003438a42dc12fea8fca6e282b40",
    "original": "Conserve your stamina when in prolonged engagements.",
    "translation": "",
    "context": ""
  },
  {
    "key": "a80f4a9f9cc282d214364c7d37cf4230ed92e15e11698c307d55cc9f0391485f",
    "original": "Consider building up a reserve roster and rotating your men, so you can more easily deal with losses down the road.",
    "translation": "",
    "context": ""
  },
  {
    "key": "9b3db48fbaee7327a296cfe0d716695d2a4dcb4c12d16f482ede5914880ccc46",
    "original": "Consider forming a shieldwall when surrounded.",
    "translation": "",
    "context": ""
  },
  {
    "key": "1e36596543100b294da820c5d61c25ff1f1b9daa3151f68303c1fb913e8c77c7",
    "original": "Consider putting injured characters in reserve until their wounds have healed.",
    "translation": "",
    "context": ""
  },
  {
    "key": "7f74f6907a97f238f7b9a1d41a581552c15cb63a5c2ec5bb06102f775b72a747",
    "original": "Consider that enemy encampments on hills are harder to assault, especially if they are fortified.",
    "translation": "",
    "context": ""
  },
  {
    "key": "4906566bf7560b240d2c76b5851d18b5fa5c71b0946572e9e48f6288f1e0a37e",
    "original": "Crossbows require less skill to fire accurately than bows, but are slower to use.",
    "translation": "",
    "context": ""
  },
  {
    "key": "f9116ebcedae20514cd4012453580552413b8f45f48397020e2938c0f10e78ef",
    "original": "Daggers can be used to attack weak spots in armor and deal damage directly to hitpoints.",
    "translation": "",
    "context": ""
  },
  {
    "key": "31488e764f5e2922e7f0bf3069e3c030f0ba9841315b65a28958a9b5e481a242",
    "original": "Different backgrounds may unlock additional options at handling events and contracts.",
    "translation": "",
    "context": ""
  },
  {
    "key": "ea89d96d2a09429df037327edb78182207d36e17e78e0c85690dddb9ae46a43b",
    "original": "Different types of enemies require different tactics to beat reliably.",
    "translation": "",
    "context": ""
  },
  {
    "key": "fd8546c9092b66ac570ab77b03a1837f500962468569347e6b253aecedfb452b",
    "original": "Different types of shields are better suited against melee or ranged attacks.",
    "translation": "",
    "context": ""
  },
  {
    "key": "17e7bb6b14eb88bdbdeb6a4ce92fdba187cf9271fe11ad132b2022135806285b",
    "original": "Difficult terrain, such as mountains and swamp, has your men use more supplies on the worldmap.",
    "translation": "",
    "context": ""
  },
  {
    "key": "278b89e0024faa93cf6e0379d559be6e7d5d87f65f6a25c671213bf4dcd60e07",
    "original": "Do the job. Survive. Get paid.",
    "translation": "",
    "context": ""
  },
  {
    "key": "ad6266ff22ff02ffb45f19c9411ae8ea30b93fb264536bbc71b7297cc7d8956b",
    "original": "Drag and drop your men in the inventory screen to where you want them to be in your formation.",
    "translation": "",
    "context": ""
  },
  {
    "key": "fd937c58f884fcc1340840def5548f7f1e2639c8f1071abd7fb0feff0cd4791f",
    "original": "Dying is part of a mercenary's job description.",
    "translation": "",
    "context": ""
  },
  {
    "key": "676e1e1392690c8add6a0a7b48007ce81927a17788576b6d477944be199d7dab",
    "original": "Each type of weapon has advantages and disadvantages.",
    "translation": "",
    "context": ""
  },
  {
    "key": "44de64758279d8a9b906cb2d82019178a37cfd83be1e46d8d26f8f95c51c37f1",
    "original": "Elevated terrain like hills and mountains allow you to see farther on the worldmap.",
    "translation": "",
    "context": ""
  },
  {
    "key": "e26574f6b83a0ade77294e843e434ba7f9aa0dbb68a78a4e2a2fb926e415fd89",
    "original": "Every enemy in the game can be beat reliably with the right approach.",
    "translation": "",
    "context": ""
  },
  {
    "key": "b9bc86ba2739f472b3c4ed9c55099c92c3674046720f5cd9536301a1d45ac707",
    "original": "Expect to lose some men.",
    "translation": "",
    "context": ""
  },
  {
    "key": "75db4b24b40db26a8b70323ff2f606fef115c09ac109cedbab8da1cc9c5dfc66",
    "original": "Flails ignore the defense bonus of shields.",
    "translation": "",
    "context": ""
  },
  {
    "key": "5e0324829879f9780934a7343eee8749c61d08f61d99e6febea5a6b42969d99a",
    "original": "Forests can hide many dangers within.",
    "translation": "",
    "context": ""
  },
  {
    "key": "656031edfb02e4a45c034b1c7da777c188fd15bb399120af484134f42b7db124",
    "original": "Fortifications will only offer you contracts from the noble house that owns them.",
    "translation": "",
    "context": ""
  },
  {
    "key": "351f87d0d9135596eb4d46d0a968343059cf936cf0449e18addd897ad0f55863",
    "original": "Fulfilling ambitions will raise everyone's mood and grant you renown, as well as some unique rewards.",
    "translation": "",
    "context": ""
  },
  {
    "key": "b6cd43dd07d1668d959fc4217ad671e81468022060d8e5d9cc3840f296690705",
    "original": "Geists are lost between the physical world and the world beyond, constantly shifting between the two.",
    "translation": "",
    "context": ""
  },
  {
    "key": "c0bf20862b162c5c6e26d5d518bc06eebd4d188bbfbbfb4cb649281e68035ed8",
    "original": "Geists test the resolve of your men - the lower, the more likely they are to panic and flee.",
    "translation": "",
    "context": ""
  },
  {
    "key": "f3e61a184972377a233f7c6b9e390e2691f0908d8c8c6afa8cee48cdddd94240",
    "original": "Having men of different backgrounds in your company may enable you to perform different actions in events.",
    "translation": "",
    "context": ""
  },
  {
    "key": "9c84023f3d2a54123f1ea5a554b25d254a46eda5723738bcfa43b7e9a9d89af5",
    "original": "Heavy armor offers great protection, but also slows down the wearer and makes him tire more quickly.",
    "translation": "",
    "context": ""
  },
  {
    "key": "1c8e084b7db5359acb5fd7e2a2a78fe6ca82e15b6f1db27151ca08a8933dfa44",
    "original": "Heavy helmets can be hard to breathe in and limit the field of vision.",
    "translation": "",
    "context": ""
  },
  {
    "key": "46b0a36df09454b750b51a9adfeb26bb64f62204a7874ce439b5b8d6b9466fbd",
    "original": "Higher renown will unlock more difficult contracts and better pay.",
    "translation": "",
    "context": ""
  },
  {
    "key": "013f0f2880390fca9378f6e7b5e233a972d70c673bdc96d1d819dae0315a7c4f",
    "original": "Highly talented characters can come from all backgrounds.",
    "translation": "",
    "context": ""
  },
  {
    "key": "054fcb7c6b417c46b6363e7ae2738bd312075808b95410a830b22fdaba7c2d37",
    "original": "If a character waits their turn, their position in the turn order of the next round is determined with a penalty of 25% to Initiative.",
    "translation": "",
    "context": ""
  },
  {
    "key": "ecbd30344ed707c449de8300c7550a0aad5645eccb0ac4d34bd60dc63eb08dac",
    "original": "If contract negotiations turn sour, it will damage your relations with your potential employer.",
    "translation": "",
    "context": ""
  },
  {
    "key": "8cc04af626f67a98277c25b7c9d87654bbfdc7965cce46c8e46c1724f702dde8",
    "original": "If you can not win, retreat to fight another day.",
    "translation": "",
    "context": ""
  },
  {
    "key": "ed1ca5cebbc96ec7742b31d148406a6126c1bf3c130937dccc8ee42770d2eeab",
    "original": "If you keep losing to an enemy, change your tactics!",
    "translation": "",
    "context": ""
  },
  {
    "key": "1aa48894959827fee8cd7622f9808e5ef2f9badb061204c07170b54185ed9264",
    "original": "If your plan can fail with bad luck, maybe it isn't good enough of a plan.",
    "translation": "",
    "context": ""
  },
  {
    "key": "582a2cc1e187f9bde8a0721b28afcfd0ceb9cfa14d03dc85d2a823048f295742",
    "original": "Keep an eye on the mood of your men. If they are angry for too long, they may desert!",
    "translation": "",
    "context": ""
  },
  {
    "key": "14b684d8a27bedba866604bbbadb7b2dd2aa3154c35df11e3af1c633f5ba2c41",
    "original": "Learn from your mistakes. Don't just repeat them and hope you'll get lucky this time.",
    "translation": "",
    "context": ""
  },
  {
    "key": "da3526227cf4373b5c83a6be46199b18805685d34a60e5c8702da6be7e6e80a1",
    "original": "Learn the 'Rotation' or 'Footwork' perks for additional mobility in battle.",
    "translation": "",
    "context": ""
  },
  {
    "key": "b991694c9a066b17803fac26e2c835afcd2ed0babdc491f11313ffb98e385c25",
    "original": "Longswords and Greatswords can hit multiple targets with one strike.",
    "translation": "",
    "context": ""
  },
  {
    "key": "2525afd57578a2c1a97946fae24971894ebf285afd1c1af4de1ace4275fa9707",
    "original": "Losing is fun.",
    "translation": "",
    "context": ""
  },
  {
    "key": "0118994e77103101c0aa846d02bd22aa0e47096819825d014f0630d744c33e8b",
    "original": "Make camp to have your men heal and repair their equipment faster.",
    "translation": "",
    "context": ""
  },
  {
    "key": "f1b2a348d62c34e588966ef65d12f7f1074a4b2cbd07e2efbd10cbe8ba8fda25",
    "original": "Nobles give contracts only to mercenary companies with professional renown.",
    "translation": "",
    "context": ""
  },
  {
    "key": "0c15dd1e8995d0a36fd23ae8c9bb378483c7ffcdf9812af3135ab8f0686bd96b",
    "original": "Not every battle can be won.",
    "translation": "",
    "context": ""
  },
  {
    "key": "cc76f1cd821eab623b877eb0a032cf05443e98f15da351aca3026ba5f862ffd0",
    "original": "Not every contract is worth the risk.",
    "translation": "",
    "context": ""
  },
  {
    "key": "08b899474c056fbcebd2100dc32765c8fd72cf32be1b599471b68edbec93a778",
    "original": "Objects blocking tiles can be highlighted using the 'B' key.",
    "translation": "",
    "context": ""
  },
  {
    "key": "abd2e2c068d8a77c76183a2715a65a582539242a5c7f10a8aabe76518fb58896",
    "original": "Orc Berserkers gain rage and get tougher to take down, the more blood they have drawn.",
    "translation": "",
    "context": ""
  },
  {
    "key": "90d4f1b3ca7b8f51ae21127667fe1da1094b433efa7d2de10d6c0932bce4b415",
    "original": "Orcs rely on raw power and physical prowess.",
    "translation": "",
    "context": ""
  },
  {
    "key": "182cf4ac654e50b5ff9f2282b3878cd8beed1a2307f709520c8ee2ce2d650c08",
    "original": "Ranged weapon accuracy drops with distance.",
    "translation": "",
    "context": ""
  },
  {
    "key": "112aa01000e2ab571067b1461fddc2c14657fa30bd985d872969bdd364bf779c",
    "original": "Ranged weapons are less accurate at night - those of your enemies included.",
    "translation": "",
    "context": ""
  },
  {
    "key": "eaa790c10e29bf4a729d35c710184735aaca516c58e21c5b596369083645e7c6",
    "original": "Ranged weapons work best when firing into groups of enemies - they are bound to hit someone.",
    "translation": "",
    "context": ""
  },
  {
    "key": "833826c581519dab886277047bd539327152f2e37a55e2acdd37a4c1f69bacd8",
    "original": "Retreat. Flee. Don't fight every battle to the death.",
    "translation": "",
    "context": ""
  },
  {
    "key": "eb64b81a443efbe659b1a175b8c22d7edf972c25d25419d56e63a3619ca5d738",
    "original": "Roads are the fastest way to travel over land, but not always the safest.",
    "translation": "",
    "context": ""
  },
  {
    "key": "e028e7d5e33c5de41ecb429241daded7007bc687030cde6027db703f90365d0e",
    "original": "Selling in rich and big cities will net you the most crowns for your goods.",
    "translation": "",
    "context": ""
  },
  {
    "key": "f9c638b64d60c32efa033b34c5dd918148fe9331b5d4a1e08012fbf00aa8747c",
    "original": "Shields can be destroyed using axes and some two-handed weapons.",
    "translation": "",
    "context": ""
  },
  {
    "key": "73df700f1e1a3ef7796441f02223c536d53b9832b2b54327c9262e107284fd68",
    "original": "Shields take minor damage each time they are used to deflect an attack.",
    "translation": "",
    "context": ""
  },
  {
    "key": "348dba502e942b40e9b20461a3ce8e0469e0c8cce1d49c1f2caf1847fc91de32",
    "original": "Shrubbery can hide characters from being detected from afar.",
    "translation": "",
    "context": ""
  },
  {
    "key": "b0a85f87f23dcffc49a044a72c68e90834118fe7f6031c5ae946081cc50bde8f",
    "original": "Skeletons are highly resistant to ranged attacks and fire.",
    "translation": "",
    "context": ""
  },
  {
    "key": "968f0a0d687f9f0d6ee150325d9d187e5376c896eac9ba254042bf3bc932d3ff",
    "original": "Some difficult terrain, like swamp, gives combat penalties.",
    "translation": "",
    "context": ""
  },
  {
    "key": "cf340ce29f1a72159817ffa19444b60d9c0cb3c57b11980605b7cabed817ca9d",
    "original": "Some parts of the world are more dangerous than others.",
    "translation": "",
    "context": ""
  },
  {
    "key": "f7dd52bcb2fb5680e99384504decd7724853b7f668fe1d72ed4d2f2ed6821860",
    "original": "Some people will use you and throw you away.",
    "translation": "",
    "context": ""
  },
  {
    "key": "47404b39254e2e4a2bf81281939d1f31233fef368ad68fc7a7e7f71146b24fee",
    "original": "Spears are good defensive weapons due to their Spearwall ability.",
    "translation": "",
    "context": ""
  },
  {
    "key": "f4696e9153ac2f98178d4adb56d3f84e3723220c96e8e524792e1e92dc69e8d5",
    "original": "Stunned characters get no attack of opportunity when someone moves inside their zone of control.",
    "translation": "",
    "context": ""
  },
  {
    "key": "661c09113e62f56e911ddf88c01c5bbfe72c0724d9b7fbe9460cf7d76aedf5df",
    "original": "Success in Battle Brothers is also about picking the right fights.",
    "translation": "",
    "context": ""
  },
  {
    "key": "b670ecee078781f49047acb7233d28af544567d0479407d0ac97750500922fdf",
    "original": "Surrounding an opponent from multiple sides makes it easier to score a hit.",
    "translation": "",
    "context": ""
  },
  {
    "key": "eebcd41115699c8366dfb72edcd7e3d26107504c25291f7ee8607ddf40df7b51",
    "original": "The 'Fast Adaptation' perk reduces variance of randomness.",
    "translation": "",
    "context": ""
  },
  {
    "key": "4277536eac1501caa27c87991cda011de4b3d1937e6ed63f687417e908208c5c",
    "original": "The 'Lone Wolf' perk is not affected by nearby dogs or allies that are not part of your company.",
    "translation": "",
    "context": ""
  },
  {
    "key": "377eadfaf62d265f8f7290f5ec5e8100d6bbe5ab2f4271d6ff02de3329b5ae99",
    "original": "The Billhook, Pike and Longaxe can attack over 2 tiles, unlike most other melee weapons.",
    "translation": "",
    "context": ""
  },
  {
    "key": "2bfa4e746b0285c4c2384131112348e6abb2d701b562118f1cab4267da42cf5a",
    "original": "The higher their level, the more your men will demand in wages.",
    "translation": "",
    "context": ""
  },
  {
    "key": "4a42ae5c16d1cc6349132fd12584f3ad9ee070ca11787183b053d4002eacd7f2",
    "original": "The larger a party on the worldmap, the slower it moves. Yours included.",
    "translation": "",
    "context": ""
  },
  {
    "key": "b4fe05ab2fc55974c9339b525bdd471ca9fe7c5ee97db904622099a5dbe4b792",
    "original": "The minimum hit chance for any attack is 5%, and the maximum hit chance for any attack is 95%.",
    "translation": "",
    "context": ""
  },
  {
    "key": "a6937c42ff16cc636c5211e49a8184ca77a55443dfe86e3607a370871a4623fe",
    "original": "The natural habitat of direwolves is the forest.",
    "translation": "",
    "context": ""
  },
  {
    "key": "fcc5ee11359cb55f27db1544db05122289e07e30f4a702e592985cae34615fc3",
    "original": "Throwing weapons can be deadly on short distances, but their accuracy drops sharply the farther away the target.",
    "translation": "",
    "context": ""
  },
  {
    "key": "f8b99eb43ec3161b9f284fb5933c0f1d39e5667b08e47e6ec0bbd0f5c14f8aa6",
    "original": "Trees can be hidden in combat using the 'T' key.",
    "translation": "",
    "context": ""
  },
  {
    "key": "1e84adca20686930f1d8a926cc0e92f7fa307130c9cea10d0431e802c4d182d1",
    "original": "Try playing a campaign in veteran mode once you've gained some experience - it's the recommended difficulty.",
    "translation": "",
    "context": ""
  },
  {
    "key": "3d50825845a23988c3c4852f8a39a2d8059afdcb84414b4fb74a2367b247e6b9",
    "original": "Try the Ironman mode to experience Battle Brothers the way it's meant to be played.",
    "translation": "",
    "context": ""
  },
  {
    "key": "f88bd2a140a7831f420ba5031717fd8f09b67373da8041ad7fb85c489a3140d9",
    "original": "Try to negotiate better payment for your contracts.",
    "translation": "",
    "context": ""
  },
  {
    "key": "76748e5936001f87e037213c2c19ebdafbc9df248bcf2eee06c9e2f670207397",
    "original": "Try to negotiate payment modalities that guarantee you the most money for contracts.",
    "translation": "",
    "context": ""
  },
  {
    "key": "985bac49ebe2a3236c3624ded054b992e08a29b5c38dd14804ffa088786d5fce",
    "original": "Try to save some crowns for when things turn sour.",
    "translation": "",
    "context": ""
  },
  {
    "key": "8a3316509d83db93487820962bd5a64f0604fc8b13d344e6ffa7ebd87f5fadfe",
    "original": "Two-handed axes can hit both head and body with a single hit.",
    "translation": "",
    "context": ""
  },
  {
    "key": "fe5dbab88636c77344aca3ca0eb2092909005e58c9218337cb51348d72acd281",
    "original": "Two-handed axes can hit up to 6 targets with a single round swing.",
    "translation": "",
    "context": ""
  },
  {
    "key": "2d37019147e8837727aaf5ec556dbec3a33c1d9e02f96b10cdf3804a7eb9d8c7",
    "original": "Undead are unaffected by fatigue and morale.",
    "translation": "",
    "context": ""
  },
  {
    "key": "7c13ceb7de47406720aa2499208463198e150aee86919bbf31a425d31eea03e9",
    "original": "Use ALT + Right Click to mark items for repair in your stash. Items equipped by your men are repaired automatically.",
    "translation": "",
    "context": ""
  },
  {
    "key": "4941b78e31e823a22b44f4f5914afd2f1ad24a068d5c1f05b2915045ebf5fc0e",
    "original": "Use CTRL + Left Click to attack allied parties on the worldmap. This only works if you are currently unemployed.",
    "translation": "",
    "context": ""
  },
  {
    "key": "f2c64e6c9136cdc4673fd79735f20fa8b2ec50a6fadea8292f0d512e6a8f7dd9",
    "original": "Use a trained falcon to discover hidden enemies on difficult terrain.",
    "translation": "",
    "context": ""
  },
  {
    "key": "d56ca3b394bc01c4135f7d763b3e9490d94d587d16dd20b617781e3c539f7341",
    "original": "Use ports to fast travel around the world.",
    "translation": "",
    "context": ""
  },
  {
    "key": "202efa92ad5fa6ddb499665b121f0814151a4c54be6a0a5b192b8ae923d883c0",
    "original": "Use terrain and chokepoints to your advantage.",
    "translation": "",
    "context": ""
  },
  {
    "key": "178022c2cbd91f5fcffc4c0de69cad71a652dc3933c7cb98c8adbe613ed77eb2",
    "original": "Use the spacebar key to pause on the worldmap.",
    "translation": "",
    "context": ""
  },
  {
    "key": "d21143e197c37bc51285f1a7be99006536b1723be09da9839f3ea48f33e2a33b",
    "original": "Use throwing nets to restrict the movement of particularly dangerous enemies.",
    "translation": "",
    "context": ""
  },
  {
    "key": "56de7ba178afd876854725ae4720f003a1b1abc997c84f49bd1dbe9494cd82d2",
    "original": "Use trading to supplement your income.",
    "translation": "",
    "context": ""
  },
  {
    "key": "fc89a9387b4c1d9fb326fd772bdf9dc0e5e3d45035755504889c27afe37c35cd",
    "original": "Use wardogs to hunt down elusive or fleeing enemies.",
    "translation": "",
    "context": ""
  },
  {
    "key": "2c8bf1f465d9bf9caad1e73b53136cc0bfb8456674afa3e0920eec4eb9ba0403",
    "original": "View range is decreased at night, both in combat and on the worldmap.",
    "translation": "",
    "context": ""
  },
  {
    "key": "c45a330b32129041cb0935f673cad8bd32ae97ddb2fba56119f3ea8adeb9b9f1",
    "original": "Warhammers and Military Picks can make short work of heavy armor.",
    "translation": "",
    "context": ""
  },
  {
    "key": "ecf6fcc62ebdb957ff20c989ad4a52c960581014f762eb91a7232f06b0191f86",
    "original": "Wiedergangers are the dead walking again.",
    "translation": "",
    "context": ""
  },
  {
    "key": "cbcea1c8c8964945f303bfd80cf52e3549804c41495343e00dc7fd3bf7c97fbc",
    "original": "You can change camera height levels using the + and - keys.",
    "translation": "",
    "context": ""
  },
  {
    "key": "0c7e47c6b1ea049e115ddcc3d2e5c0cfe59c09ee288cc4da9b5df3f6ef0df88e",
    "original": "You can enable faster AI turns in the options menu.",
    "translation": "",
    "context": ""
  },
  {
    "key": "05b6f996e02a4dbc46ddd8f6912d45ce8dd28b0e2c5b1eebd31dd53754c19e2f",
    "original": "You can find contract offers in the top left of settlement screens.",
    "translation": "",
    "context": ""
  },
  {
    "key": "5cc39a5d44e11c777acd49428d12178f7aecfa1cf508ad401cb643908dfbb9f7",
    "original": "You can have your items repaired at the smith for a fee by using ALT + Right Click.",
    "translation": "",
    "context": ""
  },
  {
    "key": "da1d211ef7b219244d08ed93fe22465387e87b580fecba0d9fdf5361f695e0f0",
    "original": "You can zoom in and out using the mouse wheel or Page Up and Page Down keys.",
    "translation": "",
    "context": ""
  },
  {
    "key": "6adaa50d862d6af2fa51cc4d63f6c3ba96b8828468c3fb4f8e39f9726b604778",
    "original": "You don't have to be a hero, you're running a business.",
    "translation": "",
    "context": ""
  },
  {
    "key": "7d53e8ce21fbe841be3ce044d72aaaff83088ab0499334b8fe2e76d7c03af2df",
    "original": "You may find powerful named items far away from civilization by exploring or following tavern rumors.",
    "translation": "",
    "context": ""
  },
  {
    "key": "73990c92b30b7b4249e91c91fb55c984f44576927b44c7f8cc9b2bbe2c68e630",
    "original": "Your men will interact with each other differently depending on their backgrounds and traits.",
    "translation": "",
    "context": ""
  }
]